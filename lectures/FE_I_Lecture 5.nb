Cell[CellGroupData[{

Cell["Threshold Autoregressive (TAR)-GARCH Model", "Section",
 CellChangeTimes->{{3.406269143060752*^9, 3.406269147568752*^9}, {
  3.530599059624044*^9, 3.530599065584362*^9}, {3.530691073690981*^9, 
  3.530691075674041*^9}, {3.53069147302001*^9, 3.530691474871354*^9}, {
  3.530693029400872*^9, 3.5306930616095943`*^9}, {3.530794625264617*^9, 
  3.530794629791909*^9}},ExpressionUUID->"d5905f37-d638-4ab4-b478-\
b4f0331fb4b6"],

Cell["\<\

Threshold Autoregressive (TAR) model can be used to refine the model by \
allowing for asymmetric response in the (volatility) equation to the sign of \
shock. We can observe asymmetry in declining and rising patterns of examined \
time series. Model uses simple threshold to improve linear approximation. We \
demonstrate the idea on a simple two regime AR(1) model and then we proceed \
to threshold model in the variance equation.
\
\>", "Text",
 CellChangeTimes->{{3.4062691559797516`*^9, 3.406269427871752*^9}, 
   3.5296755517986937`*^9, 3.530691101115761*^9, {3.530691203421274*^9, 
   3.530691263909665*^9}, {3.530691298812022*^9, 3.530691587991209*^9}, {
   3.5306916569332542`*^9, 3.530691791578145*^9}, {3.530691826696795*^9, 
   3.5306918520562468`*^9}, {3.530691904724057*^9, 3.5306919544418077`*^9}, {
   3.5306920106236897`*^9, 3.530692199564807*^9}, {3.530693289725193*^9, 
   3.530693296399984*^9}, {3.530717495965859*^9, 3.5307175484304113`*^9}, 
   3.530779904529253*^9, {3.5307800233656797`*^9, 3.530780036975236*^9}, {
   3.530780094991973*^9, 3.5307801160746*^9}, {3.5307946477911673`*^9, 
   3.5307947090563393`*^9}, {3.5307947890058947`*^9, 
   3.5307948548863373`*^9}, {3.5307949081432953`*^9, 
   3.5307949979202967`*^9}, {3.530855310141869*^9, 3.5308553126396437`*^9}, {
   3.5308624365234756`*^9, 
   3.530862453562359*^9}},ExpressionUUID->"aba4173a-c5dc-4859-a8bb-\
ff780fc82ee5"],

Cell[CellGroupData[{

Cell["Examples of Two Regime AR (1) model", "Subsection",
 CellChangeTimes->{
  3.3967798439211683`*^9, {3.396783235916957*^9, 
   3.3967832365760946`*^9}},ExpressionUUID->"3c10e1a3-88a1-4767-a125-\
ddcd96c3933d"],

Cell[TextData[{
 "Two-Regime AR(1) model is represented by:\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", "t"], "="}], TraditionalForm]],ExpressionUUID->
  "118c4196-19cc-46c6-88af-b6139a5822ec"],
 Cell[BoxData[
  FormBox[
   RowBox[{"{", GridBox[{
      {
       RowBox[{
        SubscriptBox["\[Alpha]", "1"], "+", 
        RowBox[{
         SubscriptBox["\[Beta]", "1"], 
         SubscriptBox["x", 
          RowBox[{"t", "-", "1"}]]}], "+", 
        SubscriptBox["\[Epsilon]", "t"]}], 
       RowBox[{
        SubscriptBox["x", 
         RowBox[{"t", "-", "1"}]], "<", "k"}]},
      {
       RowBox[{
        SubscriptBox["\[Alpha]", "2"], "+", 
        RowBox[{
         SubscriptBox["\[Beta]", "2"], 
         SubscriptBox["x", 
          RowBox[{"t", "-", "1"}]]}], "+", 
        SubscriptBox["\[Epsilon]", "t"]}], 
       RowBox[{
        SubscriptBox["x", 
         RowBox[{"t", "-", "1"}]], "\[GreaterEqual]", "k"}]}
     }]}], TraditionalForm]],ExpressionUUID->
  "a7668bf4-9dae-4139-8876-c38974554c25"],
 "\n\nParameters are initially set to:  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Alpha]", "1"], "=", 
     RowBox[{
      SubscriptBox["\[Alpha]", "2"], "=", "0"}]}], ",", " ", 
    RowBox[{
     SubscriptBox["\[Beta]", "1"], "=", 
     RowBox[{"-", "1.5"}]}]}], TraditionalForm]],ExpressionUUID->
  "e7331f4d-27c7-4dc1-b844-70c22ed41340"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Beta]", "2"], "=", "0.5"}], TraditionalForm]],
  ExpressionUUID->"4c6d2d34-b5f1-42a1-9988-8282ac37bbd6"],
 " to obtain following Two Regime AR(1) process: \n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", "t"], "="}], TraditionalForm]],ExpressionUUID->
  "4f2b08fe-6bf5-4267-b113-4fcdaa015363"],
 Cell[BoxData[
  FormBox[
   RowBox[{"{", GridBox[{
      {
       RowBox[{
        RowBox[{
         RowBox[{"-", "1.5"}], 
         SubscriptBox["x", 
          RowBox[{"t", "-", "1"}]]}], "+", 
        SubscriptBox["\[Epsilon]", "t"]}], 
       RowBox[{
        SubscriptBox["x", 
         RowBox[{"t", "-", "1"}]], "<", "0"}]},
      {
       RowBox[{
        RowBox[{"0.5", 
         SubscriptBox["x", 
          RowBox[{"t", "-", "1"}]]}], "+", 
        SubscriptBox["\[Epsilon]", "t"]}], 
       RowBox[{
        SubscriptBox["x", 
         RowBox[{"t", "-", "1"}]], "\[GreaterEqual]", "0"}]}
     }]}], TraditionalForm]],ExpressionUUID->
  "322369e8-3c9b-4f78-a2ff-493eacc42599"],
 "\n\nNote, that the process is stationary despite the coefficient -1.5 in \
the first regime. Series contains large upward jumps when it becomes negative \
(due to -1.5 coefficient), and there are more positive then negative ones. \
Model also contains no constant term, but E(",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", "t"], ")"}], TraditionalForm]],ExpressionUUID->
  "412bfc66-5841-470e-a32e-fd8b695215ed"],
 " is not zero. "
}], "Text",
 CellChangeTimes->{
  3.3967797955424285`*^9, {3.3967798518620663`*^9, 3.3967799061994085`*^9}, {
   3.3967800149893208`*^9, 3.396780020782895*^9}, {3.3967800535718117`*^9, 
   3.3967801643762436`*^9}, {3.3967805097174215`*^9, 
   3.3967805602395782`*^9}, {3.396780606546185*^9, 3.396780608663237*^9}, {
   3.396781309114499*^9, 3.3967813131347494`*^9}, {3.3967817538331056`*^9, 
   3.3967818706322703`*^9}, {3.396781990498622*^9, 3.3967820493083344`*^9}, {
   3.39678209091407*^9, 3.396782093740061*^9}, {3.3967821845164776`*^9, 
   3.396782251053234*^9}, {3.3967832721509657`*^9, 3.396783287730047*^9}, {
   3.406802555428*^9, 3.4068025579049997`*^9}, 3.465553918995021*^9, 
   3.5308553324184017`*^9, {3.562344178482237*^9, 
   3.5623441819336987`*^9}},ExpressionUUID->"3607c8fa-fa61-42ea-9567-\
66afab493e20"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"SeedRandom", "[", "seed", "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"Clear", "[", "x", "]"}], ";", 
    RowBox[{"random", "=", 
     RowBox[{"RandomReal", "[", 
      RowBox[{
       RowBox[{"NormalDistribution", "[", 
        RowBox[{"0", ",", "1"}], "]"}], ",", "500"}], "]"}]}], ";", 
    RowBox[{
     RowBox[{"x", "[", "1", "]"}], "=", "0"}], ";", "\[IndentingNewLine]", 
    RowBox[{"tardat", "=", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"f", "=", 
         RowBox[{"{", 
          RowBox[{"i", ",", "2", ",", 
           RowBox[{"Length", "[", "random", "]"}]}], "}"}]}], "}"}], ",", 
       RowBox[{"Table", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"x", "[", 
             RowBox[{"i", "-", "1"}], "]"}], "<", "tresh"}], ",", 
           RowBox[{
            RowBox[{"x", "[", "i", "]"}], "=", 
            RowBox[{"alfa1", "+", 
             RowBox[{"beta1", " ", 
              RowBox[{"x", "[", 
               RowBox[{"i", "-", "1"}], "]"}]}], " ", "+", " ", 
             RowBox[{"random", "[", 
              RowBox[{"[", "i", "]"}], "]"}]}]}], ",", 
           RowBox[{
            RowBox[{"x", "[", "i", "]"}], "=", 
            RowBox[{"alfa2", "+", 
             RowBox[{"beta2", " ", 
              RowBox[{"x", "[", 
               RowBox[{"i", "-", "1"}], "]"}]}], " ", "+", " ", 
             RowBox[{"random", "[", 
              RowBox[{"[", "i", "]"}], "]"}]}]}]}], "]"}], ",", "f"}], 
        "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"ListPlot", "[", 
     RowBox[{"tardat", ",", "\[IndentingNewLine]", 
      RowBox[{"Joined", "\[Rule]", "True"}], ",", 
      RowBox[{"Frame", "\[Rule]", "True"}], ",", 
      RowBox[{"PlotStyle", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Thickness", "[", "Medium", "]"}], ",", " ", "Red"}], 
        "}"}]}], ",", 
      RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Style", "[", 
    RowBox[{"\"\<Two Regime AR(1) model\>\"", ",", "12", ",", "Bold"}], "]"}],
    ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"tresh", ",", "0", ",", "\"\<treshold - k\>\""}], "}"}], ",", 
     RowBox[{"-", "3"}], ",", "3", ",", 
     RowBox[{"Appearance", "\[Rule]", "\"\<Labeled\>\""}]}], "}"}], ",", 
   "Delimiter", ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "alfa1", ",", "0", ",", 
       "\"\<\!\(\*SubscriptBox[\(\[Alpha]\), \(1\)]\)\>\""}], "}"}], ",", 
     RowBox[{"-", "3"}], ",", "3", ",", 
     RowBox[{"Appearance", "\[Rule]", "\"\<Labeled\>\""}]}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"beta1", ",", 
