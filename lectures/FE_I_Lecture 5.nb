Cell[CellGroupData[{

Cell["GARCH as an ARMA process", "Section",
 CellChangeTimes->{{3.406269143060752*^9, 3.406269147568752*^9}, {
   3.530599059624044*^9, 3.530599065584362*^9}, {3.530691073690981*^9, 
   3.530691075674041*^9}, {3.53069147302001*^9, 3.530691474871354*^9}, {
   3.530693029400872*^9, 3.5306930616095943`*^9}, {3.530794625264617*^9, 
   3.530794629791909*^9}, 3.623998439273554*^9, {3.6249093855400763`*^9, 
   3.624909385668138*^9}, 3.625232979051952*^9, {3.625234996563716*^9, 
   3.625235007504987*^9}, 
   3.625256424130816*^9},ExpressionUUID->"491ab89b-9ac5-4456-84fb-\
2e9c422defb2"],

Cell[TextData[{
 "Letting ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "t"], "=", 
    RowBox[{
     SubscriptBox["r", "t"], "-", 
     SubscriptBox["\[Mu]", "t"]}]}], TraditionalForm]],ExpressionUUID->
  "757f5851-7e73-44de-acb8-8ddce6a42222"],
 " be the mean-corrected log return, the GARCH(\[ScriptM],\[ScriptS]) model \
is defined as:\n\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "t"], "=", 
    RowBox[{
     SubscriptBox["\[Sigma]", "t"], 
     SubscriptBox["\[Epsilon]", "t"]}]}], TraditionalForm]],ExpressionUUID->
  "2b716c91-7f24-4216-8399-9b6584a2f0b2"],
 ",\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Sigma]", "t", "2"], "=", 
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], "+", 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"i", "=", "1"}], "m"], 
      RowBox[{
       SubscriptBox["\[Alpha]", "i"], 
       SubsuperscriptBox["a", 
        RowBox[{"t", "-", "i"}], "2"]}]}], "+", 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"j", "=", "1"}], "s"], 
      RowBox[{
       SubscriptBox["\[Beta]", "j"], 
       SubsuperscriptBox["\[Sigma]", 
        RowBox[{"t", "-", "j"}], "2"]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"e8035c01-eafe-402f-9255-9122cec1f59e"],
 ", \n\nwhere {",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Epsilon]", "t"], "}"}], TraditionalForm]],ExpressionUUID->
  "0a16e188-0b73-46ea-80a6-556df8fdf9c2"],
 " is i.i.d random variables with zero mean and variance 1,  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], ">", "0"}], ",", " ", 
    RowBox[{
     SubscriptBox["\[Alpha]", "i"], "\[GreaterEqual]", "0"}]}], 
   TraditionalForm]],ExpressionUUID->"978351a8-b88e-4ee8-9cdc-7882c01d1a5a"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Beta]", "j"], "\[GreaterEqual]", "0"}], TraditionalForm]],
  ExpressionUUID->"918529b7-66cb-44fb-a3fc-d25236cdc5af"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"i", "=", "1"}], 
      RowBox[{"max", "(", 
       RowBox[{"m", ",", "s"}], ")"}]], 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["\[Alpha]", "i"], "+", 
       SubscriptBox["\[Beta]", "i"]}], ")"}]}], "<", "1"}], TraditionalForm]],
  ExpressionUUID->"521d258c-c597-4931-b161-3357a41ad729"],
 ".\nThe GARCH(\[ScriptM],\[ScriptS]) model can be also written with \
polynomials as:\n\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Sigma]", "t", "2"], "=", 
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], "+", 
     RowBox[{
      RowBox[{"\[Alpha]", "(", "L", ")"}], 
      SubsuperscriptBox["a", "t", "2"]}], "+", 
     RowBox[{
      RowBox[{"\[Beta]", "(", "L", ")"}], 
      SubsuperscriptBox["\[Sigma]", "t", "2"]}]}]}], TraditionalForm]],
  ExpressionUUID->"eef5b31a-33fd-40e4-83b2-dee51b6b3e4e"],
 "  (*)\n\nwhere ",
 StyleBox["L ",
  FontSlant->"Italic"],
 "is the lag operator, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Alpha]", "(", "L", ")"}], "=", 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"i", "=", "1"}], "m"], 
     RowBox[{
      SubscriptBox["\[Alpha]", "i"], 
      SuperscriptBox["L", "i"]}]}]}], TraditionalForm]],ExpressionUUID->
  "5989b6b0-b9c3-4280-9a24-3daaa4c505d0"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Beta]", "(", "L", ")"}], "=", 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"j", "=", "1"}], "s"], 
     RowBox[{
      SubscriptBox["\[Beta]", "j"], 
      SuperscriptBox["L", "j"]}]}]}], TraditionalForm]],ExpressionUUID->
  "2ce69e2b-778e-4f79-b534-7472c5b89257"],
 ".\n\nDefining ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Vee]", "t"], 
    RowBox[{"=", 
     RowBox[{
      SubsuperscriptBox["a", "t", "2"], "-", 
      SubsuperscriptBox["\[Sigma]", "t", "2"]}]}]}], TraditionalForm]],
  ExpressionUUID->"26378b6a-d782-437f-9e82-dc000f2a707f"],
 " we can rewrite (*) as an ARMA (p,m) process:\n\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"[", 
      RowBox[{"1", "-", 
       RowBox[{"\[Alpha]", "(", "L", ")"}], "-", 
       RowBox[{"\[Beta]", "(", "L", ")"}]}], "]"}], 
     SubsuperscriptBox["a", "t", "2"]}], "=", 
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], "+", 
     RowBox[{
      RowBox[{"[", 
       RowBox[{"1", "-", 
        RowBox[{"\[Beta]", "(", "L", ")"}]}], "]"}], 
      SubscriptBox["\[Vee]", "t"]}]}]}], TraditionalForm]],ExpressionUUID->
  "df6dbce6-7263-4ae5-b91f-c64936814ba1"],
 "\n\t\nwhere p=max{m,s}.\n\nIf we allow for the presence of a unit root in \
[1-\[Alpha](L)-\[Beta](L)], we can define the IGARCH(m,s) model as:\n\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", "L"}], ")"}], 
     RowBox[{"\[Phi]", "(", "L", ")"}], 
     SubsuperscriptBox["a", "t", "2"]}], "=", 
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], "+", 
     RowBox[{
      RowBox[{"[", 
       RowBox[{"1", "-", 
        RowBox[{"\[Beta]", "(", "L", ")"}]}], "]"}], 
      SubscriptBox["\[Vee]", "t"]}]}]}], TraditionalForm]],ExpressionUUID->
  "3e7e8d8a-2f46-4b48-955c-f35949857825"],
 ".\n\t\nwhere ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Phi]", "(", "L", ")"}], "=", 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"i", "=", "1"}], 
      RowBox[{"s", "-", "1"}]], 
     RowBox[{
      SubscriptBox["\[Phi]", "i"], 
      SuperscriptBox["L", "i"]}]}]}], TraditionalForm]],ExpressionUUID->
  "d1777a4b-4fa2-4429-83ad-5cf4180b3fcf"],
 " is of order s-1.\n"
}], "Text",
 CellChangeTimes->{{3.625232983271399*^9, 3.625232995186215*^9}, {
   3.6252500158774014`*^9, 3.625250050969018*^9}, 3.625250116239369*^9, {
   3.625250147774188*^9, 3.6252502165878973`*^9}, {3.625250345034296*^9, 
   3.6252505025622787`*^9}, {3.625250534894741*^9, 3.625250654389242*^9}, {
   3.6252508721875257`*^9, 3.62525088241363*^9}, {3.6252512385390987`*^9, 
   3.625251260109421*^9}, {3.6252512915230913`*^9, 3.625251374805471*^9}, {
   3.625251523568467*^9, 3.625251704490613*^9}, {3.6252520042111473`*^9, 
   3.625252018916744*^9}, {3.625252582605371*^9, 3.625252599629258*^9}, 
   3.62525268360229*^9, {3.62525273042457*^9, 3.625252819721895*^9}, {
   3.625252911333563*^9, 3.62525291664242*^9}, {3.6252530237907248`*^9, 
   3.6252530608935204`*^9}, {3.6252531042656183`*^9, 3.625253118323648*^9}, {
   3.6252531571066113`*^9, 3.625253285278207*^9}, {3.62525333453557*^9, 
   3.625253377099641*^9}, 3.625254221738055*^9, {3.6252552000195017`*^9, 
   3.62525520127287*^9}, 3.625255295292377*^9, 
   3.625256427032132*^9},ExpressionUUID->"744e5c00-bda2-45dc-90b8-\
ab67098c2920"]
}, Open  ]],

Cell[CellGroupData[{

Cell["FIGARCH Model", "Section",
 CellChangeTimes->{{3.406269143060752*^9, 3.406269147568752*^9}, {
   3.530599059624044*^9, 3.530599065584362*^9}, {3.530691073690981*^9, 
   3.530691075674041*^9}, {3.53069147302001*^9, 3.530691474871354*^9}, {
   3.530693029400872*^9, 3.5306930616095943`*^9}, {3.530794625264617*^9, 
   3.530794629791909*^9}, 3.623998439273554*^9, {3.6249093855400763`*^9, 
   3.624909385668138*^9}, 
   3.625232979051952*^9},ExpressionUUID->"acd4d5a2-f361-4a57-9d58-\
035c9e1f357f"],

Cell[TextData[{
 "Baillie (1996, JoE) and Bollerslev and Mikkelsen (1996) introduced the \
FIGARCH process, generalizing the GARCH to allow for persistence in the \
conditional variance.\n\nIf we compare the IGARCH variance equation with the \
ARFIMA model ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", "\[Minus]", "L"}], ")"}], "d"], 
     RowBox[{"\[Phi]", "(", "L", ")"}], 
     SubscriptBox["X", "t"]}], "=", 
    RowBox[{
     RowBox[{"\[Theta]", "(", "L", ")"}], 
     SubscriptBox["\[CurlyEpsilon]", "t"]}]}], TraditionalForm]],
  ExpressionUUID->"6877b753-2bb4-4c50-abbc-591ee77bc81d"],
 ", we see that we can simply add the long memory term to the GARCH model and \
define the FIGARCH(m,d,s) model as:\n\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"\[Phi]", "(", "L", ")"}], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", "-", "L"}], ")"}], "d"], 
     SubsuperscriptBox["a", "t", "2"]}], "=", 
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], "+", 
     RowBox[{
      RowBox[{"[", 
       RowBox[{"1", "-", 
        RowBox[{"\[Beta]", "(", "L", ")"}]}], "]"}], 
      SubscriptBox["\[Vee]", "t"]}]}]}], TraditionalForm]],ExpressionUUID->
  "a5ea2984-54e2-4847-85ef-96e797cd3dca"],
 ".\n\t\nwhere ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Phi]", "(", "L", ")"}], "=", 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"i", "=", "1"}], 
      RowBox[{"s", "-", "1"}]], 
     RowBox[{
      SubscriptBox["\[Phi]", "i"], 
      SuperscriptBox["L", "i"]}]}]}], TraditionalForm]],ExpressionUUID->
  "dcc73ec9-6a19-41a3-beee-f131b5c8fa88"],
 " is of order s-1.\t"
}], "Text",
 CellChangeTimes->{{3.625232983271399*^9, 3.625232995186215*^9}, 
   3.6252500158774014`*^9, {3.6252533869468393`*^9, 3.625253424087262*^9}, {
   3.6252534613853407`*^9, 3.625253488671319*^9}, {3.625254225143489*^9, 
   3.625254229078826*^9}, {3.625254354845998*^9, 3.6252543748737803`*^9}, {
   3.625254551485794*^9, 3.625254551971971*^9}, {3.625254586090931*^9, 
   3.625254589346582*^9}, {3.625254998223621*^9, 3.625255000941093*^9}, {
   3.6252550498891706`*^9, 3.625255111145473*^9}, {3.625255141664702*^9, 
   3.625255153648241*^9}, {3.625255320660261*^9, 3.6252553709290237`*^9}, {
   3.6252938822974977`*^9, 3.625294004076844*^9}, {3.81401552260172*^9, 
   3.814015522780531*^9}, {3.857558836579111*^9, 3.8575588378290052`*^9}, {
   3.857616948976997*^9, 
   3.857616952933888*^9}},ExpressionUUID->"f754cff8-db70-4ba1-969e-\
190f5b7fcb0c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["FIEGARCH Model", "Section",
 CellChangeTimes->{{3.406269143060752*^9, 3.406269147568752*^9}, {
   3.530599059624044*^9, 3.530599065584362*^9}, {3.530691073690981*^9, 
   3.530691075674041*^9}, {3.53069147302001*^9, 3.530691474871354*^9}, {
   3.530693029400872*^9, 3.5306930616095943`*^9}, {3.530794625264617*^9, 
   3.530794629791909*^9}, 3.623998439273554*^9, {3.6249093855400763`*^9, 
   3.624909385668138*^9}},ExpressionUUID->"80b57562-1546-4b45-ab83-\
699fc3928501"],

Cell[TextData[{
 "Fractionally Integrated EGARCH (FIEGARCH) model was proposed by Bollerslev \
and Mikkelsen (1996). The model captures simultaneously with the leverage \
effect and long-memory.\n\nLet us defines the FIEGARCH(m,d,s) model as\n\t\n\t\
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "t"], "=", 
    RowBox[{
     SubscriptBox["\[Sigma]", "t"], 
     SubscriptBox["\[Epsilon]", "t"]}]}], TraditionalForm]],ExpressionUUID->
  "dbc90596-067f-484a-83a3-808951df953b"],
 "\n\t\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"ln", "(", 
     SubsuperscriptBox["\[Sigma]", "t", "2"], ")"}], "=", 
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], "+", 
     RowBox[{
      StyleBox[
       FractionBox[
        RowBox[{
         RowBox[{
          RowBox[{"1", "+", 
           RowBox[{
            SubscriptBox["\[Alpha]", "1"], "L"}], "+"}], "..."}], "+", 
         RowBox[{
          SubscriptBox["\[Alpha]", "s"], 
          SuperscriptBox["L", "s"]}]}], 
        RowBox[{
         RowBox[{
          RowBox[{"1", "-", 
           RowBox[{
            SubscriptBox["\[Beta]", "1"], "L"}]}], "..."}], "-", 
         RowBox[{
          SubscriptBox["\[Beta]", "m"], 
          SuperscriptBox["L", "m"]}]}]],
       FontSize->18], 
      StyleBox[
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", "-", "L"}], ")"}], 
        RowBox[{"-", "d"}]],
       FontColor->RGBColor[1, 0, 0]], 
      RowBox[{"g", "(", 
       SubscriptBox["\[Epsilon]", 
        RowBox[{"t", "-", "1"}]], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"bd61eb72-b3bd-4654-9d74-f5ac5dffc4cc"],
 "\n\t\n\twhere ",
 Cell[BoxData[
  FormBox[
   StyleBox[
    RowBox[{"g", "(", 
     SubscriptBox["\[Epsilon]", "t"], ")"}],
    FontColor->GrayLevel[0]], TraditionalForm]],
  FontColor->RGBColor[1, 0, 0],ExpressionUUID->
  "6aefee9a-59bd-468f-a515-ecef4ccc32f6"],
 " is defined as:\n\t\n\t",
 Cell[BoxData[
  FormBox[
   StyleBox[
    RowBox[{
     RowBox[{"g", "(", 
      SubscriptBox["\[Epsilon]", "t"], ")"}], "=", 
     RowBox[{
      RowBox[{"\[Theta]", " ", 
       SubscriptBox["\[Epsilon]", "t"]}], "+", 
      RowBox[{"\[Gamma]", "[", 
       RowBox[{
        RowBox[{"\[LeftBracketingBar]", 
         SubscriptBox["\[Epsilon]", "t"], "\[RightBracketingBar]"}], "-", 
        RowBox[{"E", 
         RowBox[{"\[LeftBracketingBar]", 
          SubscriptBox["\[Epsilon]", "t"], "\[RightBracketingBar]"}]}]}], 
       "]"}]}]}],
    FontColor->GrayLevel[0]], TraditionalForm]],
  FontColor->RGBColor[1, 0, 0],ExpressionUUID->
  "d5bc77fd-cf53-40d7-a06f-dccf26790018"],
 ".\n\t\nThe term ",
 Cell[BoxData[
  FormBox[
   StyleBox[
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"1", "-", "L"}], ")"}], 
     RowBox[{"-", "d"}]],
    FontColor->RGBColor[1, 0, 0]], TraditionalForm]],ExpressionUUID->
  "e88edeee-77fe-436f-8418-47d738d7524d"],
 " is the long memory component with the long memory parameter ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "\[Element]", 
    RowBox[{"(", 
     RowBox[{"0", ",", 
      RowBox[{"1", "/", "2"}]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "38cc87ed-f9df-4281-9768-20df8ab0a10d"],
 StyleBox[".\n", "InlineFormula"],
 "When d = 0, the short-memory EGARCH model of Nelson (1991) is obtained.\n\n\
In its simplest form, the FIEGARCH(1,d,0) model is given by",
 StyleBox["\n", "Subsection"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", 
       RowBox[{
        SubscriptBox["\[Beta]", "1"], "L"}]}], ")"}], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", "-", "L"}], ")"}], "d"], 
     RowBox[{"ln", "(", 
      SubsuperscriptBox["\[Sigma]", "t", "2"], ")"}]}], "=", 
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], "+", 
     RowBox[{"g", "(", 
      SubscriptBox["\[Epsilon]", 
       RowBox[{"t", "-", "1"}]], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "8ec65235-8ae0-4d87-8918-3893ea750615"],
 "\n"
}], "Text",
 CellChangeTimes->{{3.3967846140973024`*^9, 3.3967846161577177`*^9}, {
   3.3967849089065585`*^9, 3.3967849612762537`*^9}, {3.3967861173663216`*^9, 
   3.396786407842847*^9}, {3.39678695128951*^9, 3.396786959891498*^9}, {
   3.396787188057558*^9, 3.396787210808056*^9}, {3.396787273039424*^9, 
   3.3967872757394466`*^9}, {3.5308553353101892`*^9, 3.530855338359212*^9}, {
   3.62399846749117*^9, 3.623998505132386*^9}, {3.624000310271267*^9, 
   3.6240003488792562`*^9}, {3.624000719941234*^9, 3.6240007199412823`*^9}, {
   3.624000804277039*^9, 3.624000808283504*^9}, {3.624000843320224*^9, 
   3.6240008443058443`*^9}, {3.624000887243497*^9, 3.624000920644294*^9}, {
   3.624001001277009*^9, 3.624001002554079*^9}, {3.624001036781169*^9, 
   3.624001318126968*^9}, {3.6240015733338003`*^9, 3.624001675779069*^9}, {
   3.6240031648793716`*^9, 3.624003338284041*^9}, {3.624003566011565*^9, 
   3.624003572723907*^9}, {3.624006604333542*^9, 3.6240066540037947`*^9}, {
   3.624080721848789*^9, 3.6240807281199837`*^9}, {3.624084817083619*^9, 
   3.624084871331561*^9}, {3.624084903669697*^9, 3.624084969973837*^9}, {
   3.624085020596365*^9, 3.624085092474168*^9}, {3.624085141702301*^9, 
   3.6240851492548227`*^9}, {3.6240851961579933`*^9, 
   3.6240852542351427`*^9}, {3.624085320603003*^9, 3.624085337237501*^9}, {
   3.624085612037684*^9, 3.624085628439228*^9}, {3.624085679154614*^9, 
   3.6240857327517767`*^9}, 3.624085763287691*^9, {3.624085831484025*^9, 
   3.624085847518071*^9}, {3.625123401611259*^9, 3.62512345337659*^9}, {
   3.625133328443557*^9, 3.625133340780842*^9}, {3.6251333821128597`*^9, 
