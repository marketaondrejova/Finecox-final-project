Cell[CellGroupData[{

Cell["Example", "Subsection",
 CellChangeTimes->{{3.396784602574602*^9, 3.396784612252694*^9}, {
  3.3967864327767982`*^9, 3.396786443205818*^9}, {3.3969424139579043`*^9, 
  3.3969424142938204`*^9}, {3.465563336178287*^9, 3.465563348845381*^9}, {
  3.465563462479053*^9, 3.465563464864828*^9}, {3.5308634748009*^9, 
  3.530863477757834*^9}},ExpressionUUID->"b3514b09-f4d3-438c-854e-\
bce2886f6931"],

Cell[TextData[{
 "Set parameters of previous example to:  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Alpha]", "1"], "=", 
     RowBox[{
      SubscriptBox["\[Alpha]", "2"], "=", "0"}]}], ",", " ", 
    RowBox[{
     SubscriptBox["\[Beta]", "1"], "=", "0.2"}]}], TraditionalForm]],
  ExpressionUUID->"2d580968-61c6-4de4-8d45-38894f3eb36e"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Beta]", "2"], "=", "0.9"}], TraditionalForm]],
  ExpressionUUID->"3ee7b60b-6801-48b5-a2d1-44532b7cd7e9"],
 " to obtain following Two Regime AR(1) process \n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", "t"], "="}], TraditionalForm]],ExpressionUUID->
  "b096cc4f-6245-4fe0-82e8-cf407b09699d"],
 Cell[BoxData[
  FormBox[
   RowBox[{"{", GridBox[{
      {
       RowBox[{
        RowBox[{"0.2", 
         SubscriptBox["x", 
          RowBox[{"t", "-", "1"}]]}], "+", 
        SubscriptBox["\[Epsilon]", "t"]}], 
       RowBox[{
        SubscriptBox["x", 
         RowBox[{"t", "-", "1"}]], "<", "k"}]},
      {
       RowBox[{
        RowBox[{"0.9", 
         SubscriptBox["x", 
          RowBox[{"t", "-", "1"}]]}], "+", 
        SubscriptBox["\[Epsilon]", "t"]}], 
       RowBox[{
        SubscriptBox["x", 
         RowBox[{"t", "-", "1"}]], "\[GreaterEqual]", "k"}]}
     }]}], TraditionalForm]],ExpressionUUID->
  "89e228ce-7096-4a8d-a2ef-fc6bfbd3892b"],
 "\nand see the mixture of short-memory and long-memory processes "
}], "Text",
 CellChangeTimes->{{3.465562550012041*^9, 3.4655625975689898`*^9}, {
  3.4655626652489967`*^9, 3.4655627079679623`*^9}, {3.465562754041774*^9, 
  3.4655628333688393`*^9}},ExpressionUUID->"5dbdd9fc-b90d-45bb-85a1-\
ad4c39ea453e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Example of application: AR(1)-TAR-GARCH(1,1)", "Subsection",
 CellChangeTimes->{{3.396784602574602*^9, 3.396784612252694*^9}, {
  3.3967864327767982`*^9, 3.396786443205818*^9}, {3.3969424139579043`*^9, 
  3.3969424142938204`*^9}, {3.465563336178287*^9, 3.465563348845381*^9}, {
  3.465563462479053*^9, 
  3.465563464864828*^9}},ExpressionUUID->"3fce3c18-2e11-4a5d-a9ac-\
e560fbdddbd8"],

Cell[TextData[{
 "TAR models can be used for capturing asymmetric response in volatility. If \
we find the series to follow AR(1)-GARCH(1,1) process, we can introduce TAR \
to model asymmetric response in volatility to shocks. Model is formalized:\n\n\
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["r", "t"], "=", 
    RowBox[{
     SubscriptBox["\[Phi]", "0"], "+", 
     RowBox[{
      SubscriptBox["\[Phi]", "1"], 
      SubscriptBox["r", 
       RowBox[{"t", "-", "1"}]]}], "+", 
     SubscriptBox["a", "t"]}]}], TraditionalForm]],ExpressionUUID->
  "e861d154-740c-4ed5-8ac3-fca56710d304"],
 ",\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "t"], "=", 
    RowBox[{
     SubscriptBox["\[Sigma]", "t"], 
     SubscriptBox["\[Epsilon]", "t"]}]}], TraditionalForm]],ExpressionUUID->
  "d9432b14-0272-4ee4-9627-b8d343de3232"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Sigma]", "t", "2"], "=", 
    RowBox[{"{", GridBox[{
       {
        RowBox[{
         SubscriptBox["\[Alpha]", "0"], "+", 
         RowBox[{
          SubscriptBox["\[Alpha]", "1"], 
          SubsuperscriptBox["a", 
           RowBox[{"t", "-", "1"}], "2"]}], "+", 
         RowBox[{
          SubscriptBox["\[Beta]", "1"], 
          SubsuperscriptBox["\[Sigma]", 
           RowBox[{"t", "-", "1"}], "2"]}]}], 
        RowBox[{
         SubscriptBox["a", 
          RowBox[{"t", "-", "1"}]], "\[LessEqual]", "0"}]},
       {
        RowBox[{
         SubscriptBox["\[Alpha]", "2"], "+", 
         RowBox[{
          SubscriptBox["\[Alpha]", "3"], 
          SubsuperscriptBox["a", 
           RowBox[{"t", "-", "1"}], "2"]}], "+", 
         RowBox[{
          SubscriptBox["\[Beta]", "2"], 
          SubsuperscriptBox["\[Sigma]", 
           RowBox[{"t", "-", "1"}], "2"]}]}], 
        RowBox[{
         SubscriptBox["a", 
          RowBox[{"t", "-", "1"}]], ">", "0"}]}
      }]}]}], TraditionalForm]],ExpressionUUID->
  "80bd25a1-cbb4-4aa6-b1d3-4e7598b0d8d7"]
}], "Text",
 CellChangeTimes->{{3.3967846140973024`*^9, 3.3967846161577177`*^9}, {
  3.3967849089065585`*^9, 3.3967849612762537`*^9}, {3.3967861173663216`*^9, 
  3.396786407842847*^9}, {3.39678695128951*^9, 3.396786959891498*^9}, {
  3.396787188057558*^9, 3.396787210808056*^9}, {3.396787273039424*^9, 
  3.3967872757394466`*^9}, {3.5308553353101892`*^9, 
  3.530855338359212*^9}},ExpressionUUID->"0e6d46f9-b251-4119-8b7d-\
9ee90f379105"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"SeedRandom", "[", "seed", "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"random", "=", 
     RowBox[{"RandomReal", "[", 
      RowBox[{
       RowBox[{"NormalDistribution", "[", 
        RowBox[{"0", ",", "1"}], "]"}], ",", "500"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"s", "=", 
     RowBox[{"Table", "[", 
      RowBox[{"0", ",", 
       RowBox[{"{", "500", "}"}]}], "]"}]}], ";", 
    RowBox[{"r", "=", 
     RowBox[{"Table", "[", 
      RowBox[{"0", ",", 
       RowBox[{"{", "500", "}"}]}], "]"}]}], ";", 
    RowBox[{"a", "=", 
     RowBox[{"Table", "[", 
      RowBox[{"0", ",", 
       RowBox[{"{", "500", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"r", "[", 
      RowBox[{"[", "1", "]"}], "]"}], "=", 
     RowBox[{"random", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";", 
    RowBox[{
     RowBox[{"s", "[", 
      RowBox[{"[", "1", "]"}], "]"}], "=", 
     RowBox[{"Variance", "[", "random", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"a", "[", 
           RowBox[{"[", 
            RowBox[{"i", "-", "1"}], "]"}], "]"}], ">", "tresh"}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"s", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "=", 
           RowBox[{"alfa2", "+", 
            RowBox[{"alfa3", " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"r", "[", 
                RowBox[{"[", 
                 RowBox[{"i", "-", "1"}], "]"}], "]"}], ")"}], "^", "2"}]}], 
            " ", "+", 
            RowBox[{"beta2", " ", 
             RowBox[{"s", "[", 
              RowBox[{"[", 
               RowBox[{"i", "-", "1"}], "]"}], "]"}]}]}]}], ";"}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"s", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "=", 
           RowBox[{"alfa0", "+", 
            RowBox[{"alfa1", " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"r", "[", 
                RowBox[{"[", 
                 RowBox[{"i", "-", "1"}], "]"}], "]"}], ")"}], "^", "2"}]}], 
            " ", "+", 
            RowBox[{"beta1", " ", 
             RowBox[{"s", "[", 
              RowBox[{"[", 
               RowBox[{"i", "-", "1"}], "]"}], "]"}]}]}]}], ";"}]}], "]"}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"a", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "=", 
        RowBox[{
         RowBox[{"Sqrt", "[", 
          RowBox[{"s", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "]"}], " ", 
         RowBox[{"random", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"r", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "=", 
        RowBox[{"arconst", "+", 
         RowBox[{"arp1", " ", 
          RowBox[{"r", "[", 
           RowBox[{"[", 
            RowBox[{"i", "-", "1"}], "]"}], "]"}]}], "+", 
         RowBox[{"a", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
      ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "2", ",", 
        RowBox[{"Length", "[", "random", "]"}]}], "}"}]}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"alfa1", "+", "beta1"}], ")"}], "<", "1"}], "===", "True"}], 
      ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"alfa3", "+", "beta2"}], ")"}], "<", "1"}], "===", 
         "True"}], ",", "\[IndentingNewLine]", 
        RowBox[{"ListPlot", "[", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"type", "===", "\"\<Simulated series\>\""}], ",", "r", 
            ",", "s"}], "]"}], ",", 
          RowBox[{"Joined", "\[Rule]", "True"}], ",", 
          RowBox[{"Frame", "\[Rule]", "True"}], ",", 
          RowBox[{"PlotStyle", "\[Rule]", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Thickness", "[", "Medium", "]"}], ",", " ", "Red"}], 
            "}"}]}], ",", 
          RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"Style", "[", 
         RowBox[{
         "\"\<Please input (\!\(\*SubscriptBox[\(\[Alpha]\), \
\(i\)]\)+\!\(\*SubscriptBox[\(\[Beta]\), \(i\)]\))<1\>\"", ",", "Bold", ",", 
          "12"}], "]"}]}], "]"}], ",", 
      RowBox[{"Style", "[", 
       RowBox[{
       "\"\<Please input (\!\(\*SubscriptBox[\(\[Alpha]\), \
\(i\)]\)+\!\(\*SubscriptBox[\(\[Beta]\), \(i\)]\))<1\>\"", ",", "Bold", ",", 
        "12"}], "]"}]}], "]"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"Style", "[", 
    RowBox[{"\"\<AR(1)-TAR-GARCH(1,1)\>\"", ",", "12", ",", "Bold"}], "]"}], 
   ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"type", ",", "\"\<Simulated series\>\"", ",", "\"\<\>\""}], 
      "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
      "\"\<Simulated series\>\"", ",", "\"\<Simulated Volatility\>\""}], 
      "}"}]}], "}"}], ",", "Delimiter", ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"tresh", ",", "0", ",", "\"\<treshold - k\>\""}], "}"}], ",", 
     RowBox[{"-", "10"}], ",", "10", ",", 
     RowBox[{"Appearance", "\[Rule]", "\"\<Labeled\>\""}]}], "}"}], ",", 
   "Delimiter", ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "arconst", ",", "0.6", ",", 
       "\"\<\!\(\*SubscriptBox[\(\[Phi]\), \(0\)]\)\>\""}], "}"}], ",", 
     RowBox[{"-", "3"}], ",", "3", ",", 
     RowBox[{"Appearance", "\[Rule]", "\"\<Labeled\>\""}]}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "arp1", ",", "0.5", ",", 
       "\"\<\!\(\*SubscriptBox[\(\[Phi]\), \(1\)]\)\>\""}], "}"}], ",", 
     RowBox[{"-", "1"}], ",", "1", ",", 
     RowBox[{"Appearance", "\[Rule]", "\"\<Labeled\>\""}]}], "}"}], ",", 
   "Delimiter", ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "alfa0", ",", "0.5", ",", 
       "\"\<\!\(\*SubscriptBox[\(\[Alpha]\), \(0\)]\)\>\""}], "}"}], ",", 
     "0.01", ",", "1", ",", 
     RowBox[{"Appearance", "\[Rule]", "\"\<Labeled\>\""}]}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "alfa1", ",", "0.3", ",", 
       "\"\<\!\(\*SubscriptBox[\(\[Alpha]\), \(1\)]\)\>\""}], "}"}], ",", "0",
      ",", "1", ",", 
     RowBox[{"Appearance", "\[Rule]", "\"\<Labeled\>\""}]}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "beta1", ",", "0.2", ",", 
       "\"\<\!\(\*SubscriptBox[\(\[Beta]\), \(1\)]\)\>\""}], "}"}], ",", "0", 
     ",", "1", ",", 
     RowBox[{"Appearance", "\[Rule]", "\"\<Labeled\>\""}]}], "}"}], ",", 
   "Delimiter", ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "alfa2", ",", "0.5", ",", 
       "\"\<\!\(\*SubscriptBox[\(\[Alpha]\), \(2\)]\)\>\""}], "}"}], ",", 
     "0.01", ",", "1", ",", 
     RowBox[{"Appearance", "\[Rule]", "\"\<Labeled\>\""}]}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "alfa3", ",", "0.3", ",", 
       "\"\<\!\(\*SubscriptBox[\(\[Alpha]\), \(3\)]\)\>\""}], "}"}], ",", "0",
      ",", "1", ",", 
     RowBox[{"Appearance", "\[Rule]", "\"\<Labeled\>\""}]}], "}"}], ",", 
