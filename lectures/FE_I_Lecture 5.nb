   3.8569471337724257`*^9}},ExpressionUUID->"3b42c7d4-ad39-44f9-836c-\
6c39b1559009"],

Cell["\<\
We can clearly observe different levels of GARCH model persistence (sum of \
\[Alpha] and \[Beta])\
\>", "Text",
 CellChangeTimes->{{3.856947023757888*^9, 3.856947099302217*^9}, 
   3.856947150050345*^9},ExpressionUUID->"aa908203-aa3d-4dcb-8c7c-\
d3cfc3b4f331"],

Cell[TextData[{
 "Sample 1: 1/02/1950 12/31/1953:\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Sigma]", "t", "2"], "=", 
    RowBox[{"0.000011", "+", 
     RowBox[{"0.64", 
      SubsuperscriptBox["\[Sigma]", 
       RowBox[{"t", "-", "1"}], "2"]}], "+", 
     RowBox[{"0.14", 
      SubsuperscriptBox["a", 
       RowBox[{"t", "-", "1"}], "2"]}]}]}], TraditionalForm]],ExpressionUUID->
  "607cae10-1480-43b3-9b92-3de48e6d5c35"],
 ",  \tt-dof = 5.079.\nSample 2: 1/02/2007 12/31/2010:\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Sigma]", "t", "2"], "=", 
    RowBox[{"0.0000017", "+", 
     RowBox[{"0.9007", 
      SubsuperscriptBox["\[Sigma]", 
       RowBox[{"t", "-", "1"}], "2"]}], "+", 
     RowBox[{"0.09989", 
      SubsuperscriptBox["a", 
       RowBox[{"t", "-", "1"}], "2"]}]}]}], TraditionalForm]],ExpressionUUID->
  "108fde08-14e4-4dfb-b8e6-e847c2b9e4af"],
