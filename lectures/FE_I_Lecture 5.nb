Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  StyleBox[
   RowBox[{
    RowBox[{
     RowBox[{"data", "=", 
      RowBox[{"RandomFunction", "[", 
       RowBox[{
        RowBox[{"FARIMAProcess", "[", 
         RowBox[{
          RowBox[{"{", ".7", "}"}], ",", ".19", ",", 
          RowBox[{"{", ".3", "}"}], ",", "1"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", "500"}], "}"}]}], "]"}]}], ";"}], "\n", 
    RowBox[{
     RowBox[{"acf", "[", 
      RowBox[{"data_", ",", "lmax_", ",", 
       RowBox[{"clev_:", "0.95"}]}], "]"}], ":=", 
     RowBox[{"Show", "[", 
      RowBox[{
       RowBox[{"ListPlot", "[", 
        RowBox[{
         RowBox[{"CorrelationFunction", "[", 
          RowBox[{"data", ",", 
           RowBox[{"{", 
            RowBox[{"0", ",", "lmax"}], "}"}]}], "]"}], ",", 
         RowBox[{"Filling", "\[Rule]", "Axis"}], ",", 
         RowBox[{"PlotRange", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", "lmax"}], "}"}], ",", "All"}], "}"}]}], ",", 
         RowBox[{"PlotStyle", "\[Rule]", 
          RowBox[{"PointSize", "[", "Medium", "]"}]}]}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"Graphics", "[", 
          RowBox[{"{", 
           RowBox[{"Dashed", ",", 
            RowBox[{"Line", "[", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"0", ",", "#"}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{"lmax", ",", "#"}], "}"}]}], "}"}], "]"}]}], "}"}], 
          "]"}], "&"}], "/@", 
        FractionBox[
         RowBox[{"Quantile", "[", 
          RowBox[{
           RowBox[{"NormalDistribution", "[", "]"}], ",", 
           RowBox[{"{", 
            RowBox[{
             FractionBox[
              RowBox[{"1", "-", "clev"}], "2"], ",", 
             RowBox[{"1", "-", 
              FractionBox[
               RowBox[{"1", "-", "clev"}], "2"]}]}], "}"}]}], "]"}], 
         SqrtBox[
          RowBox[{
           RowBox[{"data", "[", "\"\<PathLengths\>\"", "]"}], 
           "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]]]}]}], 
      "]"}]}], "\[IndentingNewLine]", 
    RowBox[{"acf", "[", 
     RowBox[{"data", ",", "100", ",", ".95"}], "]"}]}],
   FontSize->10]}]], "Input",
