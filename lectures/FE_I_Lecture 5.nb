Cell[CellGroupData[{

Cell["ACF for ARFIMA (0, d, 0)", "Subsection",
 CellChangeTimes->{{3.4755279135696697`*^9, 3.475527955497498*^9}, 
   3.477594319769936*^9},ExpressionUUID->"89f96cec-5c02-4746-8d45-\
4bc868933fb4"],

Cell[TextData[{
 "\nARFIMA (0, d, 0):   ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", "\[Minus]", "L"}], ")"}], "d"], 
     SubscriptBox["r", "t"]}], "=", 
    SubscriptBox["\[CurlyEpsilon]", "t"]}], TraditionalForm]],ExpressionUUID->
  "80223268-40cb-4638-8b92-4b037d7e7f1b"],
 "\n\nThe autocorrelations of such a process decline at a hyperbolic rate to \
zero ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"0", "<", "d", "<", 
     FractionBox["1", "2"]}], ")"}], TraditionalForm]],ExpressionUUID->
  "8c1572c6-1be8-4d1a-9796-25f1567c62a9"],
 ", a much slower rate of decay than the exponential decay of the ARMA \
process.The sum of the absolute values of the autocovariance function is \
infinite; this is the case of long memory or long range dependence (Hosking \
1981).\n\nLet us assume ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", "=", 
    RowBox[{
     RowBox[{"E", "(", 
      SubscriptBox["r", "t"], ")"}], "=", "0"}]}], TraditionalForm]],
  ExpressionUUID->"c0603de5-d95a-4763-a68b-fe1148c8b694"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Epsilon]", "t"], TraditionalForm]],ExpressionUUID->
  "1b9d4960-b0f7-457c-9331-0729a0857a68"],
 " is a white noise and the process is stationary and invertible, then the \
autocovariance is defined as\n\n\t",
 Cell[BoxData[
  FormBox[
   TagBox[
    RowBox[{
     RowBox[{"\[Gamma]", "(", "k", ")"}], "=", 
     RowBox[{
      SuperscriptBox["\[Sigma]", "2"], 
      FractionBox[
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"\[Minus]", "1"}], ")"}], "k"], 
        RowBox[{"\[CapitalGamma]", "(", 
         RowBox[{"1", "\[Minus]", 
          RowBox[{"2", "d"}]}], ")"}]}], 
       RowBox[{
        RowBox[{"\[CapitalGamma]", "(", 
         RowBox[{
          RowBox[{"k", "\[Minus]", "d"}], "+", "1"}], ")"}], 
        RowBox[{"\[CapitalGamma]", "(", 
         RowBox[{
          RowBox[{"1", "\[Minus]", "k"}], "\[Minus]", "d"}], ")"}]}]]}]}],
    "MathMLPresentationTag",
    AutoDelete->True], TraditionalForm]],ExpressionUUID->
  "c692a302-2d44-408a-bb51-262cb8720440"],
 "\n\nand the autocorrelation\n\n\t",
 Cell[BoxData[
  FormBox[
   TagBox[
    RowBox[{
     RowBox[{"\[Rho]", "(", "k", ")"}], "=", 
     FractionBox[
      RowBox[{
       RowBox[{"\[CapitalGamma]", "(", 
        RowBox[{"1", "\[Minus]", "d"}], ")"}], 
       RowBox[{"\[CapitalGamma]", "(", 
        RowBox[{"k", "+", "d"}], ")"}]}], 
      RowBox[{
       RowBox[{"\[CapitalGamma]", "(", "d", ")"}], 
       RowBox[{"\[CapitalGamma]", "(", 
        RowBox[{"k", "+", 
         RowBox[{"1", "\[Minus]", "d"}]}], ")"}]}]]}],
    "MathMLPresentationTag",
    AutoDelete->True], TraditionalForm]],ExpressionUUID->
  "b05dbb35-12d5-40bd-9703-2802af0cd81f"],
 ",\n\t\n\t",
 Cell[BoxData[
  FormBox[
   TagBox[
    RowBox[{
     RowBox[{
      RowBox[{"\[Rho]", "(", "k", ")"}], "\[Tilde]", 
      RowBox[{
       FractionBox[
        RowBox[{"\[CapitalGamma]", "(", 
         RowBox[{"1", "\[Minus]", "d"}], ")"}], 
        RowBox[{"\[CapitalGamma]", "(", "d", ")"}]], 
       SuperscriptBox[
        RowBox[{"|", "k", "|"}], 
        RowBox[{
         RowBox[{"2", "d"}], "\[Minus]", "1"}]], Cell[
       "\[NonBreakingSpace]\[NonBreakingSpace]\[NonBreakingSpace]", "Text",
        ExpressionUUID->"f326b83d-15e0-49a0-ba9a-7ad233540676"]}]}], "|", "k",
      "|", 
     RowBox[{"\[RightArrow]", "\[Infinity]"}]}],
    "MathMLPresentationTag",
    AutoDelete->True], TraditionalForm]],ExpressionUUID->
  "59e55440-46a1-4238-bf0d-457813dc3a7c"],
 ".\n\t"
}], "Text",
 CellChangeTimes->{{3.475527956959721*^9, 3.475527970068891*^9}, {
  3.477594006862886*^9, 3.477594169322126*^9}, {3.477594214325161*^9, 
  3.47759421690932*^9}, {3.4775942477848597`*^9, 3.477594350023678*^9}, {
  3.47759457379279*^9, 3.477594644009355*^9}, {3.539286834495573*^9, 
  3.5392868362450647`*^9}, {3.605036887917301*^9, 3.6050369006419067`*^9}, {
  3.605094299726757*^9, 3.605094300146982*^9}, {3.62529323170406*^9, 
  3.625293237572418*^9}, {3.85755538791986*^9, 3.857555387920155*^9}, {
  3.857555480478918*^9, 3.8575555551654463`*^9}, {3.8575555919812307`*^9, 
  3.857555701091161*^9}},ExpressionUUID->"b8981dd6-a4f0-4aa0-ab4b-\
b44ed3e0a0ec"]
}, Open  ]],

