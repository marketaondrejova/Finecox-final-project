Cell[CellGroupData[{

Cell["Concept of Long memory", "Section",
 CellChangeTimes->{{3.406269143060752*^9, 3.406269147568752*^9}, {
   3.530599059624044*^9, 3.530599065584362*^9}, {3.530691073690981*^9, 
   3.530691075674041*^9}, {3.53069147302001*^9, 3.530691474871354*^9}, {
   3.530693029400872*^9, 3.5306930616095943`*^9}, {3.530794625264617*^9, 
   3.530794629791909*^9}, 3.623998439273554*^9, {3.624909357014391*^9, 
   3.62490936629243*^9}},ExpressionUUID->"0af2b4b0-18cb-4ffc-9e90-\
ebbf3e572878"],

Cell[TextData[{
 "There are various definitions of long memory! We focus on a covariance \
structure of the process:\n \n",
 StyleBox["Definition:",
  FontWeight->"Bold",
  FontColor->RGBColor[1, 0, 0]],
 " Let ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "t"], TraditionalForm]],ExpressionUUID->
  "089a997a-b15f-4cf6-87f1-cd8f5697d328"],
 " be a stationary process for which the following holds. There exists a real \
number ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Alpha]", "\[Element]", 
    RowBox[{"(", 
     RowBox[{"0", ",", "1"}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "3884f27f-9027-4127-bba7-2ee9c4d4556f"],
 " and a constant ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["c", "\[Rho]"], ">", "0"}], TraditionalForm]],ExpressionUUID->
  "7c75e603-3a1b-4e94-a726-8e0bb18432be"],
 " such that\n\n\t",
 Cell[BoxData[
  FormBox[
   StyleBox[
    RowBox[{
     RowBox[{
      UnderscriptBox["lim", 
       RowBox[{"k", "\[LongRightArrow]", "\[Infinity]"}]], 
      FractionBox[
       RowBox[{
        RowBox[{"\[Rho]", "(", "k", ")"}], " "}], 
       RowBox[{"[", 
        RowBox[{
         SubscriptBox["c", "\[Rho]"], 
         SuperscriptBox["k", 
          RowBox[{"-", "\[Alpha]"}]]}], "]"}]]}], "=", "1"}],
    FontSize->16], TraditionalForm]],ExpressionUUID->
  "89857c2a-9121-428d-9cc0-feb160ee8ca4"],
 ".\n\nThen ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "t"], TraditionalForm]],ExpressionUUID->
  "1b1407c3-9321-434f-8271-0a54b6da8b3f"],
 " is called a stationary process with long memory or long range dependence \
or strong dependence, or a stationary process with slowly decaying or long \
range correlations (Beran 1994). \n\nFurther we use memory parameter d=(1-\
\[Alpha])/2.\n\nIn case d=0, (\[Alpha]=1), then ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "t"], TraditionalForm]],ExpressionUUID->
  "502d9dc6-59a0-47f5-8aa3-e76423d5b4a8"],
 " is a random process with exponentially decaying ACF."
}], "Text",
 CellChangeTimes->{{3.4676001997071238`*^9, 3.4676002163252697`*^9}, {
