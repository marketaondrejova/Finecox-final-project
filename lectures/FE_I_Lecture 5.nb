Cell[CellGroupData[{

Cell["Example  IGARCH(1,1) artificial processes", "Subsection",
 CellChangeTimes->{{3.396546393955388*^9, 3.3965463976719475`*^9}, {
   3.3966897834559593`*^9, 3.3966897935021915`*^9}, {3.396706036866846*^9, 
   3.396706037818934*^9}, {3.3967149734706483`*^9, 3.3967149883251667`*^9}, 
   3.3967755795612917`*^9, {3.396951968122766*^9, 
   3.39695197774715*^9}},ExpressionUUID->"eebfac84-fa4a-4a03-a023-\
b9d151bc3df3"],

Cell[BoxData[
 RowBox[{
  TagBox[
   StyleBox[
    DynamicModuleBox[{$CellContext`alfa0$$ = 0.549, $CellContext`beta1$$ = 
     0.526, $CellContext`seed$$ = 77777, $CellContext`type$$ = 
     "Simulated series", Typeset`show$$ = True, Typeset`bookmarkList$$ = {}, 
     Typeset`bookmarkMode$$ = "Menu", Typeset`animator$$, Typeset`animvar$$ = 
     1, Typeset`name$$ = "\"untitled\"", Typeset`specs$$ = {{
       Hold[
        Style["IGARCH(1,1)", 12, Bold]], Manipulate`Dump`ThisIsNotAControl}, {{
        Hold[$CellContext`type$$], "Simulated series", ""}, {
       "Simulated series", "Simulated Volatility"}}, {{
        Hold[$CellContext`alfa0$$], 0.5, 
        "\!\(\*SubscriptBox[\(\[Alpha]\), \(0\)]\)"}, 0.01, 1}, {{
        Hold[$CellContext`beta1$$], 0.2, 
        "\!\(\*SubscriptBox[\(\[Beta]\), \(1\)]\)"}, 0, 1}, {{
        Hold[$CellContext`seed$$], 77777, "New Random Case"}, 10000, 999999, 
       1}, {
       Hold[
        Button["Export Simulated Series", 
         Export["igarch.txt", $CellContext`igarcha], ImageSize -> 200]], 
       Manipulate`Dump`ThisIsNotAControl}}, Typeset`size$$ = {
     1080., {328., 345.}}, Typeset`update$$ = 0, Typeset`initDone$$, 
     Typeset`skipInitDone$$ = True, $CellContext`type$298$$ = 
     False, $CellContext`alfa0$303$$ = 0, $CellContext`beta1$304$$ = 
     0, $CellContext`seed$305$$ = 0}, 
     DynamicBox[Manipulate`ManipulateBoxes[
      1, StandardForm, 
       "Variables" :> {$CellContext`alfa0$$ = 0.5, $CellContext`beta1$$ = 
         0.2, $CellContext`seed$$ = 77777, $CellContext`type$$ = 
         "Simulated series"}, "ControllerVariables" :> {
         Hold[$CellContext`type$$, $CellContext`type$298$$, False], 
         Hold[$CellContext`alfa0$$, $CellContext`alfa0$303$$, 0], 
         Hold[$CellContext`beta1$$, $CellContext`beta1$304$$, 0], 
         Hold[$CellContext`seed$$, $CellContext`seed$305$$, 0]}, 
       "OtherVariables" :> {
        Typeset`show$$, Typeset`bookmarkList$$, Typeset`bookmarkMode$$, 
         Typeset`animator$$, Typeset`animvar$$, Typeset`name$$, 
         Typeset`specs$$, Typeset`size$$, Typeset`update$$, 
         Typeset`initDone$$, Typeset`skipInitDone$$}, 
       "Body" :> (
        SeedRandom[$CellContext`seed$$]; $CellContext`eiga = RandomReal[
           NormalDistribution[0, 1], 500]; $CellContext`igarch = 
         Table[1, {500}]; $CellContext`igarcha = Table[1, {500}]; 
        Part[$CellContext`igarch, 1] = Variance[$CellContext`eiga]; 
        Part[$CellContext`igarcha, 1] = Sqrt[
            Part[$CellContext`igarch, 1]] Part[$CellContext`eiga, 1]; 
        Do[Part[$CellContext`igarch, $CellContext`i] = $CellContext`alfa0$$ + \
$CellContext`beta1$$ 
             Part[$CellContext`igarch, $CellContext`i - 1] + (
              1 - $CellContext`beta1$$) 
             Part[$CellContext`igarcha, $CellContext`i - 1]^2; 
          Part[$CellContext`igarcha, $CellContext`i] = Sqrt[
              Part[$CellContext`igarch, $CellContext`i]] 
            Part[$CellContext`eiga, $CellContext`i]; Null, {$CellContext`i, 2, 
           Length[$CellContext`eiga]}]; If[$CellContext`beta1$$ < 1 === True, 
          ListPlot[
           
           If[$CellContext`type$$ === 
            "Simulated series", $CellContext`igarcha, $CellContext`igarch], 
           Joined -> True, Frame -> True, PlotStyle -> {
             Dashing[None], 
             Thickness[Medium], Red}, AxesOrigin -> {0, 0}, PlotRange -> 
           If[$CellContext`type$$ === "Simulated series", {-12, 12}, All]], 
          Style[
          "Please input \!\(\*SubscriptBox[\(\[Beta]\), \(i\)]\)<1", Bold, 
           12]]), "Specifications" :> {
         Style[
         "IGARCH(1,1)", 12, 
          Bold], {{$CellContext`type$$, "Simulated series", ""}, {
          "Simulated series", "Simulated Volatility"}}, 
         Delimiter, {{$CellContext`alfa0$$, 0.5, 
           "\!\(\*SubscriptBox[\(\[Alpha]\), \(0\)]\)"}, 0.01, 1, Appearance -> 
          "Labeled"}, {{$CellContext`beta1$$, 0.2, 
           "\!\(\*SubscriptBox[\(\[Beta]\), \(1\)]\)"}, 0, 1, Appearance -> 
          "Labeled"}, 
         Delimiter, {{$CellContext`seed$$, 77777, "New Random Case"}, 10000, 
          999999, 1}, 
         Button["Export Simulated Series", 
          Export["igarch.txt", $CellContext`igarcha], ImageSize -> 200]}, 
       "Options" :> {}, "DefaultOptions" :> {}],
      ImageSizeCache->{1207., {628., 646.}},
      SingleEvaluation->True],
     Deinitialization:>None,
     DynamicModuleValues:>{},
     SynchronousInitialization->True,
     UnsavedVariables:>{Typeset`initDone$$},
     UntrackedVariables:>{Typeset`size$$}], "Manipulate",
    Deployed->True,
    StripOnInput->False],
   Manipulate`InterpretManipulate[1]], "\[AliasDelimiter]"}]], "Input",
 CellChangeTimes->{{3.888234408893587*^9, 
  3.888234408901264*^9}},ExpressionUUID->"8535f80d-186b-4cdb-ba61-\
6f0d7b5ddd1c"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Forecasting with GARCH", "Section",
 CellChangeTimes->{{3.406269143060752*^9, 3.406269147568752*^9}, {
   3.530599059624044*^9, 3.530599065584362*^9}, {3.530691073690981*^9, 
   3.530691075674041*^9}, {3.53069147302001*^9, 3.530691474871354*^9}, 
   3.530693048940098*^9, {3.5306931354178123`*^9, 
   3.530693141359621*^9}},ExpressionUUID->"d535336a-6a2d-4ef8-903c-\
7044ae8cf2de"],

Cell[TextData[{
 "\nGARCH(1,1) is most common for financial applications. The volatility \
equation combines connection with past returns as well as autoregressive \
dependence.\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "t"], "=", 
    RowBox[{
     SubscriptBox["\[Sigma]", "t"], 
     SubscriptBox["\[Epsilon]", "t"]}]}], TraditionalForm]],ExpressionUUID->
  "062f8b0d-bc4b-446e-b864-09473135dc99"],
 ",\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Sigma]", "t", "2"], "=", 
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], "+", 
     RowBox[{
      SubscriptBox["\[Alpha]", "i"], 
      SubsuperscriptBox["a", 
       RowBox[{"t", "-", "1"}], "2"]}], "+", 
     RowBox[{
      SubscriptBox["\[Beta]", "1"], 
      SubsuperscriptBox["\[Sigma]", 
       RowBox[{"t", "-", "1"}], "2"]}]}]}], TraditionalForm]],ExpressionUUID->
  "bb2a7b36-dbc0-44d7-b5a2-47d7e9ab131f"],
 ", \n\nForecasts of the GARCH can be obtained recursively\nat origin ",
 StyleBox["h",
  FontSlant->"Italic"],
 ", the 1-step ahead forecast of ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[Sigma]", 
    RowBox[{"h", "+", "1"}], "2"], TraditionalForm]],ExpressionUUID->
  "8164ab21-3050-4c11-b5ef-3b34b777bbaa"],
 " is:\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Sigma]", 
     RowBox[{"h", "+", "1"}], "2"], "=", 
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], "+", 
     RowBox[{
      SubscriptBox["\[Alpha]", "1"], 
      SubsuperscriptBox["a", "h", "2"]}], "+", 
     RowBox[{
      SubscriptBox["\[Beta]", "1"], 
      SubsuperscriptBox["\[Sigma]", "h", "2"]}]}]}], TraditionalForm]],
  ExpressionUUID->"80f8d89e-7fab-491e-adde-583f2b915833"],
 "\n\nFor multi-forecast, we use ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["a", "t", "2"], "=", 
    RowBox[{
     SubsuperscriptBox["\[Sigma]", "t", "2"], 
     SubsuperscriptBox["\[Epsilon]", "t", "2"]}]}], TraditionalForm]],
  ExpressionUUID->"5b1868e9-fdae-4755-987b-b1e4c9e182ca"],
 " and since ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"E", "(", 
     RowBox[{
      SubsuperscriptBox["\[Epsilon]", 
       RowBox[{"h", "+", "1"}], "2"], 
      RowBox[{"\[LeftBracketingBar]", 
       SubscriptBox["F", "h"]}]}], ")"}], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"9d740c92-d46c-4186-bd71-ee57b470ea5a"],
 ", we have,\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Sigma]", 
     RowBox[{"h", "+", "1"}], "2"], "   ", "=", 
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["\[Alpha]", "1"], "+", 
        SubscriptBox["\[Beta]", "1"]}], ")"}], 
      SubsuperscriptBox["\[Sigma]", "h", "2"]}]}]}], TraditionalForm]],
  ExpressionUUID->"2d3885ad-af99-4947-9486-84f6bb1bd7af"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Sigma]", 
     RowBox[{"h", "+", "2"}], "2"], "   ", "=", 
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["\[Alpha]", "1"], "+", 
        SubscriptBox["\[Beta]", "1"]}], ")"}], 
      SubsuperscriptBox["\[Sigma]", 
       RowBox[{"h", "+", "1"}], "2"]}]}]}], TraditionalForm]],ExpressionUUID->
  "0e391181-1589-4f37-a2b6-147854a2cc17"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Sigma]", 
     RowBox[{"h", "+", "l", "+", "1"}], "2"], "=", 
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["\[Alpha]", "1"], "+", 
        SubscriptBox["\[Beta]", "1"]}], ")"}], 
      SubsuperscriptBox["\[Sigma]", 
       RowBox[{"h", "+", "l"}], "2"]}]}]}], TraditionalForm]],ExpressionUUID->
  "92fa6784-0e7d-4c05-a9dc-599f4219d005"],
 ",  ",
 StyleBox[" l",
  FontSlant->"Italic"],
 ">1\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Sigma]", 
     RowBox[{"h", "+", "l"}], "2"], "\[Rule]", 
    StyleBox[
     FractionBox[
      SubscriptBox["\[Alpha]", "0"], 
      RowBox[{"1", "-", 
       SubscriptBox["\[Alpha]", "1"], "-", 
       SubscriptBox["\[Beta]", "1"]}]],
     FontSize->16]}], TraditionalForm]],ExpressionUUID->
  "27a7ae01-e105-403c-a95d-eb9030fc50ba"],
 ",  as  ",
 StyleBox["l\[Rule]\[Infinity].  \n",
  FontSlant->"Italic"],
 "Hence, the forecast converges to the ",
 StyleBox["unconditional variance",
  FontColor->RGBColor[1, 0, 0]],
 ".\n"
}], "Text",
 CellChangeTimes->{{3.4062691559797516`*^9, 3.406269427871752*^9}, 
   3.5296755517986937`*^9, 3.530691101115761*^9, {3.530691203421274*^9, 
   3.530691263909665*^9}, {3.530691298812022*^9, 3.530691587991209*^9}, {
   3.5306916569332542`*^9, 3.530691791578145*^9}, {3.530691826696795*^9, 
   3.5306918520562468`*^9}, {3.530691904724057*^9, 3.5306919544418077`*^9}, {
   3.5306920106236897`*^9, 3.530692199564807*^9}, {3.5306933782391043`*^9, 
   3.530693413128079*^9}, {3.530779916066235*^9, 3.530779916568037*^9}, {
   3.592418783832465*^9, 3.592418783915532*^9}, {3.592419276407947*^9, 
   3.592419346653944*^9}, {3.59242029119427*^9, 3.5924203795518303`*^9}, {
   3.856944412328459*^9, 3.856944554866324*^9}, {3.888399460866124*^9, 
   3.888399460886346*^9}, {3.888399711349668*^9, 3.888399721448269*^9}, {
   3.8884008414448023`*^9, 
   3.888400842968539*^9}},ExpressionUUID->"fa6b4c37-1d54-4c86-9410-\
782089404641"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Forecasting with the Exponential Moving Average (EWMA)", "Section",
 CellChangeTimes->{{3.396547257332746*^9, 3.3965472724968147`*^9}, 
   3.3967113542003436`*^9, {3.530822359232255*^9, 3.530822364859624*^9}, {
   3.655474841553769*^9, 
   3.65547486319009*^9}},ExpressionUUID->"0c29d011-e0cb-4172-998f-\
f4e9528aa34f"],

Cell[TextData[{
 "Alternatively, exponential moving average (EWMA) estimator of volatility \
can be used. It uses all data points, and recent observations carry larger \
weights. (weights are exponentially decreasing). It also has the effect of \
diminishing the problematic \[OpenCurlyDoubleQuote]Ghost Features\
\[CloseCurlyDoubleQuote].\n\nAn ",
 StyleBox["m-period EWMA",
  FontWeight->"Bold"],
 " with smooth constant \[Lambda] is defined as:\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Sigma]", "t", "2"], "=", 
    StyleBox[
     FractionBox[
      RowBox[{
       UnderoverscriptBox["\[Sum]", 
        RowBox[{"\[Tau]", "=", "1"}], "m"], 
       RowBox[{
        SuperscriptBox["\[Lambda]", 
         RowBox[{"\[Tau]", "-", "1"}]], 
        SubsuperscriptBox["r", 
         RowBox[{"t", "-", "1", "-", "\[Tau]"}], "2"]}]}], 
      RowBox[{
       RowBox[{
        RowBox[{"1", "+", 
         SuperscriptBox["\[Lambda]", "1"], "+"}], "..."}], "+", 
       SuperscriptBox["\[Lambda]", 
        RowBox[{"m", "-", "1"}]]}]],
     FontSize->16]}], TraditionalForm]],ExpressionUUID->
  "80f6e3ab-fad4-4a37-a34e-263752cc3fc0"],
 "  where ",
 StyleBox["0<\[Lambda]<1",
  FontSlant->"Italic"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Sigma]", 
     RowBox[{
      RowBox[{
       RowBox[{"t", "+", "1"}], "\[RightBracketingBar]"}], "t"}], "2"], "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", "\[Lambda]"}], ")"}], 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"\[Tau]", "=", "0"}], "\[Infinity]"], 
      RowBox[{
       SuperscriptBox["\[Lambda]", "\[Tau]"], 
       SubsuperscriptBox["r", 
        RowBox[{"t", "-", "\[Tau]"}], "2"]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"d075c26e-8df7-4913-bade-e36d232fddef"],
 "   as ",
 StyleBox["m",
  FontSlant->"Italic"],
 "\[Rule]\[Infinity],\[AliasDelimiter]\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Sigma]", 
     RowBox[{
      RowBox[{
       RowBox[{"t", "+", "1"}], "\[RightBracketingBar]"}], "t"}], "2"], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", "\[Lambda]"}], ")"}], 
      SubsuperscriptBox["r", "t", "2"]}], "+", 
     RowBox[{
      RowBox[{"\[Lambda]", "(", 
       RowBox[{"1", "-", "\[Lambda]"}], ")"}], 
      RowBox[{"(", 
       RowBox[{
        UnderoverscriptBox["\[Sum]", 
         RowBox[{"\[Tau]", "=", "1"}], "\[Infinity]"], 
        RowBox[{
         SuperscriptBox["\[Lambda]", 
          RowBox[{"\[Tau]", "-", "1"}]], 
         SubsuperscriptBox["r", 
          RowBox[{"t", "-", "\[Tau]"}], "2"]}]}], ")"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"1f8207b7-7685-4859-8c38-befc0f5db835"],
 "  \nusing the approximation  ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{"\[Tau]", "=", "1"}], "\[Infinity]"], 
    SuperscriptBox["\[Lambda]", 
     RowBox[{"\[Tau]", "-", "1"}]]}], "\[TildeEqual]", 
   FractionBox["1", 
    RowBox[{"1", "-", "\[Lambda]"}]]}]],ExpressionUUID->
  "2c89ddbb-9286-4e40-982a-9bcf548b1021"],
 "  we get: \n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Sigma]", 
     RowBox[{
      RowBox[{
       RowBox[{"t", "+", "1"}], "\[RightBracketingBar]"}], "t"}], "2"], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", "\[Lambda]"}], ")"}], 
      SubsuperscriptBox["r", "t", "2"]}], "+", 
     SubsuperscriptBox["\[Lambda]\[Sigma]", 
      RowBox[{
       RowBox[{
        RowBox[{"t", "\[RightBracketingBar]"}], "t"}], "-", "1"}], "2"]}]}], 
   TraditionalForm]],ExpressionUUID->"8507ea85-7bc5-40aa-80c8-cca7cbc9a046"],
 ",\n\nwhere the initial value could be unconditional variance in a \
historical sample. \nIn most financial applications, \[Lambda]=0.94 is used.\n\
\nThe EWMA model is equivalent to the IGARCH model, that is why the next day \
forecasts look very similar to forecasts based on GARCH type models.\n\nThe \
EWMA ignores the long-run variance (unconditional), while the forecasts based \
on GARCH family models converge in the long-run to the unconditional variance \
of the sample.\n\.00\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Sigma]", "t", "2"], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", "\[Lambda]"}], ")"}], 
      SubsuperscriptBox["r", 
       RowBox[{"t", "-", "1"}], "2"]}], "+", 
     SubsuperscriptBox["\[Lambda]\[Sigma]", 
      RowBox[{"t", "-", "1"}], "2"]}]}], TraditionalForm]],ExpressionUUID->
  "647d9cc8-9ecd-468c-a21c-547a903c1647"],
 ",\nwhere initial value could be unconditional variance in a historical \
sample. In most financial applications, \[Lambda]=0.94 is used.\n"
}], "Text",
 CellChangeTimes->{{3.406224215351424*^9, 3.4062242492884245`*^9}, {
   3.5308017002072353`*^9, 3.530801746121579*^9}, 3.530801804585319*^9, {
   3.530802106440384*^9, 3.530802138766775*^9}, {3.5308021732449427`*^9, 
   3.530802189989048*^9}, {3.5308125842253723`*^9, 3.5308125871043043`*^9}, 
   3.530812646353763*^9, {3.5308127185578747`*^9, 3.5308127783227386`*^9}, {
   3.530812818271785*^9, 3.530813102581506*^9}, {3.5308131480666237`*^9, 
   3.530813197646903*^9}, {3.530813429485292*^9, 3.530813526225408*^9}, {
   3.530813566227002*^9, 3.530813752722115*^9}, {3.530813827931457*^9, 
   3.530813832984796*^9}, 3.530813964937663*^9, {3.530853957959064*^9, 
   3.5308539832650843`*^9}, {3.5308540133386583`*^9, 3.530854132203023*^9}, {
   3.530855106902356*^9, 3.530855238984508*^9}, {3.530855403653458*^9, 
   3.530855408209488*^9}, {3.592485969278573*^9, 3.592485974837697*^9}, 
   3.592486017509795*^9, {3.592486069438229*^9, 3.592486090975472*^9}, {
   3.592486125900875*^9, 3.592486138187056*^9}, {3.5924947112731*^9, 
   3.592494732991228*^9}, {3.655474941642329*^9, 3.655474942351623*^9}, {
   3.888470879750965*^9, 3.888470880236792*^9}, {3.8884714774784937`*^9, 
   3.888471477864937*^9}, 
   3.8884786959274273`*^9},ExpressionUUID->"570d42f3-7f80-449f-b8b1-\
064f8d45d208"],

Cell[CellGroupData[{

Cell["Example 1 month, 1 year volatility of Apple.", "Subsection",
 CellChangeTimes->{{3.396784602574602*^9, 3.396784612252694*^9}, {
