    1.700000000000001, $CellContext`type$$ = "Simulated series", 
    Typeset`show$$ = True, Typeset`bookmarkList$$ = {}, 
    Typeset`bookmarkMode$$ = "Menu", Typeset`animator$$, Typeset`animvar$$ = 
    1, Typeset`name$$ = "\"untitled\"", Typeset`specs$$ = {{
      Hold[
       Style["AR(1)-TAR-GARCH(1,1)", 12, Bold]], 
      Manipulate`Dump`ThisIsNotAControl}, {{
       Hold[$CellContext`type$$], "Simulated series", ""}, {
      "Simulated series", "Simulated Volatility"}}, {{
       Hold[$CellContext`tresh$$], 0, "treshold - k"}, -10, 10}, {{
       Hold[$CellContext`arconst$$], 0.6, 
       "\!\(\*SubscriptBox[\(\[Phi]\), \(0\)]\)"}, -3, 3}, {{
       Hold[$CellContext`arp1$$], 0.5, 
       "\!\(\*SubscriptBox[\(\[Phi]\), \(1\)]\)"}, -1, 1}, {{
       Hold[$CellContext`alfa0$$], 0.5, 
       "\!\(\*SubscriptBox[\(\[Alpha]\), \(0\)]\)"}, 0.01, 1}, {{
       Hold[$CellContext`alfa1$$], 0.3, 
       "\!\(\*SubscriptBox[\(\[Alpha]\), \(1\)]\)"}, 0, 1}, {{
       Hold[$CellContext`beta1$$], 0.2, 
       "\!\(\*SubscriptBox[\(\[Beta]\), \(1\)]\)"}, 0, 1}, {{
       Hold[$CellContext`alfa2$$], 0.5, 
       "\!\(\*SubscriptBox[\(\[Alpha]\), \(2\)]\)"}, 0.01, 1}, {{
       Hold[$CellContext`alfa3$$], 0.3, 
       "\!\(\*SubscriptBox[\(\[Alpha]\), \(3\)]\)"}, 0, 1}, {{
       Hold[$CellContext`beta2$$], 0.5, 
       "\!\(\*SubscriptBox[\(\[Beta]\), \(2\)]\)"}, 0, 1}, {{
       Hold[$CellContext`seed$$], 77777, "New Random Case"}, 10000, 999999, 
      1}, {
      Hold[
       Button["Export Simulated Series", 
        Export["Ar1_Tar_GARCH_11.txt", $CellContext`r], ImageSize -> 200]], 
      Manipulate`Dump`ThisIsNotAControl}}, Typeset`size$$ = {
    1080., {333., 350.}}, Typeset`update$$ = 0, Typeset`initDone$$, 
    Typeset`skipInitDone$$ = True, $CellContext`type$7341$$ = 
    False, $CellContext`tresh$7342$$ = 0, $CellContext`arconst$7343$$ = 
    0, $CellContext`arp1$7344$$ = 0, $CellContext`alfa0$7345$$ = 
    0, $CellContext`alfa1$7346$$ = 0, $CellContext`beta1$7347$$ = 
    0, $CellContext`alfa2$7348$$ = 0, $CellContext`alfa3$7349$$ = 
    0, $CellContext`beta2$7350$$ = 0, $CellContext`seed$7351$$ = 0}, 
    DynamicBox[Manipulate`ManipulateBoxes[
     1, StandardForm, 
      "Variables" :> {$CellContext`alfa0$$ = 0.5, $CellContext`alfa1$$ = 
        0.3, $CellContext`alfa2$$ = 0.5, $CellContext`alfa3$$ = 
        0.3, $CellContext`arconst$$ = 0.6, $CellContext`arp1$$ = 
        0.5, $CellContext`beta1$$ = 0.2, $CellContext`beta2$$ = 
        0.5, $CellContext`seed$$ = 77777, $CellContext`tresh$$ = 
        0, $CellContext`type$$ = "Simulated series"}, "ControllerVariables" :> {
        Hold[$CellContext`type$$, $CellContext`type$7341$$, False], 
        Hold[$CellContext`tresh$$, $CellContext`tresh$7342$$, 0], 
        Hold[$CellContext`arconst$$, $CellContext`arconst$7343$$, 0], 
        Hold[$CellContext`arp1$$, $CellContext`arp1$7344$$, 0], 
        Hold[$CellContext`alfa0$$, $CellContext`alfa0$7345$$, 0], 
        Hold[$CellContext`alfa1$$, $CellContext`alfa1$7346$$, 0], 
        Hold[$CellContext`beta1$$, $CellContext`beta1$7347$$, 0], 
        Hold[$CellContext`alfa2$$, $CellContext`alfa2$7348$$, 0], 
        Hold[$CellContext`alfa3$$, $CellContext`alfa3$7349$$, 0], 
        Hold[$CellContext`beta2$$, $CellContext`beta2$7350$$, 0], 
        Hold[$CellContext`seed$$, $CellContext`seed$7351$$, 0]}, 
      "OtherVariables" :> {
       Typeset`show$$, Typeset`bookmarkList$$, Typeset`bookmarkMode$$, 
        Typeset`animator$$, Typeset`animvar$$, Typeset`name$$, 
        Typeset`specs$$, Typeset`size$$, Typeset`update$$, Typeset`initDone$$,
         Typeset`skipInitDone$$}, 
      "Body" :> (
       SeedRandom[$CellContext`seed$$]; $CellContext`random = RandomReal[
          NormalDistribution[0, 1], 500]; $CellContext`s = 
        Table[0, {500}]; $CellContext`r = Table[0, {500}]; $CellContext`a = 
        Table[0, {500}]; 
       Part[$CellContext`r, 1] = Part[$CellContext`random, 1]; 
       Part[$CellContext`s, 1] = Variance[$CellContext`random]; 
       Do[If[Part[$CellContext`a, $CellContext`i - 1] > $CellContext`tresh$$, 
           Part[$CellContext`s, $CellContext`i] = $CellContext`alfa2$$ + \
$CellContext`alfa3$$ 
              Part[$CellContext`r, $CellContext`i - 
                 1]^2 + $CellContext`beta2$$ 
              Part[$CellContext`s, $CellContext`i - 1]; Null, 
           Part[$CellContext`s, $CellContext`i] = $CellContext`alfa0$$ + \
$CellContext`alfa1$$ 
              Part[$CellContext`r, $CellContext`i - 
                 1]^2 + $CellContext`beta1$$ 
              Part[$CellContext`s, $CellContext`i - 1]; Null]; 
         Part[$CellContext`a, $CellContext`i] = Sqrt[
             Part[$CellContext`s, $CellContext`i]] 
           Part[$CellContext`random, $CellContext`i]; 
         Part[$CellContext`r, $CellContext`i] = $CellContext`arconst$$ + \
$CellContext`arp1$$ Part[$CellContext`r, $CellContext`i - 1] + 
           Part[$CellContext`a, $CellContext`i]; Null, {$CellContext`i, 2, 
          Length[$CellContext`random]}]; 
       If[$CellContext`alfa1$$ + $CellContext`beta1$$ < 1 === True, 
         If[$CellContext`alfa3$$ + $CellContext`beta2$$ < 1 === True, 
          ListPlot[
           
           If[$CellContext`type$$ === 
            "Simulated series", $CellContext`r, $CellContext`s], Joined -> 
           True, Frame -> True, PlotStyle -> {
             Thickness[Medium], Red}, PlotRange -> All], 
          Style[
          "Please input (\!\(\*SubscriptBox[\(\[Alpha]\), \
\(i\)]\)+\!\(\*SubscriptBox[\(\[Beta]\), \(i\)]\))<1", Bold, 12]], 
         Style[
         "Please input (\!\(\*SubscriptBox[\(\[Alpha]\), \
\(i\)]\)+\!\(\*SubscriptBox[\(\[Beta]\), \(i\)]\))<1", Bold, 12]]), 
      "Specifications" :> {
        Style[
        "AR(1)-TAR-GARCH(1,1)", 12, 
         Bold], {{$CellContext`type$$, "Simulated series", ""}, {
         "Simulated series", "Simulated Volatility"}}, 
        Delimiter, {{$CellContext`tresh$$, 0, "treshold - k"}, -10, 10, 
         Appearance -> "Labeled"}, 
        Delimiter, {{$CellContext`arconst$$, 0.6, 
          "\!\(\*SubscriptBox[\(\[Phi]\), \(0\)]\)"}, -3, 3, Appearance -> 
         "Labeled"}, {{$CellContext`arp1$$, 0.5, 
          "\!\(\*SubscriptBox[\(\[Phi]\), \(1\)]\)"}, -1, 1, Appearance -> 
