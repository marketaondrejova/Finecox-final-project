         "Labeled"}, {{$CellContext`beta1$$, 0.2, 
          "\!\(\*SubscriptBox[\(\[Beta]\), \(1\)]\)"}, 0, 1, Appearance -> 
         "Labeled"}, 
        Delimiter, {{$CellContext`alfa2$$, 0.5, 
          "\!\(\*SubscriptBox[\(\[Alpha]\), \(2\)]\)"}, 0.01, 1, Appearance -> 
         "Labeled"}, {{$CellContext`alfa3$$, 0.3, 
          "\!\(\*SubscriptBox[\(\[Alpha]\), \(3\)]\)"}, 0, 1, Appearance -> 
         "Labeled"}, {{$CellContext`beta2$$, 0.5, 
          "\!\(\*SubscriptBox[\(\[Beta]\), \(2\)]\)"}, 0, 1, Appearance -> 
         "Labeled"}, {{$CellContext`seed$$, 77777, "New Random Case"}, 10000, 
         999999, 1}, 
        Button["Export Simulated Series", 
         Export["Ar1_Tar_GARCH_11.txt", $CellContext`r], ImageSize -> 200]}, 
      "Options" :> {ControlPlacement -> Top}, "DefaultOptions" :> {}],
