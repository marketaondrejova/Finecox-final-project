Cell[CellGroupData[{

Cell["Fractional ARIMA", "Section",
 CellChangeTimes->{{3.4678703272823687`*^9, 3.467870385293833*^9}, {
   3.468087779585867*^9, 3.468087782806818*^9}, {3.475526242514645*^9, 
   3.475526244346588*^9}, 3.4755278873754187`*^9, 
   3.477594494940116*^9},ExpressionUUID->"e355ec3a-5a0f-4847-8166-\
3cee645cc0d6"],

Cell[TextData[{
 "ARIMA model were introduced by Box and Jenkins in 1970.\n \nFractional \
ARIMA (ARFIMA, FARIMA) models are natural extension of the classic ARIMA.\n\n",
 StyleBox["ARMA (p, q):",
  FontWeight->"Bold"],
 "\n\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["r", "t"], "=", 
    RowBox[{
     SubscriptBox["\[Phi]", "0"], "+", 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"i", "=", "1"}], "p"], 
      RowBox[{
       SubscriptBox["\[Phi]", "i"], 
       SubscriptBox["r", 
        RowBox[{"t", "-", "1"}]]}]}], "+", 
     SubscriptBox["\[Epsilon]", "t"], "-", 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"l", "=", "1"}], "q"], 
      RowBox[{
       SubscriptBox["\[Theta]", "i"], 
       SubscriptBox["\[Epsilon]", 
        RowBox[{"t", "-", "l"}]]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "38828000-a9d6-4fad-b8fb-01f7385c103c"],
 "\nor\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"1", "-", 
         RowBox[{
          SubscriptBox["\[Phi]", "1"], "L"}], " ", "-"}], "..."}], "-", 
       RowBox[{
        SubscriptBox["\[Phi]", "p"], 
        SuperscriptBox["L", "p"]}]}], ")"}], 
     SubscriptBox["r", "t"]}], "=", 
    RowBox[{
     SubscriptBox["\[Phi]", "0"], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"1", "+", 
          RowBox[{
           SubscriptBox["\[Theta]", "1"], "L"}], "+"}], "..."}], "+", 
        RowBox[{
         SubscriptBox["\[Theta]", "q"], 
         SuperscriptBox["L", "q"]}]}], ")"}], 
      SubscriptBox["\[Epsilon]", "t"]}]}]}], TraditionalForm]],ExpressionUUID->
  "d7abe87c-3da2-458f-afe8-cc3b12b8628c"],
 "\n\t\n",
 StyleBox["ARIMA (p, d, q)",
  FontWeight->"Bold"],
 ":\nSeries are said to be ARIMA(\[ScriptP],1,\[ScriptQ]), when the process ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["r", "t"], "-", 
     SubscriptBox["r", 
      RowBox[{"t", "-", "1"}]]}], "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", "L"}], ")"}], 
     SubscriptBox["r", "t"]}]}], TraditionalForm]],ExpressionUUID->
  "71c00fa2-4e54-4cc7-8f28-c6937d13c492"],
 " follows a stationary and invertible ARMA(\[ScriptP],\[ScriptQ]). Parameter \
\[ScriptD] is equal to 1, and means, that ARMA(\[ScriptP],\[ScriptQ]) series \
are differenced once (parameter ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "9861ef0a-7f41-4181-bff6-031f2f8c0e67"],
 " is an integer, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "\[GreaterEqual]", "0"}], TraditionalForm]],ExpressionUUID->
  "26c843df-246a-45d5-b638-c800c9c44f3e"],
 ").\n\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"\[Phi]", "(", "L", ")"}], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", "\[Minus]", "L"}], ")"}], "d"], 
     SubscriptBox["r", "t"]}], "=", 
    RowBox[{
     RowBox[{"\[Theta]", "(", "L", ")"}], 
     SubscriptBox["\[CurlyEpsilon]", "t"]}]}], TraditionalForm]],
  ExpressionUUID->"7600d26f-f8f0-468b-9a69-6663e03e62ec"],
 "\n\n",
 StyleBox["ARFIMA",
  FontWeight->"Bold"],
 " generalize ARIMA by allowing ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "fd0742d3-8c6b-44b6-a2fc-062548141925"],
 " to assume any real value.\n\n",
 StyleBox["Definition ARFIMA",
  FontWeight->"Bold"],
 ": Let ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "t"], TraditionalForm]],ExpressionUUID->
  "19430454-5870-423a-9d16-05f068e3dcde"],
 " be a stationary process such that\n\n\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", "\[Minus]", "L"}], ")"}], "d"], 
     RowBox[{"\[Phi]", "(", "L", ")"}], 
     SubscriptBox["r", "t"]}], "=", 
    RowBox[{
     RowBox[{"\[Theta]", "(", "L", ")"}], 
     SubscriptBox["\[CurlyEpsilon]", "t"]}]}], TraditionalForm]],
  ExpressionUUID->"77b58cf2-e53f-47c2-acaf-5283821307f8"],
 "\n\t \nfor some  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", 
     FractionBox["1", "2"]}], "<", "d", "<", 
    FractionBox["1", "2"]}], TraditionalForm]],ExpressionUUID->
  "89494917-a1c3-4770-b925-a43bbd4592d5"],
 ". Then ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "t"], TraditionalForm]],ExpressionUUID->
  "e6ca4523-5d7f-47c9-ab93-c0da2365a1f6"],
 " is called a fractional ARIMA (p,d,q) process.\n\nThe parameter ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "73d02faf-6557-4a82-a45c-22b88e0dabc6"],
 " determines the long-term behavior, parameters ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", " "}], TraditionalForm]],ExpressionUUID->
  "a18b339e-e995-450b-8969-a7cd83825a69"],
 "and ",
 Cell[BoxData[
  FormBox["q", TraditionalForm]],ExpressionUUID->
  "d4ad9408-a24e-47d7-9743-8968542b6bdb"],
 " allow for more flexible modelling of the short-range properties.\n\nFor ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"1", "\[Minus]", "L"}], ")"}], "d"], TraditionalForm]],
  ExpressionUUID->"79d4f4e1-dea3-493f-8f9b-3360b7c071de"],
 " , where ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "d178029e-8cc6-4701-8e9f-c4d5f145d1e5"],
 " is any real number we can write:\n\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"1", "\[Minus]", "L"}], ")"}], "d"], "=", 
    RowBox[{
     StyleBox[
      RowBox[{
       UnderoverscriptBox["\[Sum]", 
        RowBox[{"k", "=", "0"}], "\[Infinity]"], 
       RowBox[{"(", GridBox[{
          {"d"},
          {"k"}
         }], ")"}]}],
      GridBoxOptions->{AllowScriptLevelChange->False}], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"\[Minus]", "1"}], ")"}], "k"], 
     SuperscriptBox["L", "k"]}]}], TraditionalForm]],ExpressionUUID->
  "4b2f12cc-b8af-4f4e-8379-c1c3eb29d213"],
 "   ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"d", "=", 
     RowBox[{"H", "\[Minus]", 
      FractionBox["1", "2"]}]}], ")"}], TraditionalForm]],ExpressionUUID->
  "17070b81-b2bb-4bf2-991c-649e2aa03e92"],
 ",\n\n\t",
 Cell[BoxData[
  FormBox[
   TagBox[
    RowBox[{
     RowBox[{"(", GridBox[{
        {"d"},
        {"k"}
       }], ")"}], "=", 
     RowBox[{
      FractionBox[
       RowBox[{"d", "!"}], 
       RowBox[{
        RowBox[{"k", "!"}], 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"d", "\[Minus]", "k"}], ")"}], "!"}]}]], "=", 
      FractionBox[
       RowBox[{"\[CapitalGamma]", "(", 
        RowBox[{"d", "+", "1"}], ")"}], 
       RowBox[{
        RowBox[{"\[CapitalGamma]", "(", 
         RowBox[{"k", "+", "1"}], ")"}], 
        RowBox[{"\[CapitalGamma]", "(", 
         RowBox[{
          RowBox[{"d", "\[Minus]", "k"}], "+", "1"}], ")"}]}]]}]}],
    "MathMLPresentationTag",
    AutoDelete->True], TraditionalForm]],ExpressionUUID->
  "75ebfd71-20c5-4b86-8f2a-02a7c45896ea"],
 ",\n\t\nwhere  \[CapitalGamma](.) is Euler\[CloseCurlyQuote]s gamma \
function.\n\n",
 StyleBox["Thus, when we apply the fractional differencing operator (which is \
in fact a filter) we obtain:\n\n\t",
  FontColor->GrayLevel[0]],
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Z", "t"], "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "\[Minus]", "L"}], ")"}], "d"], 
      SubscriptBox["r", "t"]}], "=", 
     RowBox[{"\[Phi]", 
      SuperscriptBox[
       RowBox[{"(", "L", ")"}], 
       RowBox[{"-", "1"}]], 
      RowBox[{"\[Theta]", "(", "L", ")"}], 
      SubscriptBox["\[CurlyEpsilon]", "t"]}]}]}], TraditionalForm]],
  FontColor->GrayLevel[0],ExpressionUUID->
  "caa0f044-b14d-48c6-b7d3-f17aad42f635"],
 StyleBox["\n \n where ",
  FontColor->GrayLevel[0]],
 Cell[BoxData[
  FormBox[
   SubscriptBox["Z", "t"], TraditionalForm]],
  FontColor->GrayLevel[0],ExpressionUUID->
  "64ff5d6e-7310-4f8c-be8a-68b5e3c28a56"],
 StyleBox[" is the ordinary ARMA(p,q) process.\n ",
  FontColor->GrayLevel[0]]
}], "Text",
 CellChangeTimes->{{3.467870388458109*^9, 3.467870408013266*^9}, {
   3.467870644784322*^9, 3.4678706503737164`*^9}, {3.467871155888075*^9, 
