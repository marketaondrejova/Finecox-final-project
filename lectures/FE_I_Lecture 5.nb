Cell[CellGroupData[{

Cell["GJR-GARCH", "Subsection",
 CellChangeTimes->{
  3.3967798439211683`*^9, {3.396783235916957*^9, 3.3967832365760946`*^9}, {
   3.530795255839737*^9, 3.530795263628566*^9}, {3.530795329576004*^9, 
   3.530795336398631*^9}, {3.530796572285531*^9, 3.530796580547531*^9}, {
   3.530814847283098*^9, 3.53081484939305*^9}, {3.750443798692893*^9, 
   3.750443804887397*^9}},ExpressionUUID->"a3ea24a7-0ac2-4070-a0ef-\
5e3a83a7aa3f"],

Cell[TextData[{
 "GJR-GARCH is a simple version of threshold GARCH model. The volatility \
equation has a form:\n \n",
 Cell[BoxData[
  FormBox[
   RowBox[{"\t", 
    RowBox[{
     SubsuperscriptBox["\[Sigma]", "t", "2"], "=", 
     RowBox[{
      SubscriptBox["\[Alpha]", "0"], "+", 
      RowBox[{
       SubscriptBox["\[Beta]", "1"], 
       SubsuperscriptBox["\[Sigma]", 
        RowBox[{"t", "-", "1"}], "2"]}], "+", 
      RowBox[{
       SubscriptBox["\[Alpha]", "1"], 
       SubsuperscriptBox["a", 
        RowBox[{"t", "-", "1"}], "2"]}], "+", 
      RowBox[{"\[Gamma]", " ", 
       RowBox[{"I", "(", 
        RowBox[{
         SubscriptBox["a", 
          RowBox[{"t", "-", "1"}]], "\[LessSlantEqual]", "0"}], ")"}], 
       SubsuperscriptBox["a", 
        RowBox[{"t", "-", "1"}], "2"]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"a0201c19-457d-4dbe-bc48-89ebb63d0436"],
 "\n\nwhere ",
 Cell[BoxData[
  FormBox["I", TraditionalForm]],ExpressionUUID->
  "d3c1d918-3aee-4f33-88ff-c18e71c2cd67"],
 " is the indicator function."
}], "Text",
 CellChangeTimes->{{3.75044395796276*^9, 3.750443969533002*^9}, {
  3.750444001613558*^9, 3.7504441759987183`*^9}, {3.750444209498205*^9, 
  3.750444270109221*^9}, {3.7504443063317337`*^9, 3.750444421537952*^9}, {
  3.7504444909886637`*^9, 3.7504444982643013`*^9}, {3.750444532989155*^9, 
  3.750444549374481*^9}},ExpressionUUID->"47ea3db0-ede9-4611-a53a-\
14517e47b689"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Empirical example", "Subsection",
 CellChangeTimes->{{3.750443825834915*^9, 
  3.750443835835301*^9}},ExpressionUUID->"0272f50f-3ebd-4778-b2ce-\
eb8de673a9da"],

Cell[TextData[{
 "Apple (AAPL) daily closing prices sample: 9/1/2009 11/18/2011 (561 obs.)\t\n\
\nEstimated volatility eq. (normal innovations): ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Sigma]", "t", "2"], "=", 
    RowBox[{"0.00005", "+", 
     RowBox[{"0.665", 
      SubsuperscriptBox["\[Sigma]", 
       RowBox[{"t", "-", "1"}], "2"]}], "+", 
     RowBox[{"0.244", 
      SubsuperscriptBox["a", 
       RowBox[{"t", "-", "1"}], "2"], 
      RowBox[{"I", "(", 
       RowBox[{
        SubscriptBox["a", 
         RowBox[{"t", "-", "1"}]], "\[LessSlantEqual]", "0"}], ")"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"ed5e2f5d-265c-45aa-a4a4-c8b1141aebd9"],
 "\n\nEstimated volatility eq. (t innovations): ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Sigma]", "t", "2"], "=", 
    RowBox[{"0.00004", "+", 
     RowBox[{"0.71", 
      SubsuperscriptBox["\[Sigma]", 
       RowBox[{"t", "-", "1"}], "2"]}], "+", 
     RowBox[{"0.240", 
      SubsuperscriptBox["a", 
       RowBox[{"t", "-", "1"}], "2"], 
      RowBox[{"I", "(", 
       RowBox[{
        SubscriptBox["a", 
         RowBox[{"t", "-", "1"}]], "\[LessSlantEqual]", "0"}], ")"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"380335bf-04f9-465c-acec-998fb641b8af"],
 "\n\nwhere ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"I", "(", 
     RowBox[{
      SubscriptBox["a", 
       RowBox[{"t", "-", "1"}]], "<", "0"}], ")"}], "=", "1"}], 
   TraditionalForm]],ExpressionUUID->"3f5fb0e9-b4a8-4124-980d-d8c1560db070"],
 " if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", 
     RowBox[{"t", "-", "1"}]], "<", "0"}], TraditionalForm]],ExpressionUUID->
  "a3c070ec-da6d-4b79-abb3-4d9bd6e5565d"],
 ".\n"
}], "Text",
 CellChangeTimes->{{3.465562550012041*^9, 3.4655625975689898`*^9}, {
  3.4655626652489967`*^9, 3.4655627079679623`*^9}, {3.465562754041774*^9, 
  3.4655628333688393`*^9}, {3.530795306470282*^9, 3.530795312841559*^9}, {
  3.5307955256994133`*^9, 3.530795543984868*^9}, {3.5307965917113533`*^9, 
  3.530796816923686*^9}, {3.530796902276546*^9, 3.530796903386833*^9}, {
  3.530796952828418*^9, 3.530797055854691*^9}, {3.5307998114950733`*^9, 
  3.530799833611459*^9}, {3.530799957582294*^9, 3.5307999773160954`*^9}, {
  3.530800013704658*^9, 3.530800041377227*^9}, {3.5308004122716513`*^9, 
  3.5308005627548933`*^9}, {3.7504445147022142`*^9, 
  3.750444518099702*^9}},ExpressionUUID->"bec8536b-fc79-46a0-84e8-\
f3b480269659"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["EGARCH Model", "Section",
 CellChangeTimes->{{3.406269143060752*^9, 3.406269147568752*^9}, {
   3.530599059624044*^9, 3.530599065584362*^9}, {3.530691073690981*^9, 
   3.530691075674041*^9}, {3.53069147302001*^9, 3.530691474871354*^9}, {
   3.530693029400872*^9, 3.5306930616095943`*^9}, {3.530794625264617*^9, 
   3.530794629791909*^9}, 3.623998439273554*^9, {3.6249093855400763`*^9, 
   3.624909385668138*^9}, 
   3.625137733191596*^9},ExpressionUUID->"4e67a076-a214-4ce2-8652-\
d3f20bfffe04"],

Cell[TextData[{
 "The EGARCH (Nelson, 1991) model be also used for capturing asymmetric \
response in volatility - the leverage effect. The EGARCH(m,s) can be defined \
as:\n\t\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "t"], "=", 
    RowBox[{
     SubscriptBox["\[Sigma]", "t"], 
     SubscriptBox["\[Epsilon]", "t"]}]}], TraditionalForm]],ExpressionUUID->
  "c31ce071-4501-4be5-b0fe-afca5d900a23"],
 "\n\t\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"ln", "(", 
     SubsuperscriptBox["\[Sigma]", "t", "2"], ")"}], "=", 
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], "+", 
     RowBox[{
      StyleBox[
       FractionBox[
        RowBox[{
         RowBox[{
          RowBox[{"1", "+", 
           RowBox[{
            SubscriptBox["\[Alpha]", "1"], "L"}], "+"}], "..."}], "+", 
         RowBox[{
          SubscriptBox["\[Alpha]", "m"], 
          SuperscriptBox["L", "m"]}]}], 
        RowBox[{
         RowBox[{
          RowBox[{"1", "-", 
           RowBox[{
            SubscriptBox["\[Beta]", "1"], "L"}]}], "..."}], "-", 
         RowBox[{
          SubscriptBox["\[Beta]", "s"], 
          SuperscriptBox["L", "s"]}]}]],
       FontSize->18], 
      RowBox[{"g", "(", 
       SubscriptBox["\[Epsilon]", 
        RowBox[{"t", "-", "1"}]], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"420670d3-6d1b-4d4c-ab71-5b483988ff5f"],
 "\n\t\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"g", "(", 
     SubscriptBox["\[Epsilon]", "t"], ")"}], "=", 
    RowBox[{
     RowBox[{"\[Theta]", " ", 
      SubscriptBox["\[Epsilon]", "t"]}], "+", 
     RowBox[{"\[Gamma]", "[", 
      RowBox[{
       RowBox[{"\[LeftBracketingBar]", 
        SubscriptBox["\[Epsilon]", "t"], "\[RightBracketingBar]"}], "-", 
       RowBox[{"E", 
        RowBox[{"\[LeftBracketingBar]", 
         SubscriptBox["\[Epsilon]", "t"], "\[RightBracketingBar]"}]}]}], 
      "]"}]}]}], TraditionalForm]],
  FontColor->RGBColor[1, 0, 0],ExpressionUUID->
  "b3a6df3e-7e17-4719-a14a-6647bba70179"],
 "\n\t\n\nwhere ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], ">", "0"}], ",", " ", "\[Theta]", ",", 
    RowBox[{"\[Gamma]", "\[Element]", "\[DoubleStruckCapitalR]"}]}], 
   TraditionalForm]],ExpressionUUID->"9212ccbe-ae65-48ea-9160-0a4c9313c372"],
 " are real constants. For the standard Gaussian random variable ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Epsilon]", "t"], TraditionalForm]],ExpressionUUID->
  "ccdb8000-dc54-4ddc-899a-72b2969d838c"],
 " , ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"E", 
     RowBox[{"\[LeftBracketingBar]", 
      SubscriptBox["\[Epsilon]", "t"], "\[RightBracketingBar]"}]}], "=", 
    SqrtBox[
     RowBox[{"2", "/", "\[Pi]"}]]}], TraditionalForm]],ExpressionUUID->
  "15d7785f-10ea-461c-bb50-d5eaa8dbd245"],
 ".\n\nFunction ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "(", ".", ")"}], TraditionalForm]],ExpressionUUID->
  "9b8b24fc-99e0-46b5-9ded-51142bf625c4"],
 " captures the asymmetric relations between stock returns and volatility. It \
is both function of magnitude and sign of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Epsilon]", "t"], TraditionalForm]],ExpressionUUID->
  "77c74513-10fd-498f-86a9-de80d74726bd"],
 ". Each component of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "(", 
    SubscriptBox["\[Epsilon]", "t"], ")"}], TraditionalForm]],ExpressionUUID->
  "0b6a30cc-f06d-4a2e-b303-9d791ce54d66"],
 " has mean zero. Thus, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "(", 
    SubscriptBox["\[Epsilon]", "t"], ")"}], TraditionalForm]],ExpressionUUID->
  "f30b6f2a-e2fd-4adb-8d59-18b55fda1e1b"],
 " is a zero mean i.i.d. random sequence.\n\nWhen ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Epsilon]", "t"], TraditionalForm]],ExpressionUUID->
  "7581f61d-f061-4ba7-b24a-f09cfd7266a9"],
 " is positive (negative) ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "(", 
    SubscriptBox["\[Epsilon]", "t"], ")"}], TraditionalForm]],ExpressionUUID->
  "48764dea-7866-4930-ab3f-7daf060f2643"],
 " is linear in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Epsilon]", "t"], TraditionalForm]],ExpressionUUID->
  "bb524820-0de5-4cd8-8074-540937cb8178"],
 " with slope \[Theta]+\[Gamma] (\[Theta]-\[Gamma]). Thus, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "(", 
    SubscriptBox["\[Epsilon]", "t"], ")"}], TraditionalForm]],ExpressionUUID->
  "18e508e6-fb75-4af5-a52d-5c228d2f0615"],
 " allows for asymmetrical response of conditional variance (",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[Sigma]", "t", "2"], TraditionalForm]],ExpressionUUID->
  "56093fcb-4e77-4fbd-b674-22e028073b09"],
 ") to positive or negative returns.\n\n\n",
 StyleBox["Example EGARCH(0,1)", "Subsection"],
 "\n\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", 
       RowBox[{
        SubscriptBox["\[Beta]", "1"], "L"}]}], ")"}], 
     RowBox[{"ln", "(", 
      SubsuperscriptBox["\[Sigma]", "t", "2"], ")"}]}], "=", 
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], "+", 
     RowBox[{"g", "(", 
      SubscriptBox["\[Epsilon]", 
       RowBox[{"t", "-", "1"}]], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "46d7832e-6141-40c3-98d2-13310ba353f4"],
 "\n\t\n"
}], "Text",
