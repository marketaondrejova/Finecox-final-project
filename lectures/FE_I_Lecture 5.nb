Cell[CellGroupData[{

Cell["Where do we need IGARCH?", "Subsubsection",
 CellChangeTimes->{{3.856947215322497*^9, 
  3.856947234591422*^9}},ExpressionUUID->"569de059-906d-45cc-bb49-\
c12ef0d1b2a6"],

Cell[TextData[{
 "IGARCH models are unit-root (integrated) GARCH models where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Alpha]", "1"], "+", 
     SubscriptBox["\[Beta]", "1"]}], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"ab2d4818-2123-4503-b198-6a562062f53b"],
 ", their key feature is, that past squared shocks are persistent. The \
unconditional variance of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "t"], TraditionalForm]],ExpressionUUID->
  "c6588527-dcff-40bc-be25-ef739f4aa826"],
 " is not defined under the IGARCH(1,1) model specification. \n\nThe IGARCH \
effect might be caused by level shifts in volatility, i.e., can be spurious, \
(for example long samples. Similar to simple AR processes.) see Mikosch and \
St\[ACup]rica\:0306 (2004).\n\nIGARCH(1,1) is defined as:\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "t"], "=", 
    RowBox[{
     SubscriptBox["\[Sigma]", "t"], 
     SubscriptBox["\[Epsilon]", "t"]}]}], TraditionalForm]],ExpressionUUID->
  "b1ad3d9d-6b4a-4313-8d83-f77f8107950f"],
 ",\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Sigma]", "t", "2"], "=", 
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], "+", 
     RowBox[{
      SubscriptBox["\[Beta]", "1"], 
      SubsuperscriptBox["\[Sigma]", 
       RowBox[{"t", "-", "1"}], "2"]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", 
        SubscriptBox["\[Beta]", "1"]}], ")"}], 
      SubsuperscriptBox["a", 
       RowBox[{"t", "-", "1"}], "2"]}]}]}], TraditionalForm]],ExpressionUUID->
  "c1aa1106-9d6c-433e-9074-60d789078d58"],
 ", \nwhere ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "<", 
    SubscriptBox["\[Beta]", "1"], "<", "1"}], TraditionalForm]],
  ExpressionUUID->"7e96dc9e-f7de-4fa3-b3af-32375e7b462a"],
 "\n\nFor ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Alpha]", "0"], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"07c48ca8-a5f9-474a-be8a-2b9b7c26dba0"],
 ", the IGARCH(1,1) \[Rule] infinite EWMA."
}], "Text",
 CellFrame->1,
 CellFrameColor->GrayLevel[1],
 CellChangeTimes->{{3.396951418072034*^9, 3.3969514642360716`*^9}, {
   3.39695162814062*^9, 3.3969517263394127`*^9}, 3.3969519621553745`*^9, {
   3.4062701884247518`*^9, 3.4062701914987516`*^9}, 3.529675639058058*^9, {
   3.530598690081621*^9, 3.53059882606418*^9}, {3.530599003265195*^9, 
   3.530599013011964*^9}, {3.530855950677732*^9, 3.5308560163932743`*^9}, {
   3.530859363509449*^9, 3.530859384494597*^9}, {3.530859414521831*^9, 
   3.5308596399039097`*^9}, {3.5308596727566423`*^9, 3.530859830180873*^9}, {
