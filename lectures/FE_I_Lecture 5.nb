Cell[TextData[{
 "\nLong memory:  ",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    RowBox[{"0", "<", " ", "d", " ", "<", " ", "\.bd"}]}], TraditionalForm]],
  ExpressionUUID->"278a3c4c-6486-4bf9-af9d-82c040785c12"],
 "\n\nProblems with long-memory detection: only the rate of convergence is \
defined, not the absolute size. \n\n",
 StyleBox["Example: ACF plot with white-noise confidence bands", "Subsection"]
}], "Text",
