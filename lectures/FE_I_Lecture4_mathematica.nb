Cell[CellGroupData[{

Cell["Examples of ARCH(1) artificial processes", "Subsection",
 CellChangeTimes->{{3.396546393955388*^9, 3.3965463976719475`*^9}, {
   3.396636144215088*^9, 3.3966361498660927`*^9}, 
   3.396775570023816*^9},ExpressionUUID->"57bce4d0-ca06-437f-afef-\
3e340ab7e6b9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"SeedRandom", "[", "seed", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"earch", "=", 
      RowBox[{"RandomReal", "[", 
       RowBox[{
        RowBox[{"NormalDistribution", "[", 
         RowBox[{"0", ",", "1"}], "]"}], ",", "500"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"arch", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"1", ",", 
        RowBox[{"{", "500", "}"}]}], "]"}]}], ";", 
     RowBox[{"archa", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"1", ",", 
        RowBox[{"{", "500", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"arch", "[", 
       RowBox[{"[", "1", "]"}], "]"}], "=", 
      RowBox[{"Variance", "[", "earch", "]"}]}], ";", 
     RowBox[{
      RowBox[{"archa", "[", 
       RowBox[{"[", "1", "]"}], "]"}], "=", 
      RowBox[{
       RowBox[{"Sqrt", "[", 
        RowBox[{"arch", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "]"}], " ", 
       RowBox[{"earch", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"arch", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "=", 
         RowBox[{"paramp0", "+", 
          RowBox[{"paramp1", " ", 
           RowBox[{
            RowBox[{"archa", "[", 
             RowBox[{"[", 
              RowBox[{"i", "-", "1"}], "]"}], "]"}], "^", "2"}]}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"archa", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "=", 
         RowBox[{
          RowBox[{"Sqrt", "[", 
           RowBox[{"arch", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "]"}], " ", 
          RowBox[{"earch", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
       ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "2", ",", 
         RowBox[{"Length", "[", "earch", "]"}]}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"acfarch", "=", 
      RowBox[{"CorrelationFunction", "[", 
       RowBox[{
        RowBox[{"arch", "^", "2"}], ",", 
        RowBox[{"{", "30", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"stdevarch", "=", 
      RowBox[{"2", "/", 
       RowBox[{"Sqrt", "[", "500", "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"pacfarch", "=", 
      RowBox[{"PartialCorrelationFunction", "[", 
       RowBox[{
        RowBox[{"arch", "^", "2"}], ",", 
        RowBox[{"{", "30", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"ListPlot", "[", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"type", "===", "\"\<Sample ARCH(1)\>\""}], ",", "archa", ",",
          "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"type", "===", "\"\<ARCH(1) volatility\>\""}], ",", "arch",
            ",", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
             "type", "===", 
              "\"\<ACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \
\(2\)]\)\>\""}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"Table", "[", 
                RowBox[{
                 RowBox[{"z", "=", "stdevarch"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"z", ",", "0", ",", "30"}], "}"}]}], "]"}], ",", 
               RowBox[{"Table", "[", 
                RowBox[{
                 RowBox[{"z", "=", 
                  RowBox[{"-", "stdevarch"}]}], ",", 
                 RowBox[{"{", 
                  RowBox[{"z", ",", "0", ",", "30"}], "}"}]}], "]"}], ",", 
               "acfarch"}], "}"}], ",", "\[IndentingNewLine]", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"Table", "[", 
                RowBox[{
                 RowBox[{"z", "=", "stdevarch"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"z", ",", "0", ",", "30"}], "}"}]}], "]"}], ",", 
               RowBox[{"Table", "[", 
                RowBox[{
                 RowBox[{"z", "=", 
                  RowBox[{"-", "stdevarch"}]}], ",", 
                 RowBox[{"{", 
                  RowBox[{"z", ",", "0", ",", "30"}], "}"}]}], "]"}], ",", 
               "pacfarch"}], "}"}]}], "]"}]}], "]"}]}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Joined", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"True", ",", "True", ",", "False"}], "}"}]}], ",", 
       RowBox[{"Frame", "\[Rule]", "True"}], ",", 
       RowBox[{"Filling", "\[Rule]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"type", "=!=", "\"\<Sample ARCH(1)\>\""}], ",", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"type", "=!=", "\"\<ARCH(1) volatility\>\""}], ",", 
            RowBox[{"{", 
             RowBox[{"3", "\[Rule]", " ", "Axis"}], "}"}], ",", "None"}], 
           "]"}], ",", "None"}], "]"}]}], ",", 
       RowBox[{"FillingStyle", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"3", "\[Rule]", "Black"}], "}"}]}], ",", 
       RowBox[{"PlotStyle", "\[Rule]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"type", "=!=", "\"\<Sample ARCH(1)\>\""}], ",", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"type", "=!=", "\"\<ARCH(1) volatility\>\""}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"Dashing", "[", "Large", "]"}], ",", " ", 
                RowBox[{"Thickness", "[", "Medium", "]"}], ",", " ", "Red"}], 
               "}"}], ",", " ", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"Dashing", "[", "Large", "]"}], ",", " ", 
                RowBox[{"Thickness", "[", "Medium", "]"}], ",", " ", "Red"}], 
               "}"}], ",", " ", "Black"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Thickness", "[", "Medium", "]"}], ",", " ", "Red"}], 
             "}"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Thickness", "[", "Medium", "]"}], ",", " ", "Red"}], 
           "}"}]}], "]"}]}], "\[IndentingNewLine]", ",", 
       RowBox[{"PlotRange", "\[Rule]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"type", "===", "\"\<Sample ARCH(1)\>\""}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "10"}], ",", "10"}], "}"}], ",", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"type", "===", "\"\<ARCH(1) volatility\>\""}], ",", "All",
             ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "0.5"}], ",", "0.5"}], "}"}]}], "]"}]}], "]"}]}]}],
       "]"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"type", ",", "\"\<Sample ARCH(1)\>\"", ",", "\"\<\>\""}], 
       "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\"\<Sample ARCH(1)\>\"", ",", "\"\<ARCH(1) volatility\>\""}], 
       "}"}]}], "}"}], ",", "Delimiter", ",", "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"type", ",", "\"\<Sample ARCH(1)\>\"", ",", "\"\<\>\""}], 
       "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
       "\"\<ACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \
\(2\)]\)\>\"", ",", 
        "\"\<PACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \
\(2\)]\)\>\""}], "}"}]}], "}"}], ",", "Delimiter", ",", "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "paramp0", ",", "0.5", ",", 
        "\"\<\!\(\*SubscriptBox[\(\[Alpha]\), \(0\)]\)\>\""}], "}"}], ",", 
      "0.1", ",", "2", ",", 
      RowBox[{"Appearance", "\[Rule]", "\"\<Labeled\>\""}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "paramp1", ",", "0.5", ",", 
        "\"\<\!\(\*SubscriptBox[\(\[Alpha]\), \(1\)]\)\>\""}], "}"}], ",", 
      "0", ",", "1", ",", 
      RowBox[{"Appearance", "\[Rule]", "\"\<Labeled\>\""}]}], "}"}], ",", 
    "Delimiter", ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"seed", ",", "77777", ",", "\"\<New Random Case\>\""}], "}"}], 
      ",", "10000", ",", "999999", ",", "1"}], "}"}]}], "]"}], 
  "\[IndentingNewLine]"}]], "Input",
