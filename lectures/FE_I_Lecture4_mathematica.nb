Cell[BoxData[
 TagBox[
  StyleBox[
   DynamicModuleBox[{$CellContext`paramp0$$ = 0.1, $CellContext`paramp1$$ = 
    0.92, $CellContext`seed$$ = 89814, $CellContext`type$$ = 
    "ARCH(1) volatility", Typeset`show$$ = True, Typeset`bookmarkList$$ = {}, 
    Typeset`bookmarkMode$$ = "Menu", Typeset`animator$$, Typeset`animvar$$ = 
    1, Typeset`name$$ = "\"untitled\"", Typeset`specs$$ = {{{
       Hold[$CellContext`type$$], "Sample ARCH(1)", ""}, {
      "Sample ARCH(1)", "ARCH(1) volatility"}}, {{
       Hold[$CellContext`type$$], "Sample ARCH(1)", ""}, {
      "ACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\)]\)", 
       "PACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\)]\)"}}, {{
       Hold[$CellContext`paramp0$$], 0.5, 
       "\!\(\*SubscriptBox[\(\[Alpha]\), \(0\)]\)"}, 0.1, 2}, {{
       Hold[$CellContext`paramp1$$], 0.5, 
       "\!\(\*SubscriptBox[\(\[Alpha]\), \(1\)]\)"}, 0, 1}, {{
       Hold[$CellContext`seed$$], 77777, "New Random Case"}, 10000, 999999, 
      1}}, Typeset`size$$ = {720., {226., 237.}}, Typeset`update$$ = 0, 
    Typeset`initDone$$, Typeset`skipInitDone$$ = 
    True, $CellContext`type$78167$$ = False, $CellContext`paramp0$78168$$ = 
    0, $CellContext`paramp1$78169$$ = 0, $CellContext`seed$78170$$ = 0}, 
    DynamicBox[Manipulate`ManipulateBoxes[
     1, StandardForm, 
      "Variables" :> {$CellContext`paramp0$$ = 0.5, $CellContext`paramp1$$ = 
        0.5, $CellContext`seed$$ = 77777, $CellContext`type$$ = 
        "Sample ARCH(1)"}, "ControllerVariables" :> {
        Hold[$CellContext`type$$, $CellContext`type$78167$$, False], 
        Hold[$CellContext`paramp0$$, $CellContext`paramp0$78168$$, 0], 
        Hold[$CellContext`paramp1$$, $CellContext`paramp1$78169$$, 0], 
        Hold[$CellContext`seed$$, $CellContext`seed$78170$$, 0]}, 
      "OtherVariables" :> {
       Typeset`show$$, Typeset`bookmarkList$$, Typeset`bookmarkMode$$, 
        Typeset`animator$$, Typeset`animvar$$, Typeset`name$$, 
        Typeset`specs$$, Typeset`size$$, Typeset`update$$, Typeset`initDone$$,
         Typeset`skipInitDone$$}, 
      "Body" :> (
       SeedRandom[$CellContext`seed$$]; $CellContext`earch = RandomReal[
          NormalDistribution[0, 1], 500]; $CellContext`arch = 
        Table[1, {500}]; $CellContext`archa = Table[1, {500}]; 
       Part[$CellContext`arch, 1] = Variance[$CellContext`earch]; 
       Part[$CellContext`archa, 1] = Sqrt[
           Part[$CellContext`arch, 1]] Part[$CellContext`earch, 1]; 
       Do[Part[$CellContext`arch, $CellContext`i] = $CellContext`paramp0$$ + \
$CellContext`paramp1$$ Part[$CellContext`archa, $CellContext`i - 1]^2; 
         Part[$CellContext`archa, $CellContext`i] = Sqrt[
             Part[$CellContext`arch, $CellContext`i]] 
           Part[$CellContext`earch, $CellContext`i]; Null, {$CellContext`i, 2, 
          Length[$CellContext`earch]}]; $CellContext`acfarch = 
        CorrelationFunction[$CellContext`arch^2, {
          30}]; $CellContext`stdevarch = 2/Sqrt[500]; $CellContext`pacfarch = 
        PartialCorrelationFunction[$CellContext`arch^2, {30}]; ListPlot[
         If[$CellContext`type$$ === "Sample ARCH(1)", $CellContext`archa, 
          If[$CellContext`type$$ === "ARCH(1) volatility", $CellContext`arch, 
           
           If[$CellContext`type$$ === 
            "ACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\)]\)", {
             
             Table[$CellContext`z = $CellContext`stdevarch, {$CellContext`z, 
               0, 30}], 
             
             Table[$CellContext`z = -$CellContext`stdevarch, {$CellContext`z, 
               0, 30}], $CellContext`acfarch}, {
             
             Table[$CellContext`z = $CellContext`stdevarch, {$CellContext`z, 
               0, 30}], 
             
             Table[$CellContext`z = -$CellContext`stdevarch, {$CellContext`z, 
               0, 30}], $CellContext`pacfarch}]]], 
         Joined -> {True, True, False}, Frame -> True, Filling -> 
         If[$CellContext`type$$ =!= "Sample ARCH(1)", 
           
           If[$CellContext`type$$ =!= "ARCH(1) volatility", {3 -> Axis}, 
            None], None], FillingStyle -> {3 -> Black}, PlotStyle -> 
         If[$CellContext`type$$ =!= "Sample ARCH(1)", 
           If[$CellContext`type$$ =!= "ARCH(1) volatility", {{
              Dashing[Large], 
              Thickness[Medium], Red}, {
              Dashing[Large], 
              Thickness[Medium], Red}, Black}, {
             Thickness[Medium], Red}], {
            Thickness[Medium], Red}], PlotRange -> 
         If[$CellContext`type$$ === "Sample ARCH(1)", {-10, 10}, 
           
           If[$CellContext`type$$ === "ARCH(1) volatility", All, {-0.5, 
            0.5}]]]), 
      "Specifications" :> {{{$CellContext`type$$, "Sample ARCH(1)", ""}, {
         "Sample ARCH(1)", "ARCH(1) volatility"}}, 
        Delimiter, {{$CellContext`type$$, "Sample ARCH(1)", ""}, {
         "ACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\)]\)", 
          "PACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\)]\)"}},
         Delimiter, {{$CellContext`paramp0$$, 0.5, 
          "\!\(\*SubscriptBox[\(\[Alpha]\), \(0\)]\)"}, 0.1, 2, Appearance -> 
         "Labeled"}, {{$CellContext`paramp1$$, 0.5, 
          "\!\(\*SubscriptBox[\(\[Alpha]\), \(1\)]\)"}, 0, 1, Appearance -> 
         "Labeled"}, 
        Delimiter, {{$CellContext`seed$$, 77777, "New Random Case"}, 10000, 
         999999, 1}}, "Options" :> {}, "DefaultOptions" :> {}],
     ImageSizeCache->{804., {429., 440.}},
     SingleEvaluation->True],
