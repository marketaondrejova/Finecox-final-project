Cell[CellGroupData[{

Cell["GARCH(\[ScriptM],\[ScriptS])", "Section",
 CellChangeTimes->{{3.396681927050598*^9, 3.3966819497718005`*^9}, 
   3.3967113474742117`*^9, 
   3.91904932402645*^9},ExpressionUUID->"7c3d1800-0191-4215-bdba-\
13256eee2326"],

Cell[TextData[{
 "As ARCH model requires many parameters to adequately describe volatility \
process of returns, extension is used - Generalized autoregressive \
conditional heteroscedasticity (GARCH) model. It is assumed, that mean \
equation is adequately described by ARMA, letting ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "t"], "=", 
    RowBox[{
     SubscriptBox["r", "t"], "-", 
     SubscriptBox["\[Mu]", "t"]}]}], TraditionalForm]],ExpressionUUID->
  "cb278434-a927-45fb-9613-614961cae904"],
 " be the mean-corrected log return, GARCH(\[ScriptM],\[ScriptS]) model is \
described by following equation:\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "t"], "=", 
    RowBox[{
     SubscriptBox["\[Sigma]", "t"], 
     SubscriptBox["\[Epsilon]", "t"]}]}], TraditionalForm]],ExpressionUUID->
  "c199382c-ad35-4644-be40-e6d090eb61df"],
 ",\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Sigma]", "t", "2"], "=", 
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], "+", 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"i", "=", "1"}], "m"], 
      RowBox[{
       SubscriptBox["\[Alpha]", "i"], 
       SubsuperscriptBox["a", 
        RowBox[{"t", "-", "i"}], "2"]}]}], "+", 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"j", "=", "1"}], "s"], 
      RowBox[{
       SubscriptBox["\[Beta]", "j"], 
       SubsuperscriptBox["\[Sigma]", 
        RowBox[{"t", "-", "j"}], "2"]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"b032fe25-f808-447f-8199-b6eb89b338b6"],
 ", \n\nwhere {",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Epsilon]", "t"], "}"}], TraditionalForm]],ExpressionUUID->
  "8600c1a2-292f-40d0-9dda-e6169d1d182a"],
 " is i.i.d random variables with zero mean and variance 1,  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], ">", "0"}], ",", " ", 
    RowBox[{
     SubscriptBox["\[Alpha]", "i"], "\[GreaterEqual]", "0"}]}], 
   TraditionalForm]],ExpressionUUID->"1d305369-a765-41ec-91dc-62f86e6afb02"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Beta]", "j"], "\[GreaterEqual]", "0"}], TraditionalForm]],
  ExpressionUUID->"c6277721-44d5-4079-bb29-872a610070e9"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"i", "=", "1"}], 
      RowBox[{"max", "(", 
       RowBox[{"m", ",", "s"}], ")"}]], 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["\[Alpha]", "i"], "+", 
       SubscriptBox["\[Beta]", "i"]}], ")"}]}], "<", "1"}], TraditionalForm]],
  ExpressionUUID->"ddbadd3a-733f-4f9b-92e6-12b5c32b15ca"],
 ", so unconditional variance of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "t"], TraditionalForm]],ExpressionUUID->
  "d02dbf9c-83db-4520-8d5f-f4f61bb72b9f"],
 " is finite, whereas its conditional variance ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[Sigma]", "t", "2"], TraditionalForm]],ExpressionUUID->
  "7704c265-1095-4f78-b553-65cdeaa00168"],
 " evolves over time.\nNote, that GARCH model reduces to a pure ARCH(\
\[ScriptM]) model for \[ScriptS] = 0. "
}], "Text",
 CellChangeTimes->{{3.396546380531443*^9, 3.396546380906419*^9}, {
   3.396681779650853*^9, 3.3966818106059027`*^9}, {3.3966818422474327`*^9, 
   3.3966818744533787`*^9}, {3.396681980273754*^9, 3.3966822738897276`*^9}, {
   3.3966823043340683`*^9, 3.3966823057177687`*^9}, {3.396686428665797*^9, 
   3.3966865157940097`*^9}, 
   3.561191890349122*^9},ExpressionUUID->"73b99dd8-90ca-4eac-aa6f-\
3b3dd5d5f597"],

Cell[CellGroupData[{

Cell["Example  GARCH(m,s) artificial processes", "Subsection",
 CellChangeTimes->{{3.396546393955388*^9, 3.3965463976719475`*^9}, {
   3.3966897834559593`*^9, 3.3966897935021915`*^9}, {3.396706036866846*^9, 
   3.396706037818934*^9}, 3.396775574464938*^9, {3.397218671251992*^9, 
   3.3972186733534203`*^9}},ExpressionUUID->"17163684-12e7-4ad7-9ef2-\
943504485adc"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"SeedRandom", "[", "seed", "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"egarchm", "=", 
     RowBox[{"RandomReal", "[", 
      RowBox[{
       RowBox[{"NormalDistribution", "[", 
        RowBox[{"0", ",", "1"}], "]"}], ",", "500"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"garchm", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Variance", "[", "egarchm", "]"}], ",", 
       RowBox[{"{", "500", "}"}]}], "]"}]}], ";", 
    RowBox[{"garchma", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Sqrt", "[", 
         RowBox[{"garchm", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "]"}], "  ", 
        RowBox[{"egarchm", "[", 
         RowBox[{"[", "i", "]"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "500"}], "}"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"m", "=", 
     RowBox[{"Length", "[", "paramgm1", "]"}]}], ";", 
    RowBox[{"s", "=", 
     RowBox[{"Length", "[", "paramgm2", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"garchm", "[", 
      RowBox[{"[", "s", "]"}], "]"}], "=", 
     RowBox[{"Variance", "[", "egarchm", "]"}]}], ";", 
    RowBox[{
     RowBox[{"garchma", "[", 
      RowBox[{"[", "s", "]"}], "]"}], "=", 
     RowBox[{
      RowBox[{"Sqrt", "[", 
       RowBox[{"garchm", "[", 
        RowBox[{"[", "s", "]"}], "]"}], "]"}], " ", 
      RowBox[{"egarchm", "[", 
       RowBox[{"[", 
        RowBox[{"s", "-", "1"}], "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"garchm", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "=", 
        RowBox[{
         RowBox[{"paramgm1", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "+", 
         RowBox[{
          UnderoverscriptBox["\[Sum]", 
           RowBox[{"g", "=", "2"}], "m"], 
          RowBox[{
           RowBox[{"paramgm1", "[", 
            RowBox[{"[", "g", "]"}], "]"}], " ", 
           RowBox[{
            RowBox[{"garchma", "[", 
             RowBox[{"[", 
              RowBox[{"i", "+", "1", "-", "g"}], "]"}], "]"}], "^", "2"}]}]}],
          "+", 
         RowBox[{
          UnderoverscriptBox["\[Sum]", 
           RowBox[{"f", "=", "1"}], "s"], 
          RowBox[{
           RowBox[{"paramgm2", "[", 
            RowBox[{"[", "f", "]"}], "]"}], " ", 
           RowBox[{"garchm", "[", 
            RowBox[{"[", 
             RowBox[{"i", "-", "f"}], "]"}], "]"}]}]}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"garchma", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "=", 
        RowBox[{
         RowBox[{"Sqrt", "[", 
          RowBox[{"garchm", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "]"}], " ", 
         RowBox[{"egarchm", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
      ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", 
        RowBox[{"s", "+", "1"}], ",", 
        RowBox[{"Length", "[", "egarchm", "]"}]}], "}"}]}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"acfgarchm", "=", 
     RowBox[{"CorrelationFunction", "[", 
      RowBox[{
       RowBox[{"garchma", "^", "2"}], ",", 
       RowBox[{"{", "30", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"stdevgarchm", "=", 
     RowBox[{"2", "/", 
      RowBox[{"Sqrt", "[", "500", "]"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"pacfgarchm", "=", 
     RowBox[{"PartialCorrelationFunction", "[", 
      RowBox[{
       RowBox[{"garchma", "^", "2"}], ",", 
       RowBox[{"{", "30", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           UnderoverscriptBox["\[Sum]", 
            RowBox[{"c", "=", "1"}], "m"], 
           RowBox[{"paramgm1", "[", 
            RowBox[{"[", "c", "]"}], "]"}]}], "+", 
          RowBox[{
           UnderoverscriptBox["\[Sum]", 
            RowBox[{"d", "=", "1"}], "s"], 
           RowBox[{"paramgm2", "[", 
            RowBox[{"[", "d", "]"}], "]"}]}]}], ")"}], "<", "1"}], "===", 
       "True"}], ",", "\[IndentingNewLine]", 
      RowBox[{"ListPlot", "[", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"type", "===", "\"\<Sample GARCH(m,s)\>\""}], ",", 
          "garchma", ",", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"type", "===", "\"\<GARCH(m,s) volatility\>\""}], ",", 
            RowBox[{"Sqrt", "[", "garchm", "]"}], ",", "\[IndentingNewLine]", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
              "type", "===", 
               "\"\<ACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\
\)]\)\>\""}], ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"Table", "[", 
                 RowBox[{
                  RowBox[{"z", "=", "stdevgarchm"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"z", ",", "0", ",", "30"}], "}"}]}], "]"}], ",", 
                RowBox[{"Table", "[", 
                 RowBox[{
                  RowBox[{"z", "=", 
                   RowBox[{"-", "stdevgarchm"}]}], ",", 
                  RowBox[{"{", 
                   RowBox[{"z", ",", "0", ",", "30"}], "}"}]}], "]"}], ",", 
                "acfgarchm"}], "}"}], ",", "\[IndentingNewLine]", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"Table", "[", 
                 RowBox[{
                  RowBox[{"z", "=", "stdevgarchm"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"z", ",", "0", ",", "30"}], "}"}]}], "]"}], ",", 
                RowBox[{"Table", "[", 
                 RowBox[{
                  RowBox[{"z", "=", 
                   RowBox[{"-", "stdevgarchm"}]}], ",", 
                  RowBox[{"{", 
                   RowBox[{"z", ",", "0", ",", "30"}], "}"}]}], "]"}], ",", 
                "pacfgarchm"}], "}"}]}], "]"}]}], "]"}]}], "]"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"Joined", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"True", ",", "True", ",", "False"}], "}"}]}], ",", 
        RowBox[{"Frame", "\[Rule]", "True"}], ",", 
        RowBox[{"Filling", "\[Rule]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"type", "=!=", "\"\<Sample GARCH(m,s)\>\""}], ",", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"type", "=!=", "\"\<GARCH(m,s) volatility\>\""}], ",", 
             RowBox[{"{", 
              RowBox[{"3", "\[Rule]", " ", "Axis"}], "}"}], ",", "None"}], 
            "]"}], ",", "None"}], "]"}]}], ",", 
        RowBox[{"FillingStyle", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"3", "\[Rule]", "Black"}], "}"}]}], ",", 
        RowBox[{"PlotStyle", "\[Rule]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"type", "=!=", "\"\<Sample GARCH(m,s)\>\""}], ",", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"type", "=!=", "\"\<GARCH(m,s) volatility\>\""}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"Dashing", "[", "Large", "]"}], ",", " ", 
                 RowBox[{"Thickness", "[", "Medium", "]"}], ",", " ", "Red"}],
                 "}"}], ",", " ", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"Dashing", "[", "Large", "]"}], ",", " ", 
                 RowBox[{"Thickness", "[", "Medium", "]"}], ",", " ", "Red"}],
                 "}"}], ",", " ", "Black"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"Thickness", "[", "Medium", "]"}], ",", " ", "Red"}], 
              "}"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Thickness", "[", "Medium", "]"}], ",", " ", "Red"}], 
            "}"}]}], "]"}]}], ",", 
        RowBox[{"PlotRange", "\[Rule]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"type", "===", "\"\<Sample GARCH(m,s)\>\""}], ",", "All", 
           ",", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"type", "===", "\"\<GARCH(m,s) volatility\>\""}], ",", 
             "All", ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", "0.5"}], ",", "0.5"}], "}"}]}], "]"}]}], 
          "]"}]}]}], "]"}], ",", "\[IndentingNewLine]", 
      RowBox[{"Style", "[", 
       RowBox[{
       "\"\<Please input \!\(\*UnderoverscriptBox[\(\[Sum]\), \(i = 1\), \
\(Max[m, s]\)]\)(\!\(\*SubscriptBox[\(\[Alpha]\), \
\(i\)]\)+\!\(\*SubscriptBox[\(\[Beta]\), \(i\)]\))<1\>\"", ",", "Bold", ",", 
        "12"}], "]"}]}], "]"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"type", ",", "\"\<Sample GARCH(m,s)\>\"", ",", "\"\<\>\""}], 
      "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
      "\"\<Sample GARCH(m,s)\>\"", ",", "\"\<GARCH(m,s) volatility\>\""}], 
      "}"}]}], "}"}], ",", "Delimiter", ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"type", ",", "\"\<Sample GARCH(m,s)\>\"", ",", "\"\<\>\""}], 
      "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
      "\"\<ACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \
\(2\)]\)\>\"", ",", 
       "\"\<PACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\)]\)\>\
\""}], "}"}]}], "}"}], ",", "Delimiter", ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"paramgm1", ",", 
       RowBox[{"{", 
        RowBox[{"0.1", ",", "0.2", ",", "0.3"}], "}"}], ",", 
       "\"\<\!\(\*SubscriptBox[\(\[Alpha]\), \(m\)]\)\>\""}], "}"}], ",", 
     RowBox[{"ControlType", "\[Rule]", "InputField"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"paramgm2", ",", 
       RowBox[{"{", 
        RowBox[{"0.05", ",", "0.2"}], "}"}], ",", 
       "\"\<\!\(\*SubscriptBox[\(\[Beta]\), \(s\)]\)\>\""}], "}"}], ",", 
     RowBox[{"ControlType", "\[Rule]", "InputField"}]}], "}"}], ",", 
   "Delimiter", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"seed", ",", "77777", ",", "\"\<New Random Case\>\""}], "}"}], 
     ",", "10000", ",", "999999", ",", "1"}], "}"}], ",", 
   RowBox[{"Button", "[", 
    RowBox[{"\"\<Export Simulated Series\>\"", ",", 
     RowBox[{"Export", "[", 
      RowBox[{"\"\<garch.txt\>\"", ",", "garchm"}], "]"}], ",", 
     RowBox[{"ImageSize", "\[Rule]", "200"}]}], "]"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.3972187010791845`*^9, 3.3972187852847323`*^9}, {
   3.397218956031616*^9, 3.3972189644470935`*^9}, {3.3972190133316603`*^9, 
   3.397219038105465*^9}, {3.397219388267624*^9, 3.397219457690914*^9}, {
   3.397219528048716*^9, 3.3972195355941315`*^9}, {3.397219919812704*^9, 
   3.397219928423481*^9}, {3.397219977266058*^9, 3.397220001439316*^9}, {
   3.3972200746650977`*^9, 3.3972201798028994`*^9}, {3.3972202157029457`*^9, 
   3.397220298917346*^9}, {3.3972205355525913`*^9, 3.397220554856043*^9}, {
   3.3972205874272003`*^9, 3.397220596070202*^9}, {3.397221460006118*^9, 
   3.397221469037766*^9}, {3.3972215080518703`*^9, 3.3972215351790404`*^9}, {
   3.397221645372183*^9, 3.39722172616584*^9}, {3.3972219698426266`*^9, 
   3.3972219701961193`*^9}, {3.3972256176316137`*^9, 
   3.3972256177605124`*^9}, {3.3972256813082027`*^9, 
   3.3972257736538544`*^9}, {3.3972258193452663`*^9, 
   3.3972258804858837`*^9}, {3.3972260072697616`*^9, 3.3972260424667273`*^9}, 
   3.397226234193714*^9, {3.397226277767097*^9, 3.3972263502458563`*^9}, {
   3.3972263848842645`*^9, 3.3972263877942343`*^9}, {3.46495410730404*^9, 
   3.464954130419981*^9}, {3.464954331857703*^9, 3.464954332067678*^9}, 
   3.464959643421741*^9, {3.5930618678115597`*^9, 3.593061881623124*^9}, {
   3.593072067168084*^9, 3.593072134825755*^9}, {3.623661243154952*^9, 
   3.623661243714149*^9}},ExpressionUUID->"9086cca1-2a99-42da-bb74-\
8d551c61ae65"],

Cell[BoxData[
 TagBox[
  StyleBox[
   DynamicModuleBox[{$CellContext`paramgm1$$ = {0.1, 0.2, 
    0.3}, $CellContext`paramgm2$$ = {0.05, 0.2}, $CellContext`seed$$ = 
    137140, $CellContext`type$$ = "Sample GARCH(m,s)", Typeset`show$$ = True, 
    Typeset`bookmarkList$$ = {}, Typeset`bookmarkMode$$ = "Menu", 
    Typeset`animator$$, Typeset`animvar$$ = 1, Typeset`name$$ = 
    "\"untitled\"", Typeset`specs$$ = {{{
       Hold[$CellContext`type$$], "Sample GARCH(m,s)", ""}, {
      "Sample GARCH(m,s)", "GARCH(m,s) volatility"}}, {{
       Hold[$CellContext`type$$], "Sample GARCH(m,s)", ""}, {
      "ACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\)]\)", 
       "PACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\)]\)"}}, {{
       Hold[$CellContext`paramgm1$$], {0.1, 0.2, 0.3}, 
       "\!\(\*SubscriptBox[\(\[Alpha]\), \(m\)]\)"}}, {{
       Hold[$CellContext`paramgm2$$], {0.05, 0.2}, 
       "\!\(\*SubscriptBox[\(\[Beta]\), \(s\)]\)"}}, {{
       Hold[$CellContext`seed$$], 77777, "New Random Case"}, 10000, 999999, 
      1}, {
      Hold[
       Button["Export Simulated Series", 
        Export["garch.txt", $CellContext`garchm], ImageSize -> 200]], 
      Manipulate`Dump`ThisIsNotAControl}}, Typeset`size$$ = {
    1080., {333., 350.}}, Typeset`update$$ = 0, Typeset`initDone$$, 
    Typeset`skipInitDone$$ = True, $CellContext`type$153620$$ = 
    False, $CellContext`seed$153621$$ = 0}, 
    DynamicBox[Manipulate`ManipulateBoxes[
     1, StandardForm, 
      "Variables" :> {$CellContext`paramgm1$$ = {0.1, 0.2, 
         0.3}, $CellContext`paramgm2$$ = {0.05, 0.2}, $CellContext`seed$$ = 
        77777, $CellContext`type$$ = "Sample GARCH(m,s)"}, 
      "ControllerVariables" :> {
        Hold[$CellContext`type$$, $CellContext`type$153620$$, False], 
        Hold[$CellContext`seed$$, $CellContext`seed$153621$$, 0]}, 
      "OtherVariables" :> {
       Typeset`show$$, Typeset`bookmarkList$$, Typeset`bookmarkMode$$, 
        Typeset`animator$$, Typeset`animvar$$, Typeset`name$$, 
        Typeset`specs$$, Typeset`size$$, Typeset`update$$, Typeset`initDone$$,
         Typeset`skipInitDone$$}, 
      "Body" :> (
       SeedRandom[$CellContext`seed$$]; $CellContext`egarchm = RandomReal[
          NormalDistribution[0, 1], 500]; $CellContext`garchm = Table[
          Variance[$CellContext`egarchm], {500}]; $CellContext`garchma = 
        Table[Sqrt[
            Part[$CellContext`garchm, $CellContext`i]] 
          Part[$CellContext`egarchm, $CellContext`i], {$CellContext`i, 
           500}]; $CellContext`m = 
        Length[$CellContext`paramgm1$$]; $CellContext`s = 
        Length[$CellContext`paramgm2$$]; 
       Part[$CellContext`garchm, $CellContext`s] = 
        Variance[$CellContext`egarchm]; 
       Part[$CellContext`garchma, $CellContext`s] = Sqrt[
           Part[$CellContext`garchm, $CellContext`s]] 
         Part[$CellContext`egarchm, $CellContext`s - 1]; 
       Do[Part[$CellContext`garchm, $CellContext`i] = 
          Part[$CellContext`paramgm1$$, 1] + 
           Sum[Part[$CellContext`paramgm1$$, $CellContext`g] 
             Part[$CellContext`garchma, $CellContext`i + 
                1 - $CellContext`g]^2, {$CellContext`g, 2, $CellContext`m}] + 
           Sum[Part[$CellContext`paramgm2$$, $CellContext`f] 
             Part[$CellContext`garchm, $CellContext`i - $CellContext`f], \
{$CellContext`f, 1, $CellContext`s}]; 
         Part[$CellContext`garchma, $CellContext`i] = Sqrt[
             Part[$CellContext`garchm, $CellContext`i]] 
           Part[$CellContext`egarchm, $CellContext`i]; 
         Null, {$CellContext`i, $CellContext`s + 1, 
          Length[$CellContext`egarchm]}]; $CellContext`acfgarchm = 
        CorrelationFunction[$CellContext`garchma^2, {
          30}]; $CellContext`stdevgarchm = 
        2/Sqrt[500]; $CellContext`pacfgarchm = 
        PartialCorrelationFunction[$CellContext`garchma^2, {30}]; If[Sum[
             
             Part[$CellContext`paramgm1$$, $CellContext`c], {$CellContext`c, 
              1, $CellContext`m}] + Sum[
             
             Part[$CellContext`paramgm2$$, $CellContext`d], {$CellContext`d, 
              1, $CellContext`s}] < 1 === True, 
         ListPlot[
          If[$CellContext`type$$ === 
           "Sample GARCH(m,s)", $CellContext`garchma, 
           If[$CellContext`type$$ === "GARCH(m,s) volatility", 
            Sqrt[$CellContext`garchm], 
            
            If[$CellContext`type$$ === 
             "ACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \
\(2\)]\)", {
              
              Table[$CellContext`z = $CellContext`stdevgarchm, \
{$CellContext`z, 0, 30}], 
              
              Table[$CellContext`z = -$CellContext`stdevgarchm, \
{$CellContext`z, 0, 30}], $CellContext`acfgarchm}, {
              
              Table[$CellContext`z = $CellContext`stdevgarchm, \
{$CellContext`z, 0, 30}], 
              
              Table[$CellContext`z = -$CellContext`stdevgarchm, \
{$CellContext`z, 0, 30}], $CellContext`pacfgarchm}]]], 
          Joined -> {True, True, False}, Frame -> True, Filling -> 
          If[$CellContext`type$$ =!= "Sample GARCH(m,s)", 
            
            If[$CellContext`type$$ =!= "GARCH(m,s) volatility", {3 -> Axis}, 
             None], None], FillingStyle -> {3 -> Black}, PlotStyle -> 
          If[$CellContext`type$$ =!= "Sample GARCH(m,s)", 
            If[$CellContext`type$$ =!= "GARCH(m,s) volatility", {{
               Dashing[Large], 
               Thickness[Medium], Red}, {
               Dashing[Large], 
               Thickness[Medium], Red}, Black}, {
              Thickness[Medium], Red}], {
             Thickness[Medium], Red}], PlotRange -> 
          If[$CellContext`type$$ === "Sample GARCH(m,s)", All, 
            
            If[$CellContext`type$$ === "GARCH(m,s) volatility", All, {-0.5, 
             0.5}]]], 
         Style[
         "Please input \!\(\*UnderoverscriptBox[\(\[Sum]\), \(i = 1\), \
\(Max[m, s]\)]\)(\!\(\*SubscriptBox[\(\[Alpha]\), \
\(i\)]\)+\!\(\*SubscriptBox[\(\[Beta]\), \(i\)]\))<1", Bold, 12]]), 
      "Specifications" :> {{{$CellContext`type$$, "Sample GARCH(m,s)", ""}, {
         "Sample GARCH(m,s)", "GARCH(m,s) volatility"}}, 
        Delimiter, {{$CellContext`type$$, "Sample GARCH(m,s)", ""}, {
         "ACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\)]\)", 
          "PACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\)]\)"}},
         Delimiter, {{$CellContext`paramgm1$$, {0.1, 0.2, 0.3}, 
          "\!\(\*SubscriptBox[\(\[Alpha]\), \(m\)]\)"}, ControlType -> 
         InputField}, {{$CellContext`paramgm2$$, {0.05, 0.2}, 
          "\!\(\*SubscriptBox[\(\[Beta]\), \(s\)]\)"}, ControlType -> 
         InputField}, 
        Delimiter, {{$CellContext`seed$$, 77777, "New Random Case"}, 10000, 
         999999, 1}, 
        Button["Export Simulated Series", 
         Export["garch.txt", $CellContext`garchm], ImageSize -> 200]}, 
      "Options" :> {}, "DefaultOptions" :> {}],
