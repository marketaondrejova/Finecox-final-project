        77777, $CellContext`type$$ = "Simulated Series"}, 
      "ControllerVariables" :> {
        Hold[$CellContext`type$$, $CellContext`type$245582$$, 0], 
        Hold[$CellContext`d$$, $CellContext`d$245583$$, 0], 
        Hold[$CellContext`seed$$, $CellContext`seed$245584$$, 0]}, 
      "OtherVariables" :> {
       Typeset`show$$, Typeset`bookmarkList$$, Typeset`bookmarkMode$$, 
        Typeset`animator$$, Typeset`animvar$$, Typeset`name$$, 
        Typeset`specs$$, Typeset`size$$, Typeset`update$$, Typeset`initDone$$,
         Typeset`skipInitDone$$}, 
      "Body" :> (
       SeedRandom[$CellContext`seed$$]; $CellContext`egarch = RandomReal[
          NormalDistribution[0, 1], 500]; $CellContext`garch = Table[
          Variance[$CellContext`egarch], {500}]; $CellContext`garcha = 
        Table[Sqrt[
            Part[$CellContext`garch, $CellContext`i]] 
          Part[$CellContext`egarch, $CellContext`i], {$CellContext`i, 
           500}]; $CellContext`m = 
        Length[$CellContext`parg1$$]; $CellContext`s = 
        Length[$CellContext`parg2$$]; 
       Part[$CellContext`garch, $CellContext`s] = 
        Variance[$CellContext`egarchm]; 
       Part[$CellContext`garcha, $CellContext`s] = Sqrt[
           Part[$CellContext`garch, $CellContext`s]] 
         Part[$CellContext`egarch, $CellContext`s - 1]; 
       Do[Part[$CellContext`garch, $CellContext`i] = 
          Part[$CellContext`parg1$$, 1] + 
           Sum[Part[$CellContext`parg1$$, $CellContext`g] 
             Part[$CellContext`garcha, $CellContext`i + 
                1 - $CellContext`g]^2, {$CellContext`g, 2, $CellContext`m}] + 
           Sum[Part[$CellContext`parg2$$, $CellContext`f] 
             Part[$CellContext`garch, $CellContext`i - $CellContext`f], \
{$CellContext`f, 1, $CellContext`s}]; 
         Part[$CellContext`garcha, $CellContext`i] = 
          Sum[Part[$CellContext`paramp$$, $CellContext`g] 
             Part[$CellContext`garcha, $CellContext`i + 
               1 - $CellContext`g], {$CellContext`g, 1, 
              Length[$CellContext`paramp$$]}] + 
           Sum[Part[$CellContext`paramq$$, $CellContext`f] 
             Part[$CellContext`egarch, $CellContext`i - $CellContext`f], \
{$CellContext`f, 1, 
              Length[$CellContext`paramq$$]}] + Sqrt[
              Part[$CellContext`garch, $CellContext`i]] 
            Part[$CellContext`egarch, $CellContext`i]; 
         Null, {$CellContext`i, $CellContext`s + 1, 
          Length[$CellContext`egarchm]}]; 
       If[$CellContext`d$$ == 
         0, $CellContext`arimagarch = $CellContext`garcha, \
$CellContext`arimagarch = 
         FoldList[Plus, 0, $CellContext`garcha]]; $CellContext`acfargar = 
        CorrelationFunction[$CellContext`arimagarch, {
          40}]; $CellContext`stdev = 2/Sqrt[200]; $CellContext`pacfargar = 
        PartialCorrelationFunction[$CellContext`arimagarch, {40}]; If[Sum[
             
             Part[$CellContext`parg1$$, $CellContext`c], {$CellContext`c, 
              1, $CellContext`m}] + Sum[
             
             Part[$CellContext`parg2$$, $CellContext`d$$], {$CellContext`d$$, 
              1, $CellContext`s}] < 1 === True, 
         ListPlot[
          
          If[$CellContext`type$$ === 
           "Simulated Series", $CellContext`arimagarch, 
           
           If[$CellContext`type$$ === 
            "Simulated Volatility", $CellContext`garch, 
            If[$CellContext`type$$ === "ACF function", {
              
              Table[$CellContext`z = $CellContext`stdev, {$CellContext`z, 0, 
                40}], 
              
              Table[$CellContext`z = -$CellContext`stdev, {$CellContext`z, 0, 
                40}], $CellContext`acfargar}, {
              
              Table[$CellContext`z = $CellContext`stdev, {$CellContext`z, 0, 
                40}], 
              
              Table[$CellContext`z = -$CellContext`stdev, {$CellContext`z, 0, 
                40}], $CellContext`pacfargar}]]], 
          Joined -> {True, True, False}, Frame -> True, Filling -> 
          If[$CellContext`type$$ =!= "Simulated Series", 
            
            If[$CellContext`type$$ =!= "Simulated Volatility", {3 -> Axis}, 
             None], None], FillingStyle -> {3 -> Black}, PlotStyle -> 
          If[$CellContext`type$$ =!= "Simulated Series", 
            If[$CellContext`type$$ =!= "Simulated Volatility", {{
               Dashing[Large], 
               Thickness[Medium], Red}, {
               Dashing[Large], 
               Thickness[Medium], Red}, Black}, {
              Thickness[Medium], Red}], {
             Thickness[Medium], Red}], PlotRange -> 
          If[$CellContext`type$$ =!= "Simulated Series", 
            If[$CellContext`type$$ =!= "Simulated Volatility", {-1, 1}, All], 
            Automatic], PlotLabel -> 
          If[$CellContext`d$$ =!= 0, "process is unit-root nonstationary", 
            ""]], 
         Style[
         "Please input (\!\(\*SubscriptBox[\(\[Alpha]\), \
\(i\)]\)+\!\(\*SubscriptBox[\(\[Beta]\), \(i\)]\))<1", Bold, 12]]), 
      "Specifications" :> {{{$CellContext`type$$, "Simulated Series", ""}, {
         "Simulated Series", "Simulated Volatility", "ACF function", 
          "PACF function"}}, 
        Style["ARIMA[p,q,d] parameters", Bold, 12], 
        Delimiter, {{$CellContext`d$$, 0, "difference"}, 0, 1, 1, Appearance -> 
         "Labeled"}, {{$CellContext`paramp$$, {0.2, -0.2}, 
          "AR(p) parameters"}, ControlType -> 
         InputField}, {{$CellContext`paramq$$, {0.1, 0.3}, 
          "MA(q) parameters"}, ControlType -> InputField}, Delimiter, 
        Style["GARCH[m,s] parameters", Bold, 12], 
        Delimiter, {{$CellContext`parg1$$, {0.1, 0.2, 0.3}, 
          "\!\(\*SubscriptBox[\(\[Alpha]\), \(m\)]\)"}, ControlType -> 
         InputField}, {{$CellContext`parg2$$, {0.05, 0.2}, 
          "\!\(\*SubscriptBox[\(\[Beta]\), \(s\)]\)"}, ControlType -> 
         InputField}, 
        Delimiter, {{$CellContext`seed$$, 77777, "New Random Case"}, 10000, 
         999999, 1}, 
        Button["Export Simulated Series", 
         Export["arima_garch.txt", $CellContext`arimagarch], ImageSize -> 
         200]}, "Options" :> {ControlPlacement -> Right}, 
      "DefaultOptions" :> {}],
     ImageSizeCache->{1915., {437., 455.}},
     SingleEvaluation->True],
