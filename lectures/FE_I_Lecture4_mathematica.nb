Cell[CellGroupData[{

Cell["ARCH(1)", "Section",
 CellChangeTimes->{{3.3966353923022757`*^9, 3.3966354214508004`*^9}, {
   3.3966359474024887`*^9, 3.3966359493701363`*^9}, 3.396711350135174*^9, 
   3.529611360192326*^9},ExpressionUUID->"7b9b6a25-a660-449e-80ad-\
a3ee224808fd"],

Cell[TextData[{
 "The first model that provides a systematic framework for volatility \
modeling is Autoregressive conditional heteroscedasticity (ARCH) model. \
ARCH(1) model is most common from ARCH(\[ScriptM]) models in financial \
theory. Basic idea is that the mean-corrected return is serially \
uncorrelated, but dependent, and that the dependence can be described by a \
simple function of lagged values:\n\n",
 Cell[BoxData[{
  FormBox[
   RowBox[{
    SubscriptBox["r", "t"], "=", " ", 
    RowBox[{
     SubscriptBox["\[Mu]", "t"], "+", 
     SubscriptBox["a", "t"]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    SubscriptBox["a", "t"], "=", 
    RowBox[{
     SubscriptBox["\[Sigma]", "t"], 
     SubscriptBox["\[Epsilon]", "t"]}]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Sigma]", "t", "2"], "=", 
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], "+", 
     RowBox[{
      SubscriptBox["\[Alpha]", "1"], 
      SubsuperscriptBox["a", 
       RowBox[{"t", "-", "1"}], "2"]}]}]}], TraditionalForm]}],ExpressionUUID->
  "7196f907-b7d9-4386-abab-b17c8998df43"],
 "\n\nWhere ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "t"], TraditionalForm]],ExpressionUUID->
  "935e9e8c-4bc0-4852-81e8-45c918015e74"],
 " is mean corrected return and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], ">", "0"}], ",", " ", 
    RowBox[{
     SubscriptBox["\[Alpha]", "1"], "\[GreaterEqual]", "0"}]}], 
   TraditionalForm]],ExpressionUUID->"e975aacb-3386-418f-96e6-3e96db74a31b"],
 ". \nUnconditional mean of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "t"], TraditionalForm]],ExpressionUUID->
  "36b769c0-68e1-4bb8-ae9c-f381d032b9b6"],
 " is zero, unconditional variance is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Alpha]", "0"], "/", 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      SubscriptBox["\[Alpha]", "1"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"41941c27-ae66-45f8-9433-f4141bcbf769"],
 ". \nThe process is stationary, if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Alpha]", "1"], "<", "1"}], TraditionalForm]],
  ExpressionUUID->"6f02ead3-d6f9-4d07-8842-47b1a6e3ac40"],
 ", the fourth moment is finite if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"3", 
     SubsuperscriptBox["\[Alpha]", "1", "2"]}], "<", "1"}], TraditionalForm]],
  ExpressionUUID->"d7589fe5-c26c-45a1-8caf-8012e6cc2739"],
 ". "
}], "Text",
 CellChangeTimes->{
  3.396635426615509*^9, {3.3966354627958107`*^9, 3.39663555449502*^9}, {
   3.3966357344327216`*^9, 3.396635741236974*^9}, {3.396635952540832*^9, 
   3.396635965698193*^9}, {3.396636015056362*^9, 3.3966360260244102`*^9}, {
   3.396636156414502*^9, 3.3966361596183987`*^9}, {3.396636322800337*^9, 
   3.396636505718317*^9}, {3.529611279757804*^9, 3.529611289277423*^9}, {
   3.529611329547666*^9, 3.52961134470189*^9}, {3.5296114035539713`*^9, 
   3.529611406703779*^9}, {3.529611453399448*^9, 3.529611497510206*^9}, {
   3.529611656475263*^9, 3.529611743056159*^9}, {3.529611844530061*^9, 
   3.52961185054027*^9}, {3.529612157184717*^9, 3.52961215828225*^9}, {
   3.5296130831640787`*^9, 3.529613137766034*^9}, {3.529646617019518*^9, 
   3.529646727917447*^9}, {3.5296469295302553`*^9, 3.529646956422077*^9}, {
   3.52964715705252*^9, 3.529647161557067*^9}, {3.52964727660288*^9, 
   3.529647288495977*^9}, {3.5296473297283173`*^9, 3.529647358662133*^9}, {
   3.529647436466901*^9, 3.529647451960693*^9}, {3.529647489365049*^9, 
   3.529647760922366*^9}, {3.529648251628587*^9, 3.52964832008888*^9}, {
   3.529666147212743*^9, 3.5296662087377443`*^9}, 3.5611089297112923`*^9, 
   3.561180542582994*^9, {3.5920596540308323`*^9, 3.5920596800283117`*^9}, 
   3.654783800415937*^9, {3.781585191500187*^9, 3.781585287468074*^9}, {
   3.8127908532258177`*^9, 3.812790874136145*^9}, {3.812790911855399*^9, 
   3.8127909205778847`*^9}, {3.8127909649282417`*^9, 3.8127909671559973`*^9}, 
   3.887873326240756*^9, 
   3.919047913435225*^9},ExpressionUUID->"8a503910-8e9d-4333-a4b5-\
5ffd170ce242"],

Cell[CellGroupData[{

Cell["Kurtosis of ARCH(1) processes", "Subsection",
 CellChangeTimes->{{3.396546393955388*^9, 3.3965463976719475`*^9}, {
   3.396636144215088*^9, 3.3966361498660927`*^9}, 3.396775570023816*^9, {
   3.529647024698086*^9, 
   3.529647033160212*^9}},ExpressionUUID->"0c3f78d9-fdb6-4722-bbbe-\
2ecec7715715"],

Cell[TextData[{
 "The fourth moment of ARCH(1) process:\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"E", "[", 
     SuperscriptBox[
      SubscriptBox["\[Epsilon]", "t"], "4"], "]"}], "=", 
    RowBox[{
     FractionBox[
      RowBox[{"3", 
       SuperscriptBox[
        SubscriptBox["\[Alpha]", "0"], "2"]}], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "-", 
         SubscriptBox["\[Alpha]", "1"]}], ")"}], "2"]], 
     FractionBox[
      RowBox[{"1", "-", 
       SuperscriptBox[
        SubscriptBox["\[Alpha]", "1"], "2"]}], 
      RowBox[{"1", "-", 
       RowBox[{"3", 
        SuperscriptBox[
         SubscriptBox["\[Alpha]", "1"], "2"]}]}]]}]}], TraditionalForm]],
  ExpressionUUID->"d59171f9-99eb-4431-9776-3795ce8e2336"],
 ", with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"3", 
     SuperscriptBox[
      SubscriptBox["\[Alpha]", "1"], "2"]}], "<", "1"}], TraditionalForm]],
  ExpressionUUID->"7b5f878b-2ed3-4bd9-97ac-10f62f1b6a08"],
 "\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"kurt", "(", 
     SubscriptBox["\[Epsilon]", "t"], ")"}], "=", 
    RowBox[{
     FractionBox[
      RowBox[{"E", "[", 
       SuperscriptBox[
        SubscriptBox["\[Epsilon]", "t"], "4"], "]"}], 
      SuperscriptBox[
       RowBox[{"E", "[", 
        SuperscriptBox[
         SubscriptBox["\[Epsilon]", "t"], "2"], "]"}], "2"]], "=", 
     RowBox[{
      RowBox[{"3", 
       FractionBox[
        RowBox[{"1", "-", 
         SuperscriptBox[
          SubscriptBox["\[Alpha]", "1"], "2"]}], 
        RowBox[{"1", "-", 
         RowBox[{"3", 
          SuperscriptBox[
           SubscriptBox["\[Alpha]", "1"], "2"]}]}]]}], "\[GreaterSlantEqual]",
       "3"}]}]}], TraditionalForm]],ExpressionUUID->
  "6dca5bc8-ef3f-4968-aca2-80b94c164f7b"],
 "\n"
}], "Text",
 CellChangeTimes->{
  3.396635426615509*^9, {3.3966354627958107`*^9, 3.39663555449502*^9}, {
   3.3966357344327216`*^9, 3.396635741236974*^9}, {3.396635952540832*^9, 
