fb6ca22d6c08"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"SeedRandom", "[", "seed", "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"egarch", "=", 
     RowBox[{"RandomReal", "[", 
      RowBox[{
       RowBox[{"NormalDistribution", "[", 
        RowBox[{"0", ",", "1"}], "]"}], ",", "500"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"garch", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Variance", "[", "egarch", "]"}], ",", 
       RowBox[{"{", "500", "}"}]}], "]"}]}], ";", 
    RowBox[{"garcha", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Sqrt", "[", 
         RowBox[{"garch", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "]"}], "  ", 
        RowBox[{"egarch", "[", 
         RowBox[{"[", "i", "]"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "500"}], "}"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"m", "=", 
     RowBox[{"Length", "[", "parg1", "]"}]}], ";", 
    RowBox[{"s", "=", 
     RowBox[{"Length", "[", "parg2", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"garch", "[", 
      RowBox[{"[", "s", "]"}], "]"}], "=", 
     RowBox[{"Variance", "[", "egarchm", "]"}]}], ";", 
    RowBox[{
     RowBox[{"garcha", "[", 
      RowBox[{"[", "s", "]"}], "]"}], "=", 
     RowBox[{
      RowBox[{"Sqrt", "[", 
       RowBox[{"garch", "[", 
        RowBox[{"[", "s", "]"}], "]"}], "]"}], " ", 
      RowBox[{"egarch", "[", 
       RowBox[{"[", 
        RowBox[{"s", "-", "1"}], "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"garch", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "=", 
        RowBox[{
         RowBox[{"parg1", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "+", 
         RowBox[{
          UnderoverscriptBox["\[Sum]", 
           RowBox[{"g", "=", "2"}], "m"], 
          RowBox[{
           RowBox[{"parg1", "[", 
            RowBox[{"[", "g", "]"}], "]"}], " ", 
           RowBox[{
            RowBox[{"garcha", "[", 
             RowBox[{"[", 
              RowBox[{"i", "+", "1", "-", "g"}], "]"}], "]"}], "^", "2"}]}]}],
          "+", 
         RowBox[{
          UnderoverscriptBox["\[Sum]", 
           RowBox[{"f", "=", "1"}], "s"], 
          RowBox[{
           RowBox[{"parg2", "[", 
            RowBox[{"[", "f", "]"}], "]"}], " ", 
           RowBox[{"garch", "[", 
            RowBox[{"[", 
             RowBox[{"i", "-", "f"}], "]"}], "]"}]}]}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"garcha", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "=", 
        RowBox[{
         RowBox[{
          UnderoverscriptBox["\[Sum]", 
           RowBox[{"g", "=", "1"}], 
           RowBox[{"Length", "[", "paramp", "]"}]], 
          RowBox[{
           RowBox[{"paramp", "[", 
            RowBox[{"[", "g", "]"}], "]"}], " ", 
           RowBox[{"garcha", "[", 
            RowBox[{"[", 
             RowBox[{"i", "+", "1", "-", "g"}], "]"}], "]"}]}]}], "+", 
         RowBox[{
          UnderoverscriptBox["\[Sum]", 
           RowBox[{"f", "=", "1"}], 
           RowBox[{"Length", "[", "paramq", "]"}]], 
          RowBox[{
           RowBox[{"paramq", "[", 
            RowBox[{"[", "f", "]"}], "]"}], " ", 
           RowBox[{"egarch", "[", 
            RowBox[{"[", 
             RowBox[{"i", "-", "f"}], "]"}], "]"}]}]}], "+", 
         RowBox[{
          RowBox[{"Sqrt", "[", 
           RowBox[{"garch", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "]"}], " ", 
          RowBox[{"egarch", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]",
       ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", 
        RowBox[{"s", "+", "1"}], ",", 
        RowBox[{"Length", "[", "egarchm", "]"}]}], "}"}]}], "]"}], ";", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"d", "\[Equal]", "0"}], ",", 
      RowBox[{"arimagarch", "=", "garcha"}], ",", 
      RowBox[{"arimagarch", "=", 
       RowBox[{"FoldList", "[", 
        RowBox[{"Plus", ",", "0", ",", "garcha"}], "]"}]}]}], "]"}], ";", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"acfargar", "=", 
     RowBox[{"CorrelationFunction", "[", 
      RowBox[{"arimagarch", ",", 
       RowBox[{"{", "40", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"stdev", "=", 
     RowBox[{"2", "/", 
      RowBox[{"Sqrt", "[", "200", "]"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"pacfargar", "=", 
     RowBox[{"PartialCorrelationFunction", "[", 
      RowBox[{"arimagarch", ",", 
       RowBox[{"{", "40", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           UnderoverscriptBox["\[Sum]", 
            RowBox[{"c", "=", "1"}], "m"], 
           RowBox[{"parg1", "[", 
            RowBox[{"[", "c", "]"}], "]"}]}], "+", 
          RowBox[{
           UnderoverscriptBox["\[Sum]", 
            RowBox[{"d", "=", "1"}], "s"], 
           RowBox[{"parg2", "[", 
            RowBox[{"[", "d", "]"}], "]"}]}]}], ")"}], "<", "1"}], "===", 
       "True"}], ",", "\[IndentingNewLine]", 
      RowBox[{"ListPlot", "[", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"type", "===", "\"\<Simulated Series\>\""}], ",", 
          "arimagarch", ",", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"type", "===", "\"\<Simulated Volatility\>\""}], ",", 
            "garch", ",", "\[IndentingNewLine]", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"type", "===", "\"\<ACF function\>\""}], ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"Table", "[", 
                 RowBox[{
                  RowBox[{"z", "=", "stdev"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"z", ",", "0", ",", "40"}], "}"}]}], "]"}], ",", 
                RowBox[{"Table", "[", 
                 RowBox[{
                  RowBox[{"z", "=", 
                   RowBox[{"-", "stdev"}]}], ",", 
                  RowBox[{"{", 
                   RowBox[{"z", ",", "0", ",", "40"}], "}"}]}], "]"}], ",", 
                "acfargar"}], "}"}], ",", "\[IndentingNewLine]", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"Table", "[", 
                 RowBox[{
                  RowBox[{"z", "=", "stdev"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"z", ",", "0", ",", "40"}], "}"}]}], "]"}], ",", 
                RowBox[{"Table", "[", 
                 RowBox[{
                  RowBox[{"z", "=", 
                   RowBox[{"-", "stdev"}]}], ",", 
                  RowBox[{"{", 
                   RowBox[{"z", ",", "0", ",", "40"}], "}"}]}], "]"}], ",", 
                "pacfargar"}], "}"}]}], "]"}]}], "]"}]}], "]"}], 
        "\[IndentingNewLine]", ",", 
        RowBox[{"Joined", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"True", ",", "True", ",", "False"}], "}"}]}], ",", 
        RowBox[{"Frame", "\[Rule]", "True"}], ",", "\[IndentingNewLine]", 
        RowBox[{"Filling", "\[Rule]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"type", "=!=", "\"\<Simulated Series\>\""}], ",", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"type", "=!=", "\"\<Simulated Volatility\>\""}], ",", 
             RowBox[{"{", 
              RowBox[{"3", "\[Rule]", "Axis"}], "}"}], ",", "None"}], "]"}], 
           ",", "None"}], "]"}]}], ",", 
        RowBox[{"FillingStyle", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"3", "\[Rule]", "Black"}], "}"}]}], ",", 
        RowBox[{"PlotStyle", "\[Rule]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"type", "=!=", "\"\<Simulated Series\>\""}], ",", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"type", "=!=", "\"\<Simulated Volatility\>\""}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"Dashing", "[", "Large", "]"}], ",", " ", 
                 RowBox[{"Thickness", "[", "Medium", "]"}], ",", " ", "Red"}],
                 "}"}], ",", " ", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"Dashing", "[", "Large", "]"}], ",", " ", 
                 RowBox[{"Thickness", "[", "Medium", "]"}], ",", " ", "Red"}],
                 "}"}], ",", " ", "Black"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"Thickness", "[", "Medium", "]"}], ",", " ", "Red"}], 
              "}"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Thickness", "[", "Medium", "]"}], ",", " ", "Red"}], 
            "}"}]}], "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"PlotRange", "\[Rule]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"type", "=!=", "\"\<Simulated Series\>\""}], ",", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"type", "=!=", "\"\<Simulated Volatility\>\""}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", "All"}], "]"}], 
           ",", "Automatic"}], "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"PlotLabel", "\[Rule]", " ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"d", "=!=", "0"}], ",", 
           "\"\<process is unit-root nonstationary\>\"", ",", "\"\<\>\""}], 
          "]"}]}]}], "]"}], ",", "\[IndentingNewLine]", 
      RowBox[{"Style", "[", 
       RowBox[{
       "\"\<Please input (\!\(\*SubscriptBox[\(\[Alpha]\), \
\(i\)]\)+\!\(\*SubscriptBox[\(\[Beta]\), \(i\)]\))<1\>\"", ",", "Bold", ",", 
        "12"}], "]"}]}], "]"}]}], ",", "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"type", ",", "\"\<Simulated Series\>\"", ",", "\"\<\>\""}], 
      "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
      "\"\<Simulated Series\>\"", ",", "\"\<Simulated Volatility\>\"", ",", 
       "\"\<ACF function\>\"", ",", "\"\<PACF function\>\""}], "}"}]}], "}"}],
    ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"Style", "[", 
    RowBox[{"\"\<ARIMA[p,q,d] parameters\>\"", ",", "Bold", ",", "12"}], 
    "]"}], ",", "Delimiter", ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
