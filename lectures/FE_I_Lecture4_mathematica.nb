Cell[CellGroupData[{

Cell["ARCH(\[ScriptM])", "Section",
 CellChangeTimes->{{3.3966332762697415`*^9, 
  3.396633294767581*^9}},ExpressionUUID->"1aac080d-5ba8-4b10-8dcb-\
a75b7bc12383"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "t"], "=", 
    RowBox[{
     SubscriptBox["\[Sigma]", "t"], 
     SubscriptBox["\[Epsilon]", "t"]}]}], TraditionalForm]],ExpressionUUID->
  "5585206a-c521-49c1-9ff0-c3229f30a9b7"],
 ",\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Sigma]", "t", "2"], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["\[Alpha]", "0"], "+", 
       RowBox[{
        SubscriptBox["\[Alpha]", "1"], 
        SubsuperscriptBox["a", 
         RowBox[{"t", "-", "1"}], "2"]}], "+"}], "..."}], "+", 
     RowBox[{
      SubscriptBox["\[Alpha]", "m"], 
      SubsuperscriptBox["a", 
       RowBox[{"t", "-", "m"}], "2"]}]}]}], TraditionalForm]],ExpressionUUID->
  "058be5e3-439f-4c06-88af-47d3a5554c91"],
 ",\n\nwhere ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "t"], TraditionalForm]],ExpressionUUID->
  "4a300fc0-cce6-40ba-80da-60b44c984b81"],
 " is mean corrected return ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "t"], "=", 
    RowBox[{
     SubscriptBox["r", "t"], "-", 
     SubscriptBox["\[Mu]", "t"]}]}], TraditionalForm]],ExpressionUUID->
  "0f8a57eb-b750-45dd-8b4d-44db39b4f2fe"],
 ", {",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Epsilon]", "t"], "}"}], TraditionalForm]],ExpressionUUID->
  "26b21890-c499-489d-adc1-ba7a853fbbd9"],
 " is i.i.d random variables with zero mean and variance 1,  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], ">", "0"}], ",", " ", 
    RowBox[{
     SubscriptBox["\[Alpha]", "i"], "\[GreaterEqual]", "0"}]}], 
   TraditionalForm]],ExpressionUUID->"2b2b8bb6-3c30-4815-b88a-2c040a12d8b3"],
 " for \[ScriptI] > 0.\n\nOne can easily observe, that large past squared \
shocks ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox[
    RowBox[{"{", 
     SubsuperscriptBox["a", 
      RowBox[{"t", "-", "i"}], "2"], "}"}], 
    RowBox[{"i", "=", "1"}], "m"], TraditionalForm]],ExpressionUUID->
  "3d7e42d3-efa8-49cd-ad2a-e4b9f9a901bc"],
 " imply large conditional variance ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[Sigma]", "t", "2"], TraditionalForm]],ExpressionUUID->
  "b1d6850b-9f6c-434b-a05a-5c1ffd98f0e5"],
 ", or volatility. Thus under ARCH, large shocks tend to be followed by large \
shocks - ARCH effect"
}], "Text",
 CellChangeTimes->{{3.396546380531443*^9, 3.396546380906419*^9}, {
   3.39663134679558*^9, 3.3966313713242826`*^9}, {3.39663146207824*^9, 
   3.3966316366403093`*^9}, 3.396631714683166*^9, {3.3966318232514124`*^9, 
   3.3966318794362926`*^9}, {3.396632553750556*^9, 3.396632558465098*^9}, 
   3.396632646090349*^9, 3.3966327050738783`*^9, {3.39663277412317*^9, 
   3.396632911718856*^9}, 3.3966338836341877`*^9, {3.396633936443308*^9, 
   3.3966340365999837`*^9}, {3.3966342832795076`*^9, 3.396634472010592*^9}, {
   3.3966815515707245`*^9, 3.3966815809653273`*^9}, 3.529611273904132*^9, {
   3.529666265965518*^9, 3.5296662685973883`*^9}, 3.561191828807908*^9, {
   3.8564170099207*^9, 3.856417020040948*^9}, 
   3.919049380769659*^9},ExpressionUUID->"61cf4726-4f70-4e33-9901-\
8a3d43980634"],

Cell[CellGroupData[{

Cell["Examples of ARCH(\[ScriptM]) artificial processes", "Subsection",
 CellChangeTimes->{{3.396635307584065*^9, 3.396635340233342*^9}, {
   3.396636135747856*^9, 3.396636140522941*^9}, 
   3.3967755673208647`*^9},ExpressionUUID->"011be4d7-3ee2-4ded-9ed7-\
b17d26428126"],

Cell[TextData[{
 "Note that  you have to input ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], ">", "0"}], ",", " ", 
    RowBox[{
     SubscriptBox["\[Alpha]", "i"], "\[GreaterEqual]", "0"}]}], 
   TraditionalForm]],ExpressionUUID->"a8ade24c-2287-4dd0-9582-4dfe6287ad3f"],
 " for \[ScriptI] > 0. in form ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], ",", 
     RowBox[{
      SubscriptBox["\[Alpha]", "1"], "..."}], ",", 
     SubscriptBox["\[Alpha]", "m"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "088b3c65-8e6c-47c0-b3b5-c5369851ec7e"]
}], "Text",
 CellChangeTimes->{{3.3966425324194975`*^9, 3.3966425679699564`*^9}, {
  3.396647078059222*^9, 
  3.3966471245259743`*^9}},ExpressionUUID->"041f90a6-67bc-4e87-9266-\
34508f29c7f8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"SeedRandom", "[", "seed", "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"earchm", "=", 
     RowBox[{"RandomReal", "[", 
      RowBox[{
       RowBox[{"NormalDistribution", "[", 
        RowBox[{"0", ",", "1"}], "]"}], ",", "500"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"archm", "=", 
     RowBox[{"Table", "[", 
      RowBox[{"0", ",", 
       RowBox[{"{", "500", "}"}]}], "]"}]}], ";", 
    RowBox[{"archma", "=", 
     RowBox[{"Table", "[", 
      RowBox[{"0", ",", 
       RowBox[{"{", "500", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"archm", "[", 
      RowBox[{"[", "1", "]"}], "]"}], "=", 
     RowBox[{"Variance", "[", "earchm", "]"}]}], ";", 
    RowBox[{
     RowBox[{"archma", "[", 
      RowBox[{"[", "1", "]"}], "]"}], "=", 
     RowBox[{
      RowBox[{"Sqrt", "[", 
       RowBox[{"archm", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "]"}], " ", 
      RowBox[{"earchm", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}]}], ";", 
    RowBox[{"m", "=", 
     RowBox[{"Length", "[", "paramarchm", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"archm", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "=", 
        RowBox[{
         RowBox[{"paramarchm", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "+", 
         RowBox[{
          UnderoverscriptBox["\[Sum]", 
           RowBox[{"g", "=", "2"}], "m"], 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"paramarchm", "[", 
             RowBox[{"[", "g", "]"}], "]"}], "  ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"archma", "[", 
               RowBox[{"[", 
                RowBox[{"i", "-", "g", "+", "1"}], "]"}], "]"}], ")"}], "^", 
             "2"}]}], ")"}]}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"archma", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "=", 
        RowBox[{
         RowBox[{"Sqrt", "[", 
          RowBox[{"archm", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "]"}], " ", 
         RowBox[{"earchm", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
      ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "2", ",", 
        RowBox[{"Length", "[", "earchm", "]"}]}], "}"}]}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"acfarchm", "=", 
     RowBox[{"CorrelationFunction", "[", 
      RowBox[{
       RowBox[{"archma", "^", "2"}], ",", 
       RowBox[{"{", "30", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"stdevarchm", "=", 
     RowBox[{"2", "/", 
      RowBox[{"Sqrt", "[", "500", "]"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"pacfarchm", "=", 
     RowBox[{"PartialCorrelationFunction", "[", 
      RowBox[{
       RowBox[{"archma", "^", "2"}], ",", 
       RowBox[{"{", "30", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"ListPlot", "[", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"type", "===", "\"\<Sample ARCH(m)\>\""}], ",", "archma", ",",
         "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"type", "===", "\"\<ARCH(m) volatility\>\""}], ",", "archm",
           ",", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
            "type", "===", 
             "\"\<ACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \
\(2\)]\)\>\""}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{"z", "=", "stdevarchm"}], ",", 
                RowBox[{"{", 
                 RowBox[{"z", ",", "0", ",", "30"}], "}"}]}], "]"}], ",", 
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{"z", "=", 
                 RowBox[{"-", "stdevarchm"}]}], ",", 
                RowBox[{"{", 
                 RowBox[{"z", ",", "0", ",", "30"}], "}"}]}], "]"}], ",", 
              "acfarchm"}], "}"}], ",", "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{"z", "=", "stdevarchm"}], ",", 
                RowBox[{"{", 
                 RowBox[{"z", ",", "0", ",", "30"}], "}"}]}], "]"}], ",", 
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{"z", "=", 
                 RowBox[{"-", "stdevarchm"}]}], ",", 
                RowBox[{"{", 
                 RowBox[{"z", ",", "0", ",", "30"}], "}"}]}], "]"}], ",", 
              "pacfarchm"}], "}"}]}], "]"}]}], "]"}]}], "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"Joined", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"True", ",", "True", ",", "False"}], "}"}]}], ",", " ", 
      RowBox[{"Frame", " ", "->", " ", "True"}], ",", 
      RowBox[{"Filling", "\[Rule]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"type", "=!=", "\"\<Sample ARCH(m)\>\""}], ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"type", "=!=", "\"\<ARCH(m) volatility\>\""}], ",", 
           RowBox[{"{", 
            RowBox[{"3", "\[Rule]", " ", "Axis"}], "}"}], ",", "None"}], 
          "]"}], ",", "None"}], "]"}]}], ",", 
      RowBox[{"FillingStyle", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"3", "\[Rule]", "Black"}], "}"}]}], ",", 
      RowBox[{"PlotStyle", "\[Rule]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"type", "=!=", "\"\<Sample ARCH(m)\>\""}], ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"type", "=!=", "\"\<ARCH(m) volatility\>\""}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"Dashing", "[", "Large", "]"}], ",", " ", 
               RowBox[{"Thickness", "[", "Medium", "]"}], ",", " ", "Red"}], 
              "}"}], ",", " ", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"Dashing", "[", "Large", "]"}], ",", " ", 
               RowBox[{"Thickness", "[", "Medium", "]"}], ",", " ", "Red"}], 
              "}"}], ",", " ", "Black"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Thickness", "[", "Medium", "]"}], ",", " ", "Red"}], 
            "}"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Thickness", "[", "Medium", "]"}], ",", " ", "Red"}], 
          "}"}]}], "]"}]}], ",", 
      RowBox[{"PlotRange", "\[Rule]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"type", "===", "\"\<Sample ARCH(m)\>\""}], ",", "All", ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"type", "===", "\"\<ARCH(m) volatility\>\""}], ",", "All", 
           ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "0.5"}], ",", "0.5"}], "}"}]}], "]"}]}], "]"}]}]}], 
     "]"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"Style", "[", 
    RowBox[{"\"\<Input Parameters of ARCH(m):\>\"", ",", "12"}], "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"paramarchm", ",", 
       RowBox[{"{", 
        RowBox[{"0.75", ",", "0.1"}], "}"}], ",", 
       "\"\<\!\(\*SubscriptBox[\(\[Alpha]\), \(m\)]\)\>\""}], "}"}], ",", 
     RowBox[{"ControlType", "\[Rule]", "InputField"}]}], "}"}], ",", 
   "Delimiter", ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"type", ",", "\"\<Sample ARCH(m)\>\"", ",", "\"\<\>\""}], "}"}],
      ",", 
     RowBox[{"{", 
      RowBox[{"\"\<Sample ARCH(m)\>\"", ",", "\"\<ARCH(m) volatility\>\""}], 
      "}"}]}], "}"}], ",", "Delimiter", ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"type", ",", "\"\<Sample ARCH(m)\>\"", ",", "\"\<\>\""}], "}"}],
      ",", 
     RowBox[{"{", 
      RowBox[{
      "\"\<ACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \
\(2\)]\)\>\"", ",", 
       "\"\<PACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\)]\)\>\
\""}], "}"}]}], "}"}], ",", "Delimiter", ",", "\[IndentingNewLine]", 
   RowBox[{"Style", "[", 
    RowBox[{"\"\<New Random Case\>\"", ",", "12"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"seed", ",", "77777", ",", "\"\<\>\""}], "}"}], ",", "10000", 
     ",", "999999", ",", "1"}], "}"}], ",", "Delimiter"}], "]"}]], "Input",
 CellChangeTimes->{{3.3966353425007753`*^9, 3.396635343532936*^9}, {
