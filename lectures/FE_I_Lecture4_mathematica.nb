   "Delimiter", ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"Style", "[", 
    RowBox[{"\"\<GARCH[m,s] parameters\>\"", ",", "Bold", ",", "12"}], "]"}], 
   ",", "Delimiter", ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
