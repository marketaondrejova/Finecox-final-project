Cell[CellGroupData[{

Cell["Conditional Heteroscedastic Models", "Section",
 CellChangeTimes->{{3.396546312552396*^9, 3.3965463195226526`*^9}, 
   3.4062250230614243`*^9, 
   3.529611114297471*^9},ExpressionUUID->"f9794004-c002-407e-a5ca-\
166157138259"],

Cell[TextData[{
 "Log returns of an asset at time is either serially uncorrelated, or with \
minor lower order serial correlations, but it is ",
 StyleBox["dependent",
  FontColor->RGBColor[1, 0, 0]],
 ". Conditional heteroscedastic models are used for modeling ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[Sigma]", "t", "2"], TraditionalForm]],ExpressionUUID->
  "88ee11c6-2b7f-4051-9582-53f41247821e"],
 " as volatility estimate by \"allowing\" heteroscedasticity (time-variation) \
and capturing that dependence.\n"
}], "Text",
 CellChangeTimes->{{3.3965463361661186`*^9, 3.39654633621592*^9}, {
   3.3965469090728097`*^9, 3.396546938976169*^9}, {3.3965469834723444`*^9, 
   3.3965470004751625`*^9}, {3.396548165093005*^9, 3.396548169811453*^9}, {
   3.396548200726466*^9, 3.3965482758193164`*^9}, {3.396553338687655*^9, 
   3.3965533397549696`*^9}, {3.3965918020302534`*^9, 3.396591878327128*^9}, 
