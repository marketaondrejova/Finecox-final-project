   3.397202445067878*^9, 3.397202463290344*^9}, {3.397202507185972*^9, 
   3.397202525972856*^9}, {3.397202711809594*^9, 3.397202723706294*^9}, {
   3.397202817869212*^9, 3.397202819764599*^9}, {3.397202922199449*^9, 
   3.3972029248369756`*^9}, {3.397203088759101*^9, 3.3972030890998993`*^9}, {
   3.3972178224625683`*^9, 3.397217843207334*^9}, {3.397217897469486*^9, 
   3.3972179082822704`*^9}, {3.397217943471424*^9, 3.3972179485931673`*^9}, {
   3.464953780569779*^9, 3.4649537819222193`*^9}, {3.464953820546816*^9, 
   3.464953824010976*^9}, {3.464953855117118*^9, 3.464953864484578*^9}, {
   3.464953899974221*^9, 3.464953900557514*^9}, 3.464959586775461*^9, {
   3.561111188581243*^9, 3.561111190212874*^9}, 3.593061744148628*^9, {
   3.593061788751486*^9, 3.593061799236117*^9}, {3.6236613834563637`*^9, 
   3.623661384089485*^9}},ExpressionUUID->"6dc86517-fb7f-4223-a6c0-\
fd592af5df54"],

Cell[BoxData[
 TagBox[
  StyleBox[
   DynamicModuleBox[{$CellContext`paramarchm$$ = {0.5, 
    0.2}, $CellContext`seed$$ = 77777, $CellContext`type$$ = 
    "ACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\)]\)", 
    Typeset`show$$ = True, Typeset`bookmarkList$$ = {}, 
    Typeset`bookmarkMode$$ = "Menu", Typeset`animator$$, Typeset`animvar$$ = 
    1, Typeset`name$$ = "\"untitled\"", Typeset`specs$$ = {{
      Hold[
       Style["Input Parameters of ARCH(m):", 12]], 
      Manipulate`Dump`ThisIsNotAControl}, {{
       Hold[$CellContext`paramarchm$$], {0.75, 0.1}, 
       "\!\(\*SubscriptBox[\(\[Alpha]\), \(m\)]\)"}}, {{
       Hold[$CellContext`type$$], "Sample ARCH(m)", ""}, {
      "Sample ARCH(m)", "ARCH(m) volatility"}}, {{
       Hold[$CellContext`type$$], "Sample ARCH(m)", ""}, {
      "ACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\)]\)", 
       "PACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\)]\)"}}, {
      Hold[
       Style["New Random Case", 12]], Manipulate`Dump`ThisIsNotAControl}, {{
       Hold[$CellContext`seed$$], 77777, ""}, 10000, 999999, 1}}, 
    Typeset`size$$ = {720., {218., 229.}}, Typeset`update$$ = 0, 
    Typeset`initDone$$, Typeset`skipInitDone$$ = 
    True, $CellContext`type$81391$$ = False, $CellContext`seed$81392$$ = 0}, 
    DynamicBox[Manipulate`ManipulateBoxes[
     1, StandardForm, 
      "Variables" :> {$CellContext`paramarchm$$ = {0.75, 
         0.1}, $CellContext`seed$$ = 77777, $CellContext`type$$ = 
        "Sample ARCH(m)"}, "ControllerVariables" :> {
        Hold[$CellContext`type$$, $CellContext`type$81391$$, False], 
        Hold[$CellContext`seed$$, $CellContext`seed$81392$$, 0]}, 
      "OtherVariables" :> {
       Typeset`show$$, Typeset`bookmarkList$$, Typeset`bookmarkMode$$, 
        Typeset`animator$$, Typeset`animvar$$, Typeset`name$$, 
        Typeset`specs$$, Typeset`size$$, Typeset`update$$, Typeset`initDone$$,
         Typeset`skipInitDone$$}, 
      "Body" :> (
       SeedRandom[$CellContext`seed$$]; $CellContext`earchm = RandomReal[
          NormalDistribution[0, 1], 500]; $CellContext`archm = 
        Table[0, {500}]; $CellContext`archma = Table[0, {500}]; 
       Part[$CellContext`archm, 1] = Variance[$CellContext`earchm]; 
       Part[$CellContext`archma, 1] = Sqrt[
           Part[$CellContext`archm, 1]] 
         Part[$CellContext`earchm, 1]; $CellContext`m = 
        Length[$CellContext`paramarchm$$]; 
       Do[Part[$CellContext`archm, $CellContext`i] = 
          Part[$CellContext`paramarchm$$, 1] + 
           Sum[Part[$CellContext`paramarchm$$, $CellContext`g] 
             Part[$CellContext`archma, $CellContext`i - $CellContext`g + 
                1]^2, {$CellContext`g, 2, $CellContext`m}]; 
         Part[$CellContext`archma, $CellContext`i] = Sqrt[
             Part[$CellContext`archm, $CellContext`i]] 
           Part[$CellContext`earchm, $CellContext`i]; 
         Null, {$CellContext`i, 2, 
          Length[$CellContext`earchm]}]; $CellContext`acfarchm = 
        CorrelationFunction[$CellContext`archma^2, {
          30}]; $CellContext`stdevarchm = 2/Sqrt[500]; $CellContext`pacfarchm = 
        PartialCorrelationFunction[$CellContext`archma^2, {30}]; ListPlot[
         If[$CellContext`type$$ === "Sample ARCH(m)", $CellContext`archma, 
          If[$CellContext`type$$ === "ARCH(m) volatility", $CellContext`archm, 
           
           If[$CellContext`type$$ === 
            "ACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\)]\)", {
             
             Table[$CellContext`z = $CellContext`stdevarchm, {$CellContext`z, 
               0, 30}], 
             
             Table[$CellContext`z = -$CellContext`stdevarchm, {$CellContext`z,
                0, 30}], $CellContext`acfarchm}, {
             
             Table[$CellContext`z = $CellContext`stdevarchm, {$CellContext`z, 
               0, 30}], 
             
             Table[$CellContext`z = -$CellContext`stdevarchm, {$CellContext`z,
                0, 30}], $CellContext`pacfarchm}]]], 
         Joined -> {True, True, False}, Frame -> True, Filling -> 
         If[$CellContext`type$$ =!= "Sample ARCH(m)", 
           
           If[$CellContext`type$$ =!= "ARCH(m) volatility", {3 -> Axis}, 
            None], None], FillingStyle -> {3 -> Black}, PlotStyle -> 
         If[$CellContext`type$$ =!= "Sample ARCH(m)", 
           If[$CellContext`type$$ =!= "ARCH(m) volatility", {{
              Dashing[Large], 
              Thickness[Medium], Red}, {
              Dashing[Large], 
              Thickness[Medium], Red}, Black}, {
             Thickness[Medium], Red}], {
            Thickness[Medium], Red}], PlotRange -> 
         If[$CellContext`type$$ === "Sample ARCH(m)", All, 
           
           If[$CellContext`type$$ === "ARCH(m) volatility", All, {-0.5, 
            0.5}]]]), "Specifications" :> {
        Style[
        "Input Parameters of ARCH(m):", 
         12], {{$CellContext`paramarchm$$, {0.75, 0.1}, 
          "\!\(\*SubscriptBox[\(\[Alpha]\), \(m\)]\)"}, ControlType -> 
         InputField}, 
        Delimiter, {{$CellContext`type$$, "Sample ARCH(m)", ""}, {
         "Sample ARCH(m)", "ARCH(m) volatility"}}, 
        Delimiter, {{$CellContext`type$$, "Sample ARCH(m)", ""}, {
         "ACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\)]\)", 
          "PACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\)]\)"}},
         Delimiter, 
        Style[
        "New Random Case", 12], {{$CellContext`seed$$, 77777, ""}, 10000, 
         999999, 1}, Delimiter}, "Options" :> {}, "DefaultOptions" :> {}],
     ImageSizeCache->{804., {436., 447.}},
     SingleEvaluation->True],
    Deinitialization:>None,
    DynamicModuleValues:>{},
    SynchronousInitialization->True,
    UndoTrackedVariables:>{Typeset`show$$, Typeset`bookmarkMode$$},
    UnsavedVariables:>{Typeset`initDone$$},
    UntrackedVariables:>{Typeset`size$$}], "Manipulate",
   Deployed->True,
   StripOnInput->False],
  Manipulate`InterpretManipulate[1]]], "Output",
 CellChangeTimes->{3.593065453648061*^9, 
  3.6236613853562737`*^9},ExpressionUUID->"4ff1eb09-5920-445e-8245-\
740cd4c5569c"]
}, {2}]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Test for ARCH effects in time series", "Section",
 CellChangeTimes->{{3.4062688288987517`*^9, 
  3.4062688365057516`*^9}},ExpressionUUID->"13950006-ea47-4267-83f7-\
f940e43314ab"],

Cell[TextData[{
 "\nWe use Lagrange Multiplier test (LM test), with the null hypothesis of no \
ARCH effects:\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Epsilon]", "t", "2"], "=", 
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], "+", 
     RowBox[{"(", 
      RowBox[{
       UnderoverscriptBox["\[Sum]", 
        RowBox[{"s", "=", "1"}], "q"], 
       RowBox[{
        SubscriptBox["\[Alpha]", "s"], 
        SubsuperscriptBox["\[Epsilon]", 
         RowBox[{"t", "-", "s"}], "2"]}]}], ")"}], "+", 
     SubscriptBox["\[Nu]", "t"]}]}], TraditionalForm]],ExpressionUUID->
  "2fe0daa9-f4b7-4e6b-af1e-98b4fecec07c"],
 "\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["H", "0"], ":", " ", 
       SubscriptBox["\[Alpha]", "1"]}], "=."}], ".."}], "=", 
    RowBox[{
     SubscriptBox["\[Alpha]", "s"], "=", "0"}]}], TraditionalForm]],
  ExpressionUUID->"6ac05b91-8e64-4930-8ea6-1adc30397011"],
 "\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"LM", "=", 
    RowBox[{
     RowBox[{"N", ".", 
      SuperscriptBox["R", "2"]}], "\[Tilde]", 
     RowBox[{
      SuperscriptBox["\[Chi]", "2"], "(", "p", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"3746432a-7f08-4613-b93c-5ff2b22fcb23"]
}], "Text",
 CellChangeTimes->{
  3.406268837676752*^9, {3.4062689677537518`*^9, 3.406269081889752*^9}, {
   3.5296753165734997`*^9, 
   3.529675527619617*^9}},ExpressionUUID->"ddb57633-ffc4-445a-ac06-\
b3e15cba7d37"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Forecasting with ARCH", "Section",
 CellChangeTimes->{{3.406269143060752*^9, 
  3.406269147568752*^9}},ExpressionUUID->"ca0e8be8-35db-43eb-889d-\
8e36a3eff273"],

Cell[TextData[{
 "Forecasts of the ARCH can be obtained recursively\nat origin ",
 StyleBox["h",
  FontSlant->"Italic"],
 ", the 1-step ahead forecast of ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[Sigma]", 
    RowBox[{"h", "+", "1"}], "2"], TraditionalForm]],ExpressionUUID->
  "60e0fa5b-8e55-49b3-80aa-c840337484d0"],
 " is:\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[Sigma]", "h", "2"], "(", "1", ")"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["\[Alpha]", "0"], "+", 
       RowBox[{
        SubscriptBox["\[Alpha]", "1"], 
        SubsuperscriptBox["\[Epsilon]", "h", "2"]}], "+"}], "..."}], "+", 
     RowBox[{
      SubscriptBox["\[Alpha]", "m"], 
      SubsuperscriptBox["\[Epsilon]", 
       RowBox[{"h", "+", "1", "-", "m"}], "2"]}]}]}], TraditionalForm]],
  ExpressionUUID->"8eb3b520-d64a-4d9d-b595-1d99ad7e2f67"],
 "\n\n",
 StyleBox["l",
  FontSlant->"Italic"],
 "-step ahead forecast will be:\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[Sigma]", "h", "2"], "(", "l", ")"}], "=", 
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], "+", 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"i", "=", "1"}], "m"], 
      RowBox[{
       SubscriptBox["\[Alpha]", "i"], 
       RowBox[{
        SubsuperscriptBox["\[Sigma]", "h", "2"], "(", 
        RowBox[{"l", "-", "i"}], ")"}]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"cfa0266a-2df2-4cf4-9d76-e168229520f3"],
 ",\nwhere ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[Sigma]", "h", "2"], "(", 
     RowBox[{"l", "-", "i"}], ")"}], "=", 
    SubsuperscriptBox["\[Epsilon]", 
     RowBox[{"h", "+", "l", "-", "i"}], "2"]}], TraditionalForm]],
  ExpressionUUID->"f7399fc0-b80d-4947-bf3b-b65faa3d0591"],
 " if ",
 StyleBox["l - i ",
  FontSlant->"Italic"],
 "\[LessEqual]",
 StyleBox[" ",
  FontSlant->"Italic"],
 "0."
}], "Text",
 CellChangeTimes->{{3.4062691559797516`*^9, 3.406269427871752*^9}, 
   3.5296755517986937`*^9, 
   3.919049368539266*^9},ExpressionUUID->"d5bfda7b-0cc7-4918-ba2f-\
e1c12d0c2b09"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Weaknesses of ARCH Models", "Section",
 CellChangeTimes->{{3.3966430076000214`*^9, 3.396643026402529*^9}, {
   3.3966435194071074`*^9, 3.396643519717634*^9}, 3.3967113487085075`*^9, 
   3.9190492501298513`*^9},ExpressionUUID->"3b5cb79e-6d71-4338-9901-\
11f758634f96"],

Cell["ARCH model has also following weaknesses:", "Text",
 CellChangeTimes->{{3.3966430291572356`*^9, 3.3966431780930157`*^9}, {
   3.39664325339386*^9, 3.396643351478402*^9}, {3.5611112730609093`*^9, 
   3.561111310158146*^9}, 
   3.919049253574039*^9},ExpressionUUID->"e33e8265-54db-46d6-a56b-\
63d970c64892"],

Cell[CellGroupData[{

Cell["\<\
assumes that positive and negative shocks have the same effect on volatility, \
but empirical testing shows, that assets respond differently to positive and \
negative shocks.\
\>", "Item",
 CellChangeTimes->{{3.56111127605348*^9, 3.561111278637053*^9}},
 FontFamily->"Helvetica Neue Light",
 FontSize->14,ExpressionUUID->"050ee173-a264-4e9a-82f7-4b97d37d052c"],

Cell["\<\
model gives us description of the conditional variance, but does not explain \
the real behavior and source of variance.\
\>", "Item",
 CellChangeTimes->{{3.561111288170599*^9, 3.56111130049566*^9}},
 FontFamily->"Helvetica Neue Light",
 FontSize->14,ExpressionUUID->"2a87161b-76bd-4fd2-8cb0-2f607a0a09a4"],

Cell["\<\
ARCH models tend to over-predict the volatility as they respond slowly to \
large isolated shocks.\
\>", "Item",
 CellChangeTimes->{3.561111296665421*^9, 3.812791133981091*^9},
 FontFamily->"Helvetica Neue Light",
 FontSize->14,ExpressionUUID->"b3978753-1a72-4fa5-8a9c-c73ab3615b0a"]
}, Open  ]],

Cell[BoxData["\[IndentingNewLine]"], "Input",
 CellChangeTimes->{
  3.4649566868127327`*^9},ExpressionUUID->"f1a5006e-a0f5-4908-bb0d-\
44b6691c856e"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["GARCH models",
 FontFamily->"Helvetica Neue Bold Condensed"]], "Subtitle",
 CellChangeTimes->{{3.396546352830091*^9, 3.396546353410132*^9}, 
   3.3965464225150843`*^9, {3.3966332663309245`*^9, 3.3966332667303133`*^9}, 
   3.396633352998229*^9, {3.3966818916680975`*^9, 
   3.396681911224463*^9}},ExpressionUUID->"d0294403-fd97-4cd2-aa15-\
7231d752dad3"],

Cell[CellGroupData[{

Cell["\<\
GARCH(1,1)
\
\>", "Section",
 CellChangeTimes->{{3.396681927050598*^9, 3.3966819497718005`*^9}, {
   3.3966871360414205`*^9, 3.3966871374553924`*^9}, 
   3.3967113403613853`*^9},ExpressionUUID->"08be4031-535f-4b8a-b0cb-\
331ed3b2459d"],

Cell[TextData[{
 "GARCH(1,1) is most common for financial applications, as the dependencies \
are mostly very weak. It takes form of:\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "t"], "=", 
    RowBox[{
     SubscriptBox["\[Sigma]", "t"], 
     SubscriptBox["\[Epsilon]", "t"]}]}], TraditionalForm]],ExpressionUUID->
  "3164d511-9abc-4c72-8675-f495947bdfc8"],
 ",\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Sigma]", "t", "2"], "=", 
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], "+", 
     RowBox[{
      SubscriptBox["\[Alpha]", "i"], 
      SubsuperscriptBox["a", 
       RowBox[{"t", "-", "1"}], "2"]}], "+", 
     StyleBox[
      RowBox[{
       SubscriptBox["\[Beta]", "1"], 
       SubsuperscriptBox["\[Sigma]", 
        RowBox[{"t", "-", "1"}], "2"]}],
      FontColor->RGBColor[1, 0, 0]]}]}], TraditionalForm]],ExpressionUUID->
  "9cd7fad4-582d-49b4-af01-3913369e64e9"],
 ", \nwhere ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["\[Alpha]", "1"], "+", 
     SubscriptBox["\[Beta]", "1"]}], ")"}], "<", "1"}]],ExpressionUUID->
  "dc52eb61-cf67-4baa-bc19-d40b433b70a2"],
 ". Large past shocks of return and volatility in ",
 StyleBox["t-1",
  FontSlant->"Italic"],
 " gives large shocks to volatility in time ",
 StyleBox["t",
  FontSlant->"Italic"],
 ", thus volatility clustering is quite well captured.\n"
}], "Text",
 CellChangeTimes->{{3.3966871489195023`*^9, 3.396687281786975*^9}, {
   3.3966873937944546`*^9, 3.3966875312290173`*^9}, 3.3966879332189136`*^9, {
   3.3966883835592303`*^9, 3.396688387501361*^9}, {3.592053248412737*^9, 
   3.592053248442596*^9}, {3.856424038249453*^9, 3.856424038249633*^9}, {
   3.919049283816951*^9, 
   3.919049283817174*^9}},ExpressionUUID->"5e59f196-9c44-4f4f-9ebc-\
30f6a1973a2f"],

Cell[CellGroupData[{

Cell["Example  GARCH(1,1) artificial processes", "Subsection",
 CellChangeTimes->{{3.396546393955388*^9, 3.3965463976719475`*^9}, {
   3.3966897834559593`*^9, 3.3966897935021915`*^9}, {3.396706036866846*^9, 
   3.396706037818934*^9}, 
   3.396775574464938*^9},ExpressionUUID->"dd28c61a-f704-435e-b80f-\
95b0d266d185"],

Cell[TextData[{
 "Note that Condition ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"i", "=", "1"}], 
      RowBox[{"max", "(", 
       RowBox[{"m", ",", "s"}], ")"}]], 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["\[Alpha]", "i"], "+", 
       SubscriptBox["\[Beta]", "i"]}], ")"}]}], "<", "1"}], TraditionalForm]],
  ExpressionUUID->"7d7bb88b-f62d-4c6b-a217-93ed774978ee"],
 " must be met.\nInitial values are set to simulate GARCH(1,1) process with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Alpha]", "0"], "=", "0.5"}], TraditionalForm]],
  ExpressionUUID->"f7053f68-0a43-4097-8ea3-27e311619d6c"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Alpha]", "1"], "=", "0.2"}], TraditionalForm]],
  ExpressionUUID->"9d25e02b-640f-44a4-85fc-0475c8cde64f"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Beta]", "1"], "=", "0.4"}], TraditionalForm]],
  ExpressionUUID->"1ae7e61c-6d3e-4625-af96-75c69bf043cc"],
 "\n"
}], "Text",
 CellChangeTimes->{
  3.396678789844166*^9, {3.396686700139632*^9, 3.3966867124406033`*^9}, {
   3.396687100534904*^9, 3.3966871051068773`*^9}, {3.3966989166780367`*^9, 
   3.3966990689661407`*^9}, 
   3.561191848200427*^9},ExpressionUUID->"30a420bb-bc61-46eb-b054-\
777f472503d5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"SeedRandom", "[", "seed", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"egarch", "=", 
      RowBox[{"RandomReal", "[", 
       RowBox[{
        RowBox[{"NormalDistribution", "[", 
         RowBox[{"0", ",", "1"}], "]"}], ",", "500"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"garch", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", "500", "}"}]}], "]"}]}], ";", 
     RowBox[{"garcha", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", "500", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"garch", "[", 
       RowBox[{"[", "1", "]"}], "]"}], "=", 
      RowBox[{"Variance", "[", "egarch", "]"}]}], ";", 
     RowBox[{
      RowBox[{"garcha", "[", 
       RowBox[{"[", "1", "]"}], "]"}], "=", 
      RowBox[{
       RowBox[{"Sqrt", "[", 
        RowBox[{"garch", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "]"}], " ", 
       RowBox[{"egarch", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"garch", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "=", 
         RowBox[{"paramgm0", "+", 
          RowBox[{"paramgm1", " ", 
           RowBox[{
            RowBox[{"garcha", "[", 
             RowBox[{"[", 
              RowBox[{"i", "-", "1"}], "]"}], "]"}], "^", "2"}]}], "+", 
          RowBox[{"paramgm2", " ", 
           RowBox[{"garch", "[", 
            RowBox[{"[", 
             RowBox[{"i", "-", "1"}], "]"}], "]"}]}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"garcha", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "=", 
         RowBox[{
          RowBox[{"Sqrt", "[", 
           RowBox[{"garch", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "]"}], " ", 
          RowBox[{"egarch", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
       ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "2", ",", 
         RowBox[{"Length", "[", "egarch", "]"}]}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"acfgarch", "=", 
      RowBox[{"CorrelationFunction", "[", 
       RowBox[{
        RowBox[{"garcha", "^", "2"}], ",", 
        RowBox[{"{", "30", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"stdevgarch", "=", 
      RowBox[{"2", "/", 
       RowBox[{"Sqrt", "[", "500", "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"pacfgarch", "=", 
      RowBox[{"PartialCorrelationFunction", "[", 
       RowBox[{
        RowBox[{"garcha", "^", "2"}], ",", 
        RowBox[{"{", "30", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"paramgm1", "+", "paramgm2"}], ")"}], "<", "1"}], "===", 
        "True"}], ",", "\[IndentingNewLine]", 
       RowBox[{"ListPlot", "[", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"type", "===", "\"\<Sample GARCH(1,1)\>\""}], ",", 
