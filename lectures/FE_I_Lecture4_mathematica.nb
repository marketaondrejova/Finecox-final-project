Cell[CellGroupData[{

Cell["GARCH-M model", "Section",
 CellChangeTimes->{{3.396706842702965*^9, 3.3967068542032056`*^9}, 
   3.396711341508773*^9, 
   3.9190493321511602`*^9},ExpressionUUID->"692bd050-87d2-470e-a90a-\
5454ab74a0f5"],

Cell[TextData[{
 "The return of a security may sometimes depend directly on volatility. To \
model this, we use GARCH in mean (GARCH-M) model. \nGARCH(1,1) - M is \
formalized as:\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["r", "t"], "=", 
    RowBox[{"\[Mu]", "+", 
     SubsuperscriptBox["c\[Sigma]", "t", "2"], "+", 
     SubscriptBox["a", "t"]}]}], TraditionalForm]],ExpressionUUID->
  "709ccd37-3ff9-4d7a-94d5-4ccaf51ba3fd"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "t"], "=", 
    RowBox[{
     SubscriptBox["\[Sigma]", "t"], 
     SubscriptBox["\[Epsilon]", "t"]}]}], TraditionalForm]],ExpressionUUID->
  "339106c3-c363-4fe3-a506-5864e78444f5"],
 ",\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Sigma]", "t", "2"], "=", 
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], "+", 
     RowBox[{
      SubscriptBox["\[Alpha]", "i"], 
      SubsuperscriptBox["a", 
       RowBox[{"t", "-", "1"}], "2"]}], "+", 
     RowBox[{
      SubscriptBox["\[Beta]", "1"], 
      SubsuperscriptBox["\[Sigma]", 
       RowBox[{"t", "-", "1"}], "2"]}]}]}], TraditionalForm]],ExpressionUUID->
  "246c88f5-8830-4f39-9ab7-92f9ad476833"],
 ", \n\nwhere \[Mu] and \[ScriptC] are constant. \[ScriptC] is also called \
risk premium"
}], "Text",
 CellChangeTimes->{{3.3967068565175104`*^9, 3.396707010384616*^9}, 
   3.561191895281517*^9},ExpressionUUID->"3569f24c-688c-48c2-9349-\
7224bef592d1"],

Cell[CellGroupData[{

Cell["Example  GARCH(1,1)-M artificial processes", "Subsection",
 CellChangeTimes->{{3.396546393955388*^9, 3.3965463976719475`*^9}, {
   3.3966897834559593`*^9, 3.3966897935021915`*^9}, {3.396706036866846*^9, 
   3.396706037818934*^9}, {3.3967108741177893`*^9, 3.39671087495465*^9}, 
   3.3967755769511075`*^9},ExpressionUUID->"7e8f54e0-f4c5-449e-9453-\
cbeb22c369b7"],

Cell["\<\
Note, that with positive risk premium c, returns are positively skewed, as \
they are positively related to its past volatility\
\>", "Text",
 CellChangeTimes->{{3.3967108784065776`*^9, 3.3967109564972825`*^9}, {
  3.396711060149828*^9, 3.396711065641664*^9}, {3.3967110988026276`*^9, 
  3.3967111137274537`*^9}},ExpressionUUID->"e678cb0a-9063-4900-aeec-\
ca50cca7a9ee"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"SeedRandom", "[", "seed", "]"}], ";", "\[IndentingNewLine]", 
    "\[IndentingNewLine]", 
    RowBox[{"egam", "=", 
     RowBox[{"RandomReal", "[", 
      RowBox[{
       RowBox[{"NormalDistribution", "[", 
        RowBox[{"0", ",", "1"}], "]"}], ",", "500"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"garchm", "=", 
     RowBox[{"Table", "[", 
      RowBox[{"1", ",", 
       RowBox[{"{", "500", "}"}]}], "]"}]}], ";", 
    RowBox[{"garchma", "=", 
     RowBox[{"Table", "[", 
      RowBox[{"1", ",", 
       RowBox[{"{", "500", "}"}]}], "]"}]}], ";", 
    RowBox[{"garchmr", "=", 
     RowBox[{"Table", "[", 
      RowBox[{"1", ",", 
       RowBox[{"{", "500", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"garchm", "[", 
      RowBox[{"[", "1", "]"}], "]"}], "=", 
     RowBox[{"Variance", "[", "egam", "]"}]}], ";", 
    RowBox[{
     RowBox[{"garchma", "[", 
      RowBox[{"[", "1", "]"}], "]"}], "=", 
     RowBox[{
      RowBox[{"Sqrt", "[", 
       RowBox[{"garchm", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "]"}], " ", 
      RowBox[{"egam", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
    "\[IndentingNewLine]", 
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"garchm", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "=", 
        RowBox[{"paramginm0", "+", 
         RowBox[{"paramginm1", "*", 
          RowBox[{
           RowBox[{"garchma", "[", 
            RowBox[{"[", 
             RowBox[{"i", "-", "1"}], "]"}], "]"}], "^", "2"}]}], "+", 
         RowBox[{"paramginm2", "*", 
          RowBox[{"garchm", "[", 
           RowBox[{"[", 
            RowBox[{"i", "-", "1"}], "]"}], "]"}]}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"garchma", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "=", 
        RowBox[{
         RowBox[{"Sqrt", "[", 
          RowBox[{"garchm", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "]"}], " ", 
         RowBox[{"egam", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"garchmr", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "=", 
        RowBox[{
         RowBox[{"const", "*", 
          RowBox[{"garchm", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], "+", 
         RowBox[{"garchma", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
      ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "2", ",", 
        RowBox[{"Length", "[", "egam", "]"}]}], "}"}]}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"garchinm", "=", "garchmr"}], ";", "\[IndentingNewLine]", 
    RowBox[{"garchinm2", "=", "garchm"}], ";", "\[IndentingNewLine]", 
    RowBox[{"acfgarchinm", "=", 
     RowBox[{"CorrelationFunction", "[", 
      RowBox[{"garchinm2", ",", 
       RowBox[{"{", "30", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"stdevgarchinm", "=", 
     RowBox[{"2", "/", 
      RowBox[{"Sqrt", "[", "500", "]"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"pacfgarchinm", "=", 
     RowBox[{"PartialCorrelationFunction", "[", 
      RowBox[{"garchinm2", ",", 
       RowBox[{"{", "30", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"paramginm1", "+", "paramginm2"}], ")"}], "<", "1"}], "===", 
       "True"}], ",", "\[IndentingNewLine]", 
      RowBox[{"ListPlot", "[", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"type", "===", "\"\<Sample GARCH(1,1)-M\>\""}], ",", 
          "garchinm", ",", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
            "type", "===", 
             "\"\<ACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \
\(2\)]\)\>\""}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{"z", "=", "stdevgarchinm"}], ",", 
                RowBox[{"{", 
                 RowBox[{"z", ",", "0", ",", "30"}], "}"}]}], "]"}], ",", 
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{"z", "=", 
                 RowBox[{"-", "stdevgarchinm"}]}], ",", 
                RowBox[{"{", 
                 RowBox[{"z", ",", "0", ",", "30"}], "}"}]}], "]"}], ",", 
              "acfgarchinm"}], "}"}], ",", "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{"z", "=", "stdevgarchinm"}], ",", 
                RowBox[{"{", 
                 RowBox[{"z", ",", "0", ",", "30"}], "}"}]}], "]"}], ",", 
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{"z", "=", 
                 RowBox[{"-", "stdevgarchinm"}]}], ",", 
                RowBox[{"{", 
                 RowBox[{"z", ",", "0", ",", "30"}], "}"}]}], "]"}], ",", 
              "pacfgarchinm"}], "}"}]}], "]"}]}], "]"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"Joined", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"True", ",", "True", ",", "False"}], "}"}]}], ",", 
        RowBox[{"Frame", "\[Rule]", "True"}], ",", 
        RowBox[{"Filling", "\[Rule]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"type", "=!=", "\"\<Sample GARCH(1,1)-M\>\""}], ",", 
           RowBox[{"{", 
            RowBox[{"3", "\[Rule]", " ", "Axis"}], "}"}], ",", "None"}], 
          "]"}]}], ",", 
        RowBox[{"FillingStyle", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"3", "\[Rule]", "Black"}], "}"}]}], ",", 
        RowBox[{"PlotStyle", "\[Rule]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"type", "=!=", "\"\<Sample GARCH(1,1)-M\>\""}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"Dashing", "[", "Large", "]"}], ",", " ", 
               RowBox[{"Thickness", "[", "Medium", "]"}], ",", " ", "Red"}], 
              "}"}], ",", " ", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"Dashing", "[", "Large", "]"}], ",", " ", 
               RowBox[{"Thickness", "[", "Medium", "]"}], ",", " ", "Red"}], 
              "}"}], ",", " ", "Black"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Thickness", "[", "Medium", "]"}], ",", " ", "Red"}], 
            "}"}]}], "]"}]}], ",", 
        RowBox[{"AxesOrigin", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"0", ",", "0"}], "}"}]}], ",", 
        RowBox[{"PlotRange", "\[Rule]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"type", "===", "\"\<Sample GARCH(1,1)-M\>\""}], ",", "All",
            ",", 
           RowBox[{"{", 
            RowBox[{"0.5", ",", "0.5"}], "}"}]}], "]"}]}]}], "]"}], ",", 
      RowBox[{"Style", "[", 
       RowBox[{
       "\"\<Please input (\!\(\*SubscriptBox[\(\[Alpha]\), \
\(i\)]\)+\!\(\*SubscriptBox[\(\[Beta]\), \(i\)]\))<1\>\"", ",", "Bold", ",", 
        "12"}], "]"}]}], "]"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"type", ",", "\"\<Sample GARCH(1,1)-M\>\"", ",", "\"\<\>\""}], 
      "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
      "\"\<Sample GARCH(1,1)-M\>\"", ",", 
       "\"\<ACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \
\(2\)]\)\>\"", ",", 
       "\"\<PACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\)]\)\>\
\""}], "}"}]}], "}"}], ",", "Delimiter", ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"const", ",", "0.5", ",", "\"\<risk premium c\>\""}], "}"}], 
     ",", 
     RowBox[{"-", "1.5"}], ",", "1.5", ",", 
     RowBox[{"Appearance", "\[Rule]", "\"\<Labeled\>\""}]}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "paramginm0", ",", "0.5", ",", 
       "\"\<\!\(\*SubscriptBox[\(\[Alpha]\), \(0\)]\)\>\""}], "}"}], ",", 
     "0.01", ",", "1", ",", 
     RowBox[{"Appearance", "\[Rule]", "\"\<Labeled\>\""}]}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "paramginm1", ",", "0.4", ",", 
       "\"\<\!\(\*SubscriptBox[\(\[Alpha]\), \(1\)]\)\>\""}], "}"}], ",", "0",
      ",", "1", ",", 
     RowBox[{"Appearance", "\[Rule]", "\"\<Labeled\>\""}]}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "paramginm2", ",", "0.2", ",", 
       "\"\<\!\(\*SubscriptBox[\(\[Beta]\), \(1\)]\)\>\""}], "}"}], ",", "0", 
     ",", "1", ",", 
     RowBox[{"Appearance", "\[Rule]", "\"\<Labeled\>\""}]}], "}"}], ",", 
   "Delimiter", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"seed", ",", "77777", ",", "\"\<New Random Case\>\""}], "}"}], 
     ",", "10000", ",", "999999", ",", "1"}], "}"}], ",", 
   RowBox[{"Button", "[", 
    RowBox[{"\"\<Export Simulated Series\>\"", ",", 
     RowBox[{"Export", "[", 
      RowBox[{"\"\<garch_m.txt\>\"", ",", "garchinm"}], "]"}], ",", 
     RowBox[{"ImageSize", "\[Rule]", "200"}]}], "]"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.396710371159746*^9, 3.3967108445024977`*^9}, {
   3.3967139611330986`*^9, 3.3967139611858296`*^9}, {3.396719809341797*^9, 
   3.396719819966117*^9}, {3.3969568431046925`*^9, 3.3969568666822853`*^9}, {
   3.4649542043287497`*^9, 3.4649542179748373`*^9}, {3.464954289627597*^9, 
   3.464954308023947*^9}, 3.4649597614202623`*^9, {3.5930619552893963`*^9, 
   3.5930619648425913`*^9}, {3.593062027129323*^9, 3.5930620406203117`*^9}, {
   3.593071055100336*^9, 3.593071183270691*^9}, {3.5930712450810003`*^9, 
   3.593071247261147*^9}, {3.593071277341156*^9, 3.5930714032689247`*^9}, {
   3.593071440138123*^9, 3.5930714873526983`*^9}, {3.59307151907015*^9, 
   3.593071546725092*^9}, 
   3.593071648129519*^9},ExpressionUUID->"52a3d892-616a-418f-9323-\
820ba9a26224"],

Cell[BoxData[
 TagBox[
  StyleBox[
   DynamicModuleBox[{$CellContext`const$$ = -0.020000000000000018`, \
$CellContext`paramginm0$$ = 0.39, $CellContext`paramginm1$$ = 
    0.342, $CellContext`paramginm2$$ = 0.503, $CellContext`seed$$ = 
    81057, $CellContext`type$$ = "Sample GARCH(1,1)-M", Typeset`show$$ = True,
     Typeset`bookmarkList$$ = {}, Typeset`bookmarkMode$$ = "Menu", 
    Typeset`animator$$, Typeset`animvar$$ = 1, Typeset`name$$ = 
    "\"untitled\"", Typeset`specs$$ = {{{
       Hold[$CellContext`type$$], "Sample GARCH(1,1)-M", ""}, {
      "Sample GARCH(1,1)-M", 
       "ACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\)]\)", 
       "PACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\)]\)"}}, {{
       Hold[$CellContext`const$$], 0.5, "risk premium c"}, -1.5, 1.5}, {{
       Hold[$CellContext`paramginm0$$], 0.5, 
       "\!\(\*SubscriptBox[\(\[Alpha]\), \(0\)]\)"}, 0.01, 1}, {{
       Hold[$CellContext`paramginm1$$], 0.4, 
       "\!\(\*SubscriptBox[\(\[Alpha]\), \(1\)]\)"}, 0, 1}, {{
       Hold[$CellContext`paramginm2$$], 0.2, 
       "\!\(\*SubscriptBox[\(\[Beta]\), \(1\)]\)"}, 0, 1}, {{
       Hold[$CellContext`seed$$], 77777, "New Random Case"}, 10000, 999999, 
      1}, {
      Hold[
       Button["Export Simulated Series", 
        Export["garch_m.txt", $CellContext`garchinm], ImageSize -> 200]], 
      Manipulate`Dump`ThisIsNotAControl}}, Typeset`size$$ = {
    1080., {340., 357.}}, Typeset`update$$ = 0, Typeset`initDone$$, 
    Typeset`skipInitDone$$ = True, $CellContext`type$1922$$ = 
    0, $CellContext`const$1923$$ = 0, $CellContext`paramginm0$1924$$ = 
    0, $CellContext`paramginm1$1925$$ = 0, $CellContext`paramginm2$1926$$ = 
    0, $CellContext`seed$1927$$ = 0}, 
    DynamicBox[Manipulate`ManipulateBoxes[
     1, StandardForm, 
      "Variables" :> {$CellContext`const$$ = 0.5, $CellContext`paramginm0$$ = 
        0.5, $CellContext`paramginm1$$ = 0.4, $CellContext`paramginm2$$ = 
        0.2, $CellContext`seed$$ = 77777, $CellContext`type$$ = 
        "Sample GARCH(1,1)-M"}, "ControllerVariables" :> {
        Hold[$CellContext`type$$, $CellContext`type$1922$$, 0], 
        Hold[$CellContext`const$$, $CellContext`const$1923$$, 0], 
        Hold[$CellContext`paramginm0$$, $CellContext`paramginm0$1924$$, 0], 
        Hold[$CellContext`paramginm1$$, $CellContext`paramginm1$1925$$, 0], 
        Hold[$CellContext`paramginm2$$, $CellContext`paramginm2$1926$$, 0], 
        Hold[$CellContext`seed$$, $CellContext`seed$1927$$, 0]}, 
      "OtherVariables" :> {
       Typeset`show$$, Typeset`bookmarkList$$, Typeset`bookmarkMode$$, 
        Typeset`animator$$, Typeset`animvar$$, Typeset`name$$, 
        Typeset`specs$$, Typeset`size$$, Typeset`update$$, Typeset`initDone$$,
         Typeset`skipInitDone$$}, 
      "Body" :> (
       SeedRandom[$CellContext`seed$$]; $CellContext`egam = RandomReal[
          NormalDistribution[0, 1], 500]; $CellContext`garchm = 
        Table[1, {500}]; $CellContext`garchma = 
        Table[1, {500}]; $CellContext`garchmr = Table[1, {500}]; 
       Part[$CellContext`garchm, 1] = Variance[$CellContext`egam]; 
       Part[$CellContext`garchma, 1] = Sqrt[
           Part[$CellContext`garchm, 1]] Part[$CellContext`egam, 1]; 
       Do[Part[$CellContext`garchm, $CellContext`i] = \
$CellContext`paramginm0$$ + $CellContext`paramginm1$$ 
            Part[$CellContext`garchma, $CellContext`i - 
               1]^2 + $CellContext`paramginm2$$ 
            Part[$CellContext`garchm, $CellContext`i - 1]; 
         Part[$CellContext`garchma, $CellContext`i] = Sqrt[
             Part[$CellContext`garchm, $CellContext`i]] 
           Part[$CellContext`egam, $CellContext`i]; 
         Part[$CellContext`garchmr, $CellContext`i] = $CellContext`const$$ 
            Part[$CellContext`garchm, $CellContext`i] + 
           Part[$CellContext`garchma, $CellContext`i]; 
         Null, {$CellContext`i, 2, 
          
          Length[$CellContext`egam]}]; $CellContext`garchinm = \
$CellContext`garchmr; $CellContext`garchinm2 = $CellContext`garchm; \
$CellContext`acfgarchinm = 
        CorrelationFunction[$CellContext`garchinm2, {
          30}]; $CellContext`stdevgarchinm = 
        2/Sqrt[500]; $CellContext`pacfgarchinm = 
        PartialCorrelationFunction[$CellContext`garchinm2, {30}]; 
       If[$CellContext`paramginm1$$ + $CellContext`paramginm2$$ < 1 === True, 
         ListPlot[
          
          If[$CellContext`type$$ === 
           "Sample GARCH(1,1)-M", $CellContext`garchinm, 
           
           If[$CellContext`type$$ === 
            "ACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\)]\)", {
             
             Table[$CellContext`z = $CellContext`stdevgarchinm, \
{$CellContext`z, 0, 30}], 
             
             Table[$CellContext`z = -$CellContext`stdevgarchinm, \
{$CellContext`z, 0, 30}], $CellContext`acfgarchinm}, {
             
             Table[$CellContext`z = $CellContext`stdevgarchinm, \
{$CellContext`z, 0, 30}], 
             
             Table[$CellContext`z = -$CellContext`stdevgarchinm, \
{$CellContext`z, 0, 30}], $CellContext`pacfgarchinm}]], 
          Joined -> {True, True, False}, Frame -> True, Filling -> 
          If[$CellContext`type$$ =!= "Sample GARCH(1,1)-M", {3 -> Axis}, 
            None], FillingStyle -> {3 -> Black}, PlotStyle -> 
          If[$CellContext`type$$ =!= "Sample GARCH(1,1)-M", {{
              Dashing[Large], 
              Thickness[Medium], Red}, {
              Dashing[Large], 
              Thickness[Medium], Red}, Black}, {
             Thickness[Medium], Red}], AxesOrigin -> {0, 0}, PlotRange -> 
          If[$CellContext`type$$ === "Sample GARCH(1,1)-M", All, {0.5, 0.5}]], 
         Style[
         "Please input (\!\(\*SubscriptBox[\(\[Alpha]\), \
\(i\)]\)+\!\(\*SubscriptBox[\(\[Beta]\), \(i\)]\))<1", Bold, 12]]), 
      "Specifications" :> {{{$CellContext`type$$, "Sample GARCH(1,1)-M", 
          ""}, {"Sample GARCH(1,1)-M", 
          "ACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\)]\)", 
          "PACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\)]\)"}},
         Delimiter, {{$CellContext`const$$, 0.5, "risk premium c"}, -1.5, 1.5,
          Appearance -> 
         "Labeled"}, {{$CellContext`paramginm0$$, 0.5, 
          "\!\(\*SubscriptBox[\(\[Alpha]\), \(0\)]\)"}, 0.01, 1, Appearance -> 
         "Labeled"}, {{$CellContext`paramginm1$$, 0.4, 
          "\!\(\*SubscriptBox[\(\[Alpha]\), \(1\)]\)"}, 0, 1, Appearance -> 
         "Labeled"}, {{$CellContext`paramginm2$$, 0.2, 
          "\!\(\*SubscriptBox[\(\[Beta]\), \(1\)]\)"}, 0, 1, Appearance -> 
         "Labeled"}, 
        Delimiter, {{$CellContext`seed$$, 77777, "New Random Case"}, 10000, 
         999999, 1}, 
        Button["Export Simulated Series", 
         Export["garch_m.txt", $CellContext`garchinm], ImageSize -> 200]}, 
      "Options" :> {}, "DefaultOptions" :> {}],
