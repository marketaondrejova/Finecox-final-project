 TagBox[
  StyleBox[
   DynamicModuleBox[{$CellContext`paramgm0$$ = 
    0.119, $CellContext`paramgm1$$ = 0.365, $CellContext`paramgm2$$ = 
    0.625, $CellContext`seed$$ = 125624, $CellContext`type$$ = 
    "Sample GARCH(1,1)", Typeset`show$$ = True, Typeset`bookmarkList$$ = {}, 
    Typeset`bookmarkMode$$ = "Menu", Typeset`animator$$, Typeset`animvar$$ = 
    1, Typeset`name$$ = "\"untitled\"", Typeset`specs$$ = {{{
       Hold[$CellContext`type$$], "Sample GARCH(1,1)", ""}, {
      "Sample GARCH(1,1)", "GARCH(1,1) volatility"}}, {{
       Hold[$CellContext`type$$], "Sample GARCH(1,1)", ""}, {
      "ACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\)]\)", 
       "PACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\)]\)"}}, {{
       Hold[$CellContext`paramgm0$$], 0.5, 
       "\!\(\*SubscriptBox[\(\[Alpha]\), \(0\)]\)"}, 0.01, 1}, {{
       Hold[$CellContext`paramgm1$$], 0.4, 
       "\!\(\*SubscriptBox[\(\[Alpha]\), \(1\)]\)"}, 0, 1}, {{
       Hold[$CellContext`paramgm2$$], 0.2, 
       "\!\(\*SubscriptBox[\(\[Beta]\), \(1\)]\)"}, 0, 1}, {{
       Hold[$CellContext`seed$$], 77777, "New Random Case"}, 10000, 999999, 
      1}, {
      Hold[
       Button["Export Simulated Series", 
        Export["garch11.txt", $CellContext`garch], ImageSize -> 200]], 
      Manipulate`Dump`ThisIsNotAControl}}, Typeset`size$$ = {
    1080., {336., 353.}}, Typeset`update$$ = 0, Typeset`initDone$$, 
    Typeset`skipInitDone$$ = True, $CellContext`type$136017$$ = 
    False, $CellContext`paramgm0$136018$$ = 
    0, $CellContext`paramgm1$136019$$ = 0, $CellContext`paramgm2$136020$$ = 
    0, $CellContext`seed$136021$$ = 0}, 
    DynamicBox[Manipulate`ManipulateBoxes[
     1, StandardForm, 
      "Variables" :> {$CellContext`paramgm0$$ = 0.5, $CellContext`paramgm1$$ = 
        0.4, $CellContext`paramgm2$$ = 0.2, $CellContext`seed$$ = 
        77777, $CellContext`type$$ = "Sample GARCH(1,1)"}, 
      "ControllerVariables" :> {
        Hold[$CellContext`type$$, $CellContext`type$136017$$, False], 
        Hold[$CellContext`paramgm0$$, $CellContext`paramgm0$136018$$, 0], 
        Hold[$CellContext`paramgm1$$, $CellContext`paramgm1$136019$$, 0], 
        Hold[$CellContext`paramgm2$$, $CellContext`paramgm2$136020$$, 0], 
        Hold[$CellContext`seed$$, $CellContext`seed$136021$$, 0]}, 
      "OtherVariables" :> {
       Typeset`show$$, Typeset`bookmarkList$$, Typeset`bookmarkMode$$, 
        Typeset`animator$$, Typeset`animvar$$, Typeset`name$$, 
        Typeset`specs$$, Typeset`size$$, Typeset`update$$, Typeset`initDone$$,
         Typeset`skipInitDone$$}, 
      "Body" :> (
       SeedRandom[$CellContext`seed$$]; $CellContext`egarch = RandomReal[
          NormalDistribution[0, 1], 500]; $CellContext`garch = 
        Table[0, {500}]; $CellContext`garcha = Table[0, {500}]; 
       Part[$CellContext`garch, 1] = Variance[$CellContext`egarch]; 
       Part[$CellContext`garcha, 1] = Sqrt[
           Part[$CellContext`garch, 1]] Part[$CellContext`egarch, 1]; 
       Do[Part[$CellContext`garch, $CellContext`i] = $CellContext`paramgm0$$ + \
$CellContext`paramgm1$$ 
            Part[$CellContext`garcha, $CellContext`i - 
               1]^2 + $CellContext`paramgm2$$ 
            Part[$CellContext`garch, $CellContext`i - 1]; 
         Part[$CellContext`garcha, $CellContext`i] = Sqrt[
             Part[$CellContext`garch, $CellContext`i]] 
           Part[$CellContext`egarch, $CellContext`i]; 
         Null, {$CellContext`i, 2, 
          Length[$CellContext`egarch]}]; $CellContext`acfgarch = 
        CorrelationFunction[$CellContext`garcha^2, {
          30}]; $CellContext`stdevgarch = 2/Sqrt[500]; $CellContext`pacfgarch = 
        PartialCorrelationFunction[$CellContext`garcha^2, {30}]; 
       If[$CellContext`paramgm1$$ + $CellContext`paramgm2$$ < 1 === True, 
         ListPlot[
          If[$CellContext`type$$ === "Sample GARCH(1,1)", $CellContext`garcha, 
           If[$CellContext`type$$ === "GARCH(1,1) volatility", 
            Sqrt[$CellContext`garch], 
            
            If[$CellContext`type$$ === 
             "ACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \
\(2\)]\)", {
              
              Table[$CellContext`z = $CellContext`stdevgarch, {$CellContext`z,
                 0, 30}], 
              
              Table[$CellContext`z = -$CellContext`stdevgarch, \
{$CellContext`z, 0, 30}], $CellContext`acfgarch}, {
              
              Table[$CellContext`z = $CellContext`stdevgarch, {$CellContext`z,
                 0, 30}], 
              
              Table[$CellContext`z = -$CellContext`stdevgarch, \
{$CellContext`z, 0, 30}], $CellContext`pacfgarch}]]], 
          Joined -> {True, True, False}, Frame -> True, Filling -> 
          If[$CellContext`type$$ =!= "Sample GARCH(1,1)", 
            
            If[$CellContext`type$$ =!= "GARCH(1,1) volatility", {3 -> Axis}, 
             None], None], FillingStyle -> {3 -> Black}, PlotStyle -> 
          If[$CellContext`type$$ =!= "Sample GARCH(1,1)", 
            If[$CellContext`type$$ =!= "GARCH(1,1) volatility", {{
               Dashing[Large], 
               Thickness[Medium], Red}, {
               Dashing[Large], 
               Thickness[Medium], Red}, Black}, {
              Thickness[Medium], Red}], {
             Thickness[Medium], Red}], AxesOrigin -> {0, 0}, PlotRange -> 
          If[$CellContext`type$$ === "Sample GARCH(1,1)", {-10, 10}, 
            
            If[$CellContext`type$$ === "GARCH(1,1) volatility", {0, 
             15}, {-0.5, 0.5}]]], 
         Style[
         "Please input (\!\(\*SubscriptBox[\(\[Alpha]\), \
\(i\)]\)+\!\(\*SubscriptBox[\(\[Beta]\), \(i\)]\))<1", Bold, 12]]), 
      "Specifications" :> {{{$CellContext`type$$, "Sample GARCH(1,1)", ""}, {
         "Sample GARCH(1,1)", "GARCH(1,1) volatility"}}, 
        Delimiter, {{$CellContext`type$$, "Sample GARCH(1,1)", ""}, {
         "ACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\)]\)", 
          "PACF function of \!\(\*SubsuperscriptBox[\(a\), \(t\), \(2\)]\)"}},
         Delimiter, {{$CellContext`paramgm0$$, 0.5, 
          "\!\(\*SubscriptBox[\(\[Alpha]\), \(0\)]\)"}, 0.01, 1, Appearance -> 
         "Labeled"}, {{$CellContext`paramgm1$$, 0.4, 
          "\!\(\*SubscriptBox[\(\[Alpha]\), \(1\)]\)"}, 0, 1, Appearance -> 
         "Labeled"}, {{$CellContext`paramgm2$$, 0.2, 
          "\!\(\*SubscriptBox[\(\[Beta]\), \(1\)]\)"}, 0, 1, Appearance -> 
         "Labeled"}, 
        Delimiter, {{$CellContext`seed$$, 77777, "New Random Case"}, 10000, 
         999999, 1}, 
        Button["Export Simulated Series", 
         Export["garch11.txt", $CellContext`garch], ImageSize -> 200]}, 
