Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"SeedRandom", "[", "seed", "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"eiga", "=", 
     RowBox[{"RandomReal", "[", 
      RowBox[{
       RowBox[{"NormalDistribution", "[", 
        RowBox[{"0", ",", "1"}], "]"}], ",", "500"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"igarch", "=", 
     RowBox[{"Table", "[", 
      RowBox[{"1", ",", 
       RowBox[{"{", "500", "}"}]}], "]"}]}], ";", 
    RowBox[{"igarcha", "=", 
     RowBox[{"Table", "[", 
      RowBox[{"1", ",", 
       RowBox[{"{", "500", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"igarch", "[", 
      RowBox[{"[", "1", "]"}], "]"}], "=", 
     RowBox[{"Variance", "[", "eiga", "]"}]}], ";", 
    RowBox[{
     RowBox[{"igarcha", "[", 
      RowBox[{"[", "1", "]"}], "]"}], "=", 
     RowBox[{
      RowBox[{"Sqrt", "[", 
       RowBox[{"igarch", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "]"}], " ", 
      RowBox[{"eiga", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"igarch", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "=", 
        RowBox[{"alfa0", "+", 
         RowBox[{"beta1", "*", 
          RowBox[{"igarch", "[", 
           RowBox[{"[", 
            RowBox[{"i", "-", "1"}], "]"}], "]"}]}], " ", "+", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "-", "beta1"}], ")"}], "*", 
          RowBox[{
           RowBox[{"igarcha", "[", 
            RowBox[{"[", 
             RowBox[{"i", "-", "1"}], "]"}], "]"}], "^", "2"}]}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"igarcha", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "=", 
        RowBox[{
         RowBox[{"Sqrt", "[", 
          RowBox[{"igarch", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "]"}], " ", 
         RowBox[{"eiga", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
      ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "2", ",", 
        RowBox[{"Length", "[", "eiga", "]"}]}], "}"}]}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"beta1", "<", "1"}], "===", "True"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"ListPlot", "[", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"type", "===", "\"\<Simulated series\>\""}], ",", "igarcha",
           ",", "igarch"}], "]"}], ",", 
        RowBox[{"Joined", "\[Rule]", "True"}], ",", 
        RowBox[{"Frame", "\[Rule]", "True"}], ",", 
        RowBox[{"PlotStyle", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Dashing", "[", "None", "]"}], ",", " ", 
           RowBox[{"Thickness", "[", "Medium", "]"}], ",", " ", "Red"}], 
          "}"}]}], ",", 
        RowBox[{"AxesOrigin", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"0", ",", "0"}], "}"}]}], ",", 
        RowBox[{"PlotRange", "\[Rule]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"type", "===", "\"\<Simulated series\>\""}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "12"}], ",", "12"}], "}"}], ",", "All"}], "]"}]}]}],
        "]"}], ",", "\[IndentingNewLine]", 
      RowBox[{"Style", "[", 
       RowBox[{
       "\"\<Please input \!\(\*SubscriptBox[\(\[Beta]\), \(i\)]\)<1\>\"", ",",
         "Bold", ",", "12"}], "]"}]}], "]"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"Style", "[", 
    RowBox[{"\"\<IGARCH(1,1)\>\"", ",", "12", ",", "Bold"}], "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"type", ",", "\"\<Simulated series\>\"", ",", "\"\<\>\""}], 
      "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
      "\"\<Simulated series\>\"", ",", "\"\<Simulated Volatility\>\""}], 
      "}"}]}], "}"}], ",", "Delimiter", ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "alfa0", ",", "0.5", ",", 
       "\"\<\!\(\*SubscriptBox[\(\[Alpha]\), \(0\)]\)\>\""}], "}"}], ",", 
     "0.01", ",", "1", ",", 
     RowBox[{"Appearance", "\[Rule]", "\"\<Labeled\>\""}]}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "beta1", ",", "0.2", ",", 
       "\"\<\!\(\*SubscriptBox[\(\[Beta]\), \(1\)]\)\>\""}], "}"}], ",", "0", 
     ",", "1", ",", 
     RowBox[{"Appearance", "\[Rule]", "\"\<Labeled\>\""}]}], "}"}], ",", 
   "Delimiter", ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"seed", ",", "77777", ",", "\"\<New Random Case\>\""}], "}"}], 
     ",", "10000", ",", "999999", ",", "1"}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Button", "[", 
    RowBox[{"\"\<Export Simulated Series\>\"", ",", 
     RowBox[{"Export", "[", 
      RowBox[{"\"\<igarch.txt\>\"", ",", "igarcha"}], "]"}], ",", 
     RowBox[{"ImageSize", "\[Rule]", "200"}]}], "]"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.3969520755358133`*^9, 3.396952120298573*^9}, {
