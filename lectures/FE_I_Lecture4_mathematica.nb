Cell[CellGroupData[{

Cell["IGARCH - Integrated GARCH", "Section",
 CellChangeTimes->{{3.396937631261087*^9, 3.3969376475813313`*^9}, {
  3.3969514067836943`*^9, 
  3.396951414304697*^9}},ExpressionUUID->"1dfb016a-30c4-46f7-a5e5-\
ea45f211d5a1"],

Cell[TextData[{
 "IGARCH models are unit-root (integrated) GARCH models, their key feature \
is, that past squared shocks is persistent. \n\nIGARCH(1,1) is formalized as:\
\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "t"], "=", 
    RowBox[{
     SubscriptBox["\[Sigma]", "t"], 
     SubscriptBox["\[Epsilon]", "t"]}]}], TraditionalForm]],ExpressionUUID->
  "beaa06e4-61d6-4688-8b46-f0a3e4a23217"],
 ",\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Sigma]", "t", "2"], "=", 
    RowBox[{
     SubscriptBox["\[Alpha]", "0"], "+", 
     RowBox[{
      SubscriptBox["\[Beta]", "1"], 
      SubsuperscriptBox["\[Sigma]", 
       RowBox[{"t", "-", "1"}], "2"]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", 
        SubscriptBox["\[Beta]", "1"]}], ")"}], 
      SubsuperscriptBox["a", 
       RowBox[{"t", "-", "1"}], "2"]}]}]}], TraditionalForm]],ExpressionUUID->
  "002b7ff2-7dda-40f3-b1b1-1e211f77b1b2"],
 "\n"
}], "Text",
 CellChangeTimes->{{3.396951418072034*^9, 3.3969514642360716`*^9}, {
   3.39695162814062*^9, 3.3969517263394127`*^9}, 3.3969519621553745`*^9, {
   3.4062701884247518`*^9, 3.4062701914987516`*^9}, 
   3.529675639058058*^9},ExpressionUUID->"8157e689-6498-4ea2-9a55-\
7ad6b93b6536"],

